---
// Hero padrão de duas colunas (igual às páginas de produto /consultoria/<slug>):
// texto à esquerda + card de imagem à direita com selo. Escuro (navy).
// Uso:
//   <PageHero tag="..." sub="..." image="/assets/img/hero/x.webp" badge="..." icon="solar:..." chips={[...]}>
//     <Fragment slot="title">Texto <em class="accent">destaque</em></Fragment>
//     <Fragment slot="cta"><a class="btn btn--primary btn--lg">...</a></Fragment>
//   </PageHero>
const {
  tag,
  sub,
  image,
  badge,
  icon = "solar:shield-check-bold",
  accent = "var(--orange)",
  chips = [],
} = Astro.props;
---

<section class="ph-hero" style={`--accent:${accent}`}>
  <div class="ph-bg" aria-hidden="true"></div>
  <div class="container xl ph-grid">
    <div class="ph-text">
      {tag && <span class="tag-pill tag-pill--glow">{tag}</span>}
      <h1 class="ph-title"><slot name="title" /></h1>
      {sub && <p class="ph-sub">{sub}</p>}
      <div class="ph-cta"><slot name="cta" /></div>
      {chips.length > 0 && (
        <div class="ph-chips">
          {chips.map((c) => <span class="ph-chip"><iconify-icon icon="solar:check-circle-bold"></iconify-icon>{c}</span>)}
        </div>
      )}
    </div>
    <div class="ph-media">
      <div class="ph-media-fallback"><iconify-icon icon={icon}></iconify-icon></div>
      {image && <img class="ph-media-img" src={image} alt={badge || tag} loading="eager" onerror="this.style.display='none'" />}
      {badge && <span class="ph-media-badge"><iconify-icon icon={icon}></iconify-icon> {badge}</span>}
    </div>
  </div>
</section>

<style>
  .ph-hero { position: relative; overflow: hidden; color: var(--cream); padding: clamp(48px, 6vw, 80px) 0;
    background: linear-gradient(120deg, color-mix(in srgb, var(--accent) 28%, #0c0e12) 0%, color-mix(in srgb, var(--accent) 12%, #0c0e12) 48%, #0c0e12 100%); }
  .ph-bg { position: absolute; inset: 0; pointer-events: none;
    background: radial-gradient(720px 460px at 12% 0%, color-mix(in srgb, var(--accent) 26%, transparent), transparent 60%),
                radial-gradient(560px 380px at 100% 100%, color-mix(in srgb, var(--accent) 14%, transparent), transparent 60%); }
  .ph-grid { position: relative; z-index: 1; display: grid; grid-template-columns: 1.05fr 0.95fr; gap: clamp(32px, 5vw, 64px); align-items: center; }
  .ph-text { max-width: 600px; }
  .ph-hero .tag-pill { margin-bottom: 20px; }
  .ph-title { font-size: clamp(32px, 4.4vw, 54px); font-weight: 800; line-height: 1.07; letter-spacing: -0.03em; color: var(--cream); }
  .ph-sub { font-size: 17px; color: rgba(255,244,221,0.82); margin-top: 18px; max-width: 520px; line-height: 1.6; }
  .ph-cta { display: flex; gap: 12px; flex-wrap: wrap; margin-top: 28px; }
  .ph-cta:empty { display: none; }
  .ph-chips { display: flex; gap: 20px; flex-wrap: wrap; margin-top: 26px; padding-top: 22px; border-top: 1px solid rgba(255,244,221,0.14); }
  .ph-chip { display: inline-flex; align-items: center; gap: 8px; font-size: 13.5px; font-weight: 600; color: rgba(255,244,221,0.82); }
  .ph-chip iconify-icon { color: color-mix(in srgb, var(--accent) 58%, #ffffff); font-size: 18px; }

  .ph-media { position: relative; aspect-ratio: 4/4.6; border-radius: var(--r-32); overflow: hidden; box-shadow: 0 30px 70px -22px rgba(0,0,0,0.55), 0 0 0 1px rgba(255,244,221,0.1); }
  .ph-media-fallback { position: absolute; inset: 0; display: grid; place-items: center; font-size: 160px; color: color-mix(in srgb, var(--accent) 38%, transparent); background: radial-gradient(120% 90% at 50% 0%, color-mix(in srgb, var(--accent) 45%, #1a1f26), #14181e 78%); }
  .ph-media-img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .ph-media-badge { position: absolute; left: 16px; bottom: 16px; z-index: 2; display: inline-flex; align-items: center; gap: 7px; padding: 8px 14px; border-radius: 999px; font-size: 13px; font-weight: 800; color: #fff; background: color-mix(in srgb, var(--accent) 80%, #000 10%); box-shadow: 0 8px 24px -6px rgba(0,0,0,0.5); }

  @media (max-width: 900px) {
    .ph-grid { grid-template-columns: 1fr; }
    .ph-media { aspect-ratio: 16/10; order: -1; }
  }
</style>
