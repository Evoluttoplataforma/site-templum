---
// Formulário de lead reutilizável (ilha clara — funciona em seção navy ou clara).
// - Passe `norma` (nome da norma) p/ páginas específicas → vai oculto no envio.
// - Sem `norma` → mostra o seletor de norma (ex.: home).
// Campos de qualificação (cargo, urgência, nº de funcionários) vão no webhook
// e no Mailchimp. O envio é tratado pelo handler global do Base.astro: dispara
// conversão (pixels + CAPI), grava no Mailchimp/webhook e redireciona p/ /obrigado.
import { normas } from "../data/normas.js";
const {
  norma = "",
  titulo = "Fale com um especialista",
  sub = "Resposta em até 1 dia útil. Sem compromisso.",
  cta = "Quero meu diagnóstico gratuito",
  obrigado = "",   // ex: "/consultoria/iso-9001-obrigado" — sobrescreve o /obrigado padrão
  simples = false, // true → oculta nº funcionários, cargo e urgência
} = Astro.props;
const cargos = ["Proprietário", "Diretor / C-level", "Consultor", "Funcionário buscando informações", "Só estou curioso"];
const urgencias = ["Preciso certificar rápido", "Estou sem pressa para certificar", "Preciso para minha carreira", "Sou apenas estudante"];
const funcionarios = ["1 a 10", "11 a 50", "51 a 100", "101 a 250", "251 a 500", "Mais de 500"];
---

<div class="lead-card">
  <div class="lead-title">{titulo}</div>
  <p class="lead-sub">{sub}</p>
  <form class="form" data-trk-event="lead" novalidate data-obrigado={obrigado || undefined}>
    {norma && <input type="hidden" name="norma" value={norma} />}
    <div class="form-row">
      <div class="field"><label>Nome</label><input class="input" name="nome" placeholder="Seu nome" required /></div>
      <div class="field"><label>Telefone / WhatsApp</label><input class="input" type="tel" inputmode="numeric" name="telefone" placeholder="(00) 00000-0000" required /></div>
    </div>
    <div class="field"><label>E-mail</label><input class="input" type="email" name="email" placeholder="voce@empresa.com" required /></div>
    <div class="form-row">
      <div class="field"><label>Empresa</label><input class="input" name="empresa" placeholder="Nome da empresa" /></div>
      {!simples && (
        <div class="field">
          <label>Nº de funcionários</label>
          <select class="select" name="funcionarios" aria-label="Nº de funcionários">
            <option value="">Selecione</option>
            {funcionarios.map((f) => <option value={f}>{f}</option>)}
          </select>
        </div>
      )}
    </div>
    {!simples && (
      <div class="form-row">
        <div class="field">
          <label>Seu cargo</label>
          <select class="select" name="cargo" aria-label="Seu cargo">
            <option value="">Selecione</option>
            {cargos.map((c) => <option value={c}>{c}</option>)}
          </select>
        </div>
        <div class="field">
          <label>Qual sua urgência?</label>
          <select class="select" name="urgencia" aria-label="Qual sua urgência?">
            <option value="">Selecione</option>
            {urgencias.map((u) => <option value={u}>{u}</option>)}
          </select>
        </div>
      </div>
    )}
    {!norma && (
      <div class="field">
        <label>Qual norma você busca?</label>
        <select class="select" name="norma" aria-label="Qual norma você busca?">
          <option value="">Selecione (ou não sei ainda)</option>
          {normas.map((n) => <option value={n.nome}>{n.nome} — {n.categoria}</option>)}
          <option value="Outra / não sei ainda">Outra / não sei ainda</option>
        </select>
      </div>
    )}
    <button type="submit" class="btn btn--primary btn--block btn--lg">{cta} <iconify-icon icon="solar:arrow-right-linear"></iconify-icon></button>
    <p class="lead-legal">Ao enviar, você concorda em ser contatado pela Templum. Seus dados estão protegidos conforme a LGPD.</p>
  </form>
</div>

<style>
  .lead-legal { font-size: 11.5px; color: var(--text-soft); line-height: 1.5; margin-top: 2px; }
</style>
