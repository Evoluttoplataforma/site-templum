---
// tracking-kit (https://github.com/rodrigoosouza/tracking-kit) — substituto do GTM.
// IDs vazios = plataforma DESLIGADA. O cliente preenche meta/ga4/googleAds/etc.
// quando tiver as credenciais. Conversões: forms com data-trk-event e trk.lead().
//
// meta.pixelId fica vazio DE PROPÓSITO: o Meta Pixel (init + PageView + Lead +
// Advanced Matching) agora é feito nativamente em MetaPixel.astro e no handler
// de submit de Base.astro/LpBase.astro — únicos pontos auditáveis deste repo.
// A lib externa (CDN, fora deste repo) dispara, dentro de trk.lead(), um
// fbq('setUserProperties', ...) que não controlamos; com pixelId vazio esse
// ramo específico do Meta fica inativo dentro da lib, SEM afetar GA4/Google
// Ads/TikTok — que continuam disparando normalmente via trk.lead() em cada
// página de obrigado (chave própria, ga4.measurementId/googleAds.conversionId).
---
<script is:inline>
window.TRACKING_CONFIG = {
  client:    { name: 'Templum', debug: false, shadow: false },
  business:  {
    type: 'lead-gen-form',
    hasWhatsApp: true, hasForm: true, hasScheduling: false,
    hasEcommerce: false, hasRegistration: false, hasNewsletter: true,
    primaryConversion: 'Lead'
  },
  // IDs públicos (client-side). Tokens de CAPI/api_secret são SECRETOS → vão no servidor, nunca aqui.
  // pixelId vazio = desliga o ramo Meta da lib (init/PageView/Lead/setUserProperties) — ver nota acima.
  meta:      { pixelId: '', capi: false, advancedMatching: false, ctwa: false },
  googleAds: { conversionId: 'AW-17896226473', leadLabel: 'aPsvCKnw27kcEKn9ytVC', enhancedConversions: true, offlineConversions: false },
  ga4:       { measurementId: 'G-2BW8QTYLB5', apiSecret: '', engagementTracking: true },
  tiktok:    { pixelId: '', eventsApi: false },
  clarity:   { projectId: '' },
  server:    {
    endpoint: '/api/track',
    sendOnEvents: ['Lead','PageView','Contact','Schedule','ViewContent','CompleteRegistration','Subscribe','CTAClick','FormStart'],
    retryOnFail: 3
  },
  capture:   {
    firstTouch: true, referrerMapping: true, geo: true,
    journeyMaxTouches: 20, deviceFingerprint: true, ctwaCapture: true,
    leadStorageKey: '__wl_lead'
  },
  engagement:{
    scroll: true, heartbeat: 30, sections: true, sectionVisibleMs: 2000,
    ctaTracking: true, formAnalytics: true, videoTracking: true
  },
  consent:   { required: false, defaultGranted: false, cookieName: 'trk_consent' },
  helpers:   { whatsappNumber: '5519993521270', whatsappMessage: 'Olá! Vim pelo site da Templum.' },
  integrations: { calendly: false, typeform: false, tally: false },
  crossDomain:  { enabled: false, domains: [] }
};
window.TRACKING_KIT_VERSION = '1.0.0';
</script>
<script is:inline>
// Loader do tracking-kit exposto como função; o bootstrap em Base.astro chama
// __loadTrackingKit() só na 1ª interação (ou ocioso pós-load) → fora do render crítico.
window.__loadTrackingKit = function () {
  if (window.__trkLoaded) return; window.__trkLoaded = true;
  var BASE = 'https://cdn.jsdelivr.net/gh/rodrigoosouza/tracking-kit@v1.0.0/src/';
  function load(file, cb) {
    var s = document.createElement('script');
    s.async = false; s.src = BASE + file;
    if (cb) s.onload = cb;
    document.head.appendChild(s);
  }
  load('01-capture.js', function () {
    load('02-dispatch.js', function () {
      load('03-engagement.js', function () {
        load('trk-helpers.js', function () {
          var I = window.TRACKING_CONFIG.integrations || {};
          var CD = window.TRACKING_CONFIG.crossDomain || {};
          if (I.calendly || I.typeform || I.tally || CD.enabled) load('integrations.js');
        });
      });
    });
  });
  // Init da 2ª conta Meta foi REMOVIDO daqui — as 2 contas já são inicializadas
  // nativamente e imediatamente em MetaPixel.astro (ver Base.astro/LpBase.astro).
};
</script>
