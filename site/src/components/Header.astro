---
// Header estilo G4: top-banner de oferta + nav + 2 CTAs + mega-menu de normas.
import { normas } from "../data/normas.js";

const navLinks = [
  { label: "Certificações", href: "/consultoria" },
  { label: "Auditorias", href: "/auditoria" },
  { label: "Premiações", href: "/drops" },
  { label: "Soluções de IA", href: "/solucoes-de-ia", children: [
    { label: "Templum OS & Norma", href: "/solucoes-de-ia" },
    { label: "Agendar demonstração", href: "/form" },
  ] },
  { label: "Presentes 🎁", href: "/presentes" },
  { label: "Quem somos", href: "/quem-somos/sobre", children: [
    { label: "Sobre a Templum", href: "/quem-somos/sobre" },
    { label: "Nossos valores", href: "/quem-somos/valores" },
    { label: "Trabalhe conosco", href: "/carreira" },
  ] },
  { label: "Treinamentos", href: "/treinamento-fase-a-fase" },
  { label: "Cases", href: "/case-de-sucesso" },
  { label: "Histórias", href: "/historias" },
  { label: "Blog", href: "https://certificacaoiso.com.br" },
];
---

<!-- TOP BANNER -->
<a href="/form" class="top-banner">
  <iconify-icon icon="solar:fire-bold"></iconify-icon>
  <span class="tb-full"><strong>Garantia de 200%:</strong> certifique ou devolvemos o dobro do investimento.</span>
  <span class="tb-short"><strong>Garantia de 200%</strong> — o dobro de volta</span>
  <span class="tb-link">Falar com especialista <iconify-icon icon="solar:arrow-right-linear"></iconify-icon></span>
</a>

<header class="hd">
  <div class="hd-inner">
    <a href="/" class="templum-logo" aria-label="Templum — página inicial">
      <img src="/assets/logo/templum.png" alt="Templum" />
    </a>

    <nav class="hd-nav" aria-label="Navegação principal">
      <div class="hd-item has-mega">
        <a href="/consultoria" class="hd-link">Certificações <iconify-icon icon="solar:alt-arrow-down-linear"></iconify-icon></a>
        <div class="mega">
          <div class="mega-grid">
            {normas.map((n) => (
              <a class="mega-link" href={n.href}>
                <span class="mega-ico" style={`color:${n.color};background:color-mix(in srgb, ${n.color} 12%, transparent)`}><iconify-icon icon={n.icon}></iconify-icon></span>
                <span>
                  <strong>{n.nome}</strong>
                  <em>{n.categoria}</em>
                </span>
              </a>
            ))}
          </div>
        </div>
      </div>
      {navLinks.slice(1).map((l) => (
        l.children ? (
          <div class="hd-item has-drop">
            <a href={l.href} class="hd-link">{l.label} <iconify-icon icon="solar:alt-arrow-down-linear"></iconify-icon></a>
            <div class="drop">
              {l.children.map((c) => <a class="drop-link" href={c.href}>{c.label}</a>)}
            </div>
          </div>
        ) : (
          <a class="hd-link" href={l.href}>{l.label}</a>
        )
      ))}
    </nav>

    <div class="hd-actions">
      <a href="/contato" class="btn btn--outline btn--sm hd-ghost">Quero me inscrever</a>
      <a href="/form" class="btn btn--dark btn--sm">Falar com especialista</a>
    </div>

    <button class="hd-burger" aria-label="Abrir menu" id="hdBurger">
      <iconify-icon icon="solar:hamburger-menu-linear"></iconify-icon>
    </button>
  </div>

  <div class="hd-mobile" id="hdMobile">
    <nav>{navLinks.map((l) => (
      <Fragment>
        <a href={l.href}>{l.label}</a>
        {l.children && l.children.map((c) => <a class="hd-mobile-sub" href={c.href}>{c.label}</a>)}
      </Fragment>
    ))}</nav>
    <a href="/contato" class="btn btn--outline btn--block">Quero me inscrever</a>
    <a href="/form" class="btn btn--primary btn--block">Falar com especialista</a>
  </div>
</header>

<style>
  .top-banner { background: var(--surface-deep); color: var(--cream); display: flex; align-items: center; justify-content: center; gap: 10px; padding: 9px 24px; font-size: 13px; font-weight: 600; text-align: center; flex-wrap: wrap; text-decoration: none; }
  .top-banner .tb-short { display: none; }
  .top-banner iconify-icon { color: var(--orange); font-size: 15px; }
  .top-banner .tb-link { display: inline-flex; align-items: center; gap: 5px; color: var(--orange); font-weight: 700; }
  .top-banner .tb-link iconify-icon { color: var(--orange); transition: transform .3s var(--ease-soft); }
  .top-banner .tb-link:hover iconify-icon { transform: translateX(3px); }

  .hd { position: sticky; top: 0; z-index: 60; background: rgba(255,255,255,0.92); backdrop-filter: saturate(180%) blur(14px); -webkit-backdrop-filter: saturate(180%) blur(14px); border-bottom: 1px solid var(--border); }
  .hd-inner { display: flex; align-items: center; gap: 14px; height: var(--nav-h); max-width: 1400px; margin: 0 auto; padding: 0 24px; }
  .hd .templum-logo { flex-shrink: 0; }
  .hd .templum-logo img { height: 42px; }
  .hd-nav { display: flex; align-items: center; gap: 1px; margin-left: 6px; flex-wrap: nowrap; min-width: 0; }
  .hd-link { display: inline-flex; align-items: center; gap: 3px; font-size: 13.5px; font-weight: 600; color: var(--text); padding: 8px 7px; border-radius: 8px; transition: color .25s var(--ease-soft); cursor: pointer; white-space: nowrap; }
  .hd-link iconify-icon { font-size: 14px; transition: transform .25s var(--ease-soft); }
  .hd-link:hover { color: var(--orange); }
  .hd-actions { margin-left: auto; display: flex; align-items: center; gap: 10px; flex-shrink: 0; }

  .hd-item { position: relative; }
  .mega { position: absolute; top: calc(100% + 12px); left: 0; width: 640px; background: var(--surface); border: 1px solid var(--border); border-radius: var(--r-24); box-shadow: var(--shadow-lift); padding: 18px; opacity: 0; visibility: hidden; transform: translateY(8px); transition: opacity .25s var(--ease-soft), transform .25s var(--ease-soft), visibility .25s; }
  .hd-item:hover .mega { opacity: 1; visibility: visible; transform: none; }
  .hd-item:hover .hd-link iconify-icon { transform: rotate(180deg); }
  .mega-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 4px; }
  .mega-link { display: flex; align-items: center; gap: 11px; padding: 10px 12px; border-radius: var(--r-12); transition: background .2s var(--ease-soft); }
  .mega-link:hover { background: var(--bg); }
  .mega-link span:last-child { display: flex; flex-direction: column; gap: 2px; }
  .mega-link strong { font-size: 13.5px; font-weight: 700; color: var(--text); }
  .mega-link em { font-size: 11px; font-style: normal; color: var(--text-mid); line-height: 1.3; }
  .mega-ico { width: 34px; height: 34px; min-width: 34px; border-radius: 9px; display: grid; place-items: center; font-size: 19px; flex-shrink: 0; }

  /* Dropdown simples (Soluções de IA, Quem somos) */
  .has-drop { position: relative; }
  .drop { position: absolute; top: calc(100% + 10px); left: 0; min-width: 230px; background: var(--surface); border: 1px solid var(--border); border-radius: var(--r-16); box-shadow: var(--shadow-lift); padding: 8px; opacity: 0; visibility: hidden; transform: translateY(8px); transition: opacity .25s var(--ease-soft), transform .25s var(--ease-soft), visibility .25s; }
  .has-drop:hover .drop { opacity: 1; visibility: visible; transform: none; }
  .drop-link { display: block; padding: 10px 14px; border-radius: var(--r-12); font-size: 14px; font-weight: 600; color: var(--text); transition: background .2s var(--ease-soft), color .2s var(--ease-soft); }
  .drop-link:hover { background: var(--bg); color: var(--orange); }

  .hd-burger { display: none; margin-left: auto; font-size: 26px; color: var(--text); padding: 6px; }
  .hd-mobile { display: none; flex-direction: column; gap: 14px; padding: 20px 24px 28px; background: var(--surface); border-bottom: 1px solid var(--border); max-height: calc(100dvh - var(--nav-h, 64px)); overflow-y: auto; }
  .hd-mobile.open { display: flex; }
  .hd-mobile nav { display: flex; flex-direction: column; }
  .hd-mobile nav a { padding: 12px 0; font-size: 16px; font-weight: 600; border-bottom: 1px solid var(--border); color: var(--text); }
  .hd-mobile nav a.hd-mobile-sub { padding-left: 18px; font-size: 14.5px; font-weight: 500; color: var(--text-mid); }

  /* No topo fica só o CTA primário (o nav tem 9 itens). "Quero me inscrever"
     vive no menu mobile. */
  .hd-ghost { display: none; }
  @media (max-width: 1320px) {
    .hd-nav { display: none; }
    .hd-burger { display: inline-flex; }
  }
  @media (max-width: 560px) {
    .hd-actions .btn { display: none; }
    /* top-banner compacto: texto curto, 1 linha, sem o CTA */
    .top-banner { font-size: 12px; padding: 7px 14px; gap: 7px; flex-wrap: nowrap; white-space: nowrap; }
    .top-banner .tb-full, .top-banner .tb-link { display: none; }
    .top-banner .tb-short { display: inline; }
    .hd-inner { padding: 0 16px; }
  }
</style>

<script is:inline>
  (function () {
    const b = document.getElementById("hdBurger");
    const m = document.getElementById("hdMobile");
    if (b && m) b.addEventListener("click", () => m.classList.toggle("open"));
  })();
</script>
