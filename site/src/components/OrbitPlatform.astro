---
// Plataforma ORBIT + hub orbital da Olívia (12 agentes de IA).
// Réplica fiel do HTML oficial (orbit-olivia-agentes) adaptada à identidade Templum.
const resultados = [
  { num: "40%", label: "menos tempo na execução dos processos", pre: "até" },
  { num: "85%", label: "de redução em erros operacionais", pre: "" },
  { num: "65%", label: "de ganho em produtividade das equipes", pre: "" },
];

const agentes = [
  { icon: "solar:compass-bold", label: "Estrategista", desc: "SWOT, BSC e planejamento estratégico", title: "Agente Estrategista", text: "Analisa o cenário com SWOT, define OKRs e monta o planejamento estratégico, cruzando dados de todos os agentes.", impact: 95, tags: ["SWOT", "BSC", "OKRs"] },
  { icon: "mdi:sitemap-outline", label: "Processos", desc: "Mapeamento, playbooks e automação", title: "Agente de Processos", text: "Mapeia, documenta e gera instruções de trabalho automaticamente. Reduz retrabalho e garante qualidade.", impact: 90, tags: ["Playbooks", "ISO", "Automação"] },
  { icon: "solar:users-group-rounded-bold", label: "Pessoas", desc: "Cargos, desempenho e PDIs", title: "Agente de Pessoas", text: "Cria descrições de cargo, avaliações de desempenho e PDIs. Identifica gaps e sugere trilhas de desenvolvimento.", impact: 88, tags: ["360°", "PDI", "Skills"] },
  { icon: "solar:square-academic-cap-bold", label: "Treinamento", desc: "Microlearning via WhatsApp", title: "Agente de Treinamento", text: "Treina equipes via WhatsApp com microlearning diário, adaptando o conteúdo ao nível de cada colaborador.", impact: 92, tags: ["WhatsApp", "Micro", "Quiz"] },
  { icon: "solar:chart-2-bold", label: "Indicadores", desc: "KPIs em tempo real e causa raiz", title: "Agente de Indicadores", text: "Monitora KPIs em tempo real, identifica desvios e sugere hipóteses de causa raiz antes do problema crescer.", impact: 94, tags: ["KPIs", "Dashboard", "Alertas"] },
  { icon: "solar:magnifer-bold", label: "Pesquisa", desc: "Clima, formulários e insights", title: "Agente de Pesquisa", text: "Cria pesquisas de clima, satisfação e NPS. Analisa respostas e entrega insights acionáveis.", impact: 82, tags: ["NPS", "Clima", "Insights"] },
  { icon: "solar:shield-warning-bold", label: "Riscos", desc: "Mitigação e prevenção contínua", title: "Agente de Riscos", text: "Identifica ameaças antes que virem crises. Monitora indicadores de risco e sugere planos de mitigação.", impact: 91, tags: ["Prevenção", "PDCA", "Alertas"] },
  { icon: "solar:lightbulb-bold", label: "Oportunidades", desc: "Mercado, parcerias e expansão", title: "Agente de Oportunidades", text: "Escaneia o mercado, identifica oportunidades e cruza com dados internos para sugerir expansão e parcerias.", impact: 87, tags: ["Mercado", "Growth", "Parcerias"] },
  { icon: "solar:danger-triangle-bold", label: "Problemas", desc: "Não-conformidades e PDCA", title: "Agente de Problemas", text: "Registra não-conformidades, aplica PDCA automaticamente e acompanha a resolução até o fechamento.", impact: 89, tags: ["PDCA", "5W2H", "NC"] },
  { icon: "solar:document-text-bold", label: "Documentos", desc: "Padronização e controle", title: "Agente de Documentos", text: "Padroniza, versiona e controla todos os documentos. Garante que todos usem a versão mais recente.", impact: 80, tags: ["Versão", "ISO", "Padrão"] },
  { icon: "mdi:handshake-outline", label: "Vendas", desc: "CRM, funil e coaching comercial", title: "Agente de Vendas", text: "Gerencia o funil comercial, faz coaching da equipe e identifica oportunidades de upsell e cross-sell.", impact: 93, tags: ["CRM", "Funil", "Coaching"] },
  { icon: "solar:videocamera-record-bold", label: "Reuniões", desc: "Transcrição e planos de ação", title: "Agente de Reuniões", text: "Transcreve reuniões, extrai decisões e gera planos de ação automaticamente. Nunca perca um follow-up.", impact: 86, tags: ["Ata", "Follow-up", "IA"] },
];
---

<section class="orbit section--navy">
  <div class="orbit-bg" aria-hidden="true"></div>
  <div class="container xl">
    <div class="section-header">
      <span class="tag-pill tag-pill--glow">Plataforma Orbit</span>
      <h2>Uma certificação ISO guiada por <em class="accent">tecnologia</em></h2>
      <p>
        Desenvolvemos o <strong>ORBIT</strong>, uma plataforma proprietária da Templum
        criada para organizar, orientar e acelerar a implementação das normas ISO —
        transformando a certificação em um processo <strong>guiado, mensurável e
        previsível</strong>, sem retrabalho, erros ou decisões no escuro.
      </p>
    </div>

    <!-- Hub orbital: Olívia + 12 agentes -->
    <div class="orbit-subhead">
      <h3>Seu time de IA coordenado pela <span>Olívia</span></h3>
      <p>Cada agente domina uma área. A Olívia coordena todos, conecta os dados e entrega clareza. <em>Passe o mouse</em> em cada agente.</p>
    </div>

    <div class="orbit-hub" id="orbitHub">
      <div class="orbit-hub__center">
        <div class="orbit-hub__glow"></div>
        <div class="orbit-hub__photo"><img src="/assets/img/olivia.webp" alt="Olívia" /></div>
        <div class="orbit-hub__name">Olívia</div>
        <div class="orbit-hub__role">Coordenadora Geral</div>
        <div class="orbit-hub__ring orbit-hub__ring--1"></div>
        <div class="orbit-hub__ring orbit-hub__ring--2"></div>
        <div class="orbit-hub__ring orbit-hub__ring--3"></div>
      </div>
      <svg class="orbit-hub__lines" id="orbitLines"></svg>
      {agentes.map((a, i) => (
        <div class="orbit-hub__node" data-idx={i}>
          <div class="orbit-hub__node-icon"><iconify-icon icon={a.icon}></iconify-icon></div>
          <div class="orbit-hub__node-label">{a.label}</div>
          <div class="orbit-hub__node-desc">{a.desc}</div>
          <div class="orbit-node-card">
            <div class="orbit-node-card__status"><span class="dot"></span> Ativo 24/7</div>
            <div class="orbit-node-card__title">{a.title}</div>
            <div class="orbit-node-card__text">{a.text}</div>
            <div class="orbit-node-card__bar">
              <div class="orbit-node-card__bar-label"><span>Impacto</span><span>{a.impact}%</span></div>
              <div class="orbit-node-card__bar-track"><div class="orbit-node-card__bar-fill" style={`width:${a.impact}%`}></div></div>
            </div>
            <div class="orbit-node-card__tags">{a.tags.map((t) => <span class="orbit-node-card__tag">{t}</span>)}</div>
          </div>
        </div>
      ))}
    </div>

    <p class="orbit-foot">Tudo isso com clareza constante do próximo passo e acompanhamento ativo da nossa equipe.</p>

    <span class="orbit-results-eyebrow">Resultados práticos já comprovados nos clientes</span>
    <div class="orbit-stats">
      {resultados.map((r) => (
        <div class="orbit-stat">
          {r.pre && <span class="os-pre">{r.pre}</span>}
          <span class="os-num">{r.num}</span>
          <span class="os-label">{r.label}</span>
        </div>
      ))}
    </div>

    <div class="orbit-cta"><a href="/solucoes-de-ia" class="btn btn--primary btn--lg">Conhecer o Orbit <iconify-icon icon="solar:arrow-right-linear"></iconify-icon></a></div>
  </div>
</section>

<style>
  .orbit { padding: 96px 0; position: relative; overflow: hidden; }
  .orbit-bg { position: absolute; inset: 0; pointer-events: none; background: radial-gradient(700px 480px at 50% 30%, rgba(255,89,37,0.14), transparent 62%); }
  .orbit .container { position: relative; z-index: 1; }
  .orbit .section-header { margin-bottom: 32px; }
  .orbit .section-header p { color: rgba(255,244,221,0.7); }
  .orbit .section-header p strong { color: var(--cream); }

  .orbit-subhead { text-align: center; margin: 8px auto 0; max-width: 620px; }
  .orbit-subhead h3 { color: var(--cream); font-size: clamp(20px, 2.4vw, 28px); font-weight: 800; letter-spacing: -0.02em; }
  .orbit-subhead h3 span { color: var(--orange); }
  .orbit-subhead p { color: rgba(255,244,221,0.55); font-size: 14.5px; margin-top: 8px; }
  .orbit-subhead p em { color: var(--orange); font-style: normal; font-weight: 600; }

  /* hub */
  .orbit-hub { position: relative; width: 100%; max-width: 1040px; height: 940px; margin: 0 auto 8px; }
  .orbit-hub__lines { position: absolute; inset: 0; width: 100%; height: 100%; pointer-events: none; z-index: 0; opacity: 0; }
  .orbit-visible .orbit-hub__lines { animation: orbit-lines-in .8s ease .3s forwards; }
  @keyframes orbit-lines-in { to { opacity: 1; } }

  .orbit-hub__center { position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); display: flex; flex-direction: column; align-items: center; z-index: 3; opacity: 0; scale: 0.3; }
  .orbit-visible .orbit-hub__center { animation: orbit-center-in .8s cubic-bezier(.34,1.56,.64,1) forwards; }
  @keyframes orbit-center-in { to { opacity: 1; scale: 1; } }
  .orbit-hub__glow { position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); width: 320px; height: 320px; border-radius: 50%; background: radial-gradient(circle, rgba(255,89,37,0.28) 0%, rgba(255,89,37,0.06) 50%, transparent 70%); animation: orbit-glow 3.5s ease-in-out infinite; pointer-events: none; }
  @keyframes orbit-glow { 0%,100% { opacity: .5; transform: translate(-50%,-50%) scale(1); } 50% { opacity: 1; transform: translate(-50%,-50%) scale(1.15); } }
  .orbit-hub__photo { width: 184px; height: 184px; border-radius: 50%; border: 4px solid rgba(255,89,37,0.6); overflow: hidden; box-shadow: 0 0 40px rgba(255,89,37,0.4), 0 0 80px rgba(255,89,37,0.15); animation: orbit-breathe 3.5s ease-in-out infinite; position: relative; z-index: 2; }
  @keyframes orbit-breathe { 0%,100% { box-shadow: 0 0 40px rgba(255,89,37,0.4), 0 0 80px rgba(255,89,37,0.15); } 50% { box-shadow: 0 0 50px rgba(255,89,37,0.6), 0 0 100px rgba(255,89,37,0.25); } }
  .orbit-hub__photo img { width: 100%; height: 100%; object-fit: cover; object-position: top center; display: block; }
  .orbit-hub__name { color: var(--orange); font-size: 20px; font-weight: 800; margin-top: 14px; letter-spacing: 1px; text-transform: uppercase; }
  .orbit-hub__role { color: rgba(255,244,221,0.55); font-size: 13px; margin-top: 4px; }

  .orbit-hub__ring { position: absolute; top: 50%; left: 50%; border-radius: 50%; border: 1.5px solid rgba(255,89,37,0.12); pointer-events: none; animation: orbit-ring 3.5s ease-in-out infinite; }
  .orbit-hub__ring--1 { width: 240px; height: 240px; transform: translate(-50%, calc(-50% - 16px)); }
  .orbit-hub__ring--2 { width: 300px; height: 300px; border-color: rgba(255,89,37,0.07); transform: translate(-50%, calc(-50% - 16px)); animation-delay: .5s; }
  .orbit-hub__ring--3 { width: 360px; height: 360px; border-color: rgba(255,89,37,0.04); transform: translate(-50%, calc(-50% - 16px)); animation-delay: 1s; }
  @keyframes orbit-ring { 0%,100% { opacity: .3; } 50% { opacity: 1; } }

  .orbit-hub__node { position: absolute; transform: translate(-50%,-50%); display: flex; flex-direction: column; align-items: center; gap: 8px; z-index: 2; cursor: pointer; transition: transform .3s ease; opacity: 0; scale: 0.5; }
  .orbit-visible .orbit-hub__node { animation: orbit-node-in .6s cubic-bezier(.16,1,.3,1) forwards; }
  .orbit-visible .orbit-hub__node[data-idx="0"]{animation-delay:.10s}.orbit-visible .orbit-hub__node[data-idx="1"]{animation-delay:.15s}.orbit-visible .orbit-hub__node[data-idx="2"]{animation-delay:.20s}.orbit-visible .orbit-hub__node[data-idx="3"]{animation-delay:.25s}.orbit-visible .orbit-hub__node[data-idx="4"]{animation-delay:.30s}.orbit-visible .orbit-hub__node[data-idx="5"]{animation-delay:.35s}.orbit-visible .orbit-hub__node[data-idx="6"]{animation-delay:.40s}.orbit-visible .orbit-hub__node[data-idx="7"]{animation-delay:.45s}.orbit-visible .orbit-hub__node[data-idx="8"]{animation-delay:.50s}.orbit-visible .orbit-hub__node[data-idx="9"]{animation-delay:.55s}.orbit-visible .orbit-hub__node[data-idx="10"]{animation-delay:.60s}.orbit-visible .orbit-hub__node[data-idx="11"]{animation-delay:.65s}
  @keyframes orbit-node-in { to { opacity: 1; scale: 1; } }
  .orbit-hub__node:hover { transform: translate(-50%,-50%) scale(1.12); }
  .orbit-hub__node:hover .orbit-hub__node-icon { border-color: var(--orange); box-shadow: 0 0 24px rgba(255,89,37,0.5); background: linear-gradient(135deg, rgba(255,89,37,0.35), rgba(255,89,37,0.1)); }

  .orbit-hub__node-icon { width: 56px; height: 56px; border-radius: 50%; background: linear-gradient(135deg, rgba(255,89,37,0.15), rgba(255,89,37,0.04)); border: 2px solid rgba(255,89,37,0.3); display: grid; place-items: center; transition: all .3s ease; backdrop-filter: blur(4px); }
  .orbit-hub__node-icon iconify-icon { font-size: 22px; color: var(--orange); }
  .orbit-hub__node-label { font-size: 14px; font-weight: 800; color: #fff; white-space: nowrap; text-shadow: 0 2px 10px rgba(0,0,0,0.8); }
  /* descrição fixa escondida (aparece no card de hover) p/ não amontoar */
  .orbit-hub__node-desc { display: none; }
  .orbit-hub__node-label { background: rgba(13,16,20,0.55); padding: 2px 10px; border-radius: 999px; backdrop-filter: blur(2px); }

  .orbit-hub__node.orbit-node--active { transform: translate(-50%,-50%) scale(1.18); z-index: 100; }
  .orbit-hub__node.orbit-node--active .orbit-hub__node-icon { border-color: var(--orange); box-shadow: 0 0 30px rgba(255,89,37,0.6); background: linear-gradient(135deg, rgba(255,89,37,0.4), rgba(255,89,37,0.15)); }
  .orbit-hub__node.orbit-node--dimmed { opacity: .3 !important; }

  .orbit-node-card { position: absolute; top: calc(100% + 12px); left: 50%; transform: translateX(-50%) scale(0.9); width: 260px; background: rgba(26,31,38,0.96); backdrop-filter: blur(20px); border: 1px solid rgba(255,89,37,0.25); border-radius: 16px; padding: 20px; opacity: 0; pointer-events: none; transition: all .3s cubic-bezier(.16,1,.3,1); z-index: 200; box-shadow: 0 12px 40px rgba(0,0,0,0.5), 0 0 40px rgba(255,89,37,0.08); text-align: left; }
  .orbit-node--active .orbit-node-card { opacity: 1; pointer-events: auto; transform: translateX(-50%) scale(1); }
  .orbit-node-card::before { content: ''; position: absolute; top: -6px; left: 50%; transform: translateX(-50%) rotate(45deg); width: 10px; height: 10px; background: rgba(26,31,38,0.96); border-left: 1px solid rgba(255,89,37,0.25); border-top: 1px solid rgba(255,89,37,0.25); }
  .orbit-node-card__status { display: inline-flex; align-items: center; gap: 5px; font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: #22C55E; background: rgba(34,197,94,0.1); border: 1px solid rgba(34,197,94,0.2); padding: 3px 10px; border-radius: 20px; margin-bottom: 12px; }
  .orbit-node-card__status .dot { width: 5px; height: 5px; border-radius: 50%; background: #22C55E; }
  .orbit-node-card__title { color: #fff; font-size: 0.95rem; font-weight: 700; margin-bottom: 8px; }
  .orbit-node-card__text { color: rgba(255,255,255,0.6); font-size: 0.8rem; line-height: 1.6; margin-bottom: 14px; }
  .orbit-node-card__bar { margin-bottom: 12px; }
  .orbit-node-card__bar-label { display: flex; justify-content: space-between; font-size: 0.7rem; color: rgba(255,255,255,0.4); margin-bottom: 4px; }
  .orbit-node-card__bar-track { width: 100%; height: 4px; background: rgba(255,255,255,0.06); border-radius: 2px; overflow: hidden; }
  .orbit-node-card__bar-fill { height: 100%; background: linear-gradient(90deg, var(--orange), #FB923C); border-radius: 2px; }
  .orbit-node-card__tags { display: flex; flex-wrap: wrap; gap: 6px; }
  .orbit-node-card__tag { font-size: 0.65rem; color: rgba(255,255,255,0.5); background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.06); padding: 3px 8px; border-radius: 4px; }

  /* resultados */
  .orbit-foot { text-align: center; max-width: 640px; margin: 0 auto 48px; font-size: 16px; color: rgba(255,244,221,0.7); line-height: 1.6; }
  .orbit-results-eyebrow { display: block; text-align: center; font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: var(--orange); margin-bottom: 24px; }
  .orbit-stats { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
  .orbit-stat { background: rgba(255,255,255,0.04); border: 1px solid rgba(255,244,221,0.12); border-radius: var(--r-20); padding: 32px 28px; text-align: center; }
  .os-pre { display: block; font-size: 13px; font-weight: 600; color: rgba(255,244,221,0.5); text-transform: uppercase; letter-spacing: 0.08em; }
  .os-num { display: block; font-size: clamp(44px, 5vw, 60px); font-weight: 900; color: var(--orange); line-height: 1; letter-spacing: -0.03em; margin: 4px 0 12px; }
  .os-label { font-size: 14.5px; color: rgba(255,244,221,0.75); line-height: 1.5; }
  .orbit-cta { text-align: center; margin-top: 36px; }

  @media (max-width: 768px) {
    .orbit-hub { max-width: 100%; height: 500px; }
    .orbit-hub__glow { width: 150px; height: 150px; }
    .orbit-hub__photo { width: 96px; height: 96px; border-width: 3px; }
    .orbit-hub__name { font-size: 15px; margin-top: 8px; }
    .orbit-hub__ring--1 { width: 140px; height: 140px; } .orbit-hub__ring--2 { width: 175px; height: 175px; } .orbit-hub__ring--3 { display: none; }
    .orbit-hub__node-icon { width: 44px; height: 44px; } .orbit-hub__node-icon iconify-icon { font-size: 18px; }
    .orbit-hub__node-label { font-size: 11px; }
    .orbit-node-card { width: 220px; }
    .orbit-stats { grid-template-columns: 1fr; }
  }
</style>

<script is:inline>
  (function () {
    var hub = document.getElementById("orbitHub");
    if (!hub) return;
    var TOTAL = 12;
    var nodes = hub.querySelectorAll(".orbit-hub__node");
    var svg = document.getElementById("orbitLines");
    var SVGNS = "http://www.w3.org/2000/svg";

    function layout() {
      var w = hub.offsetWidth, h = hub.offsetHeight;
      var cx = w / 2, cy = h / 2;
      var radius = Math.min(w, h) / 2 - 70;
      if (w <= 480 && radius > 150) radius = 150;
      else if (w <= 768 && radius > 190) radius = 190;
      else if (radius > 380) radius = 380;
      if (radius < 80) radius = 80;

      svg.setAttribute("width", w); svg.setAttribute("height", h);
      svg.setAttribute("viewBox", "0 0 " + w + " " + h);
      svg.innerHTML = "";
      var defs = document.createElementNS(SVGNS, "defs");
      defs.innerHTML = '<filter id="lineGlow"><feGaussianBlur stdDeviation="3" result="b"/><feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge></filter>';
      svg.appendChild(defs);

      nodes.forEach(function (node, i) {
        var ang = (i / TOTAL) * Math.PI * 2 - Math.PI / 2;
        var nx = cx + Math.cos(ang) * radius, ny = cy + Math.sin(ang) * radius;
        node.style.left = nx + "px"; node.style.top = ny + "px";
        var line = document.createElementNS(SVGNS, "line");
        line.setAttribute("x1", cx); line.setAttribute("y1", cy);
        line.setAttribute("x2", nx); line.setAttribute("y2", ny);
        line.setAttribute("stroke", "rgba(255,89,37,0.22)"); line.setAttribute("stroke-width", "1.5");
        line.setAttribute("filter", "url(#lineGlow)"); svg.appendChild(line);
        var circle = document.createElementNS(SVGNS, "circle");
        circle.setAttribute("r", "3.5"); circle.setAttribute("fill", "#FB923C"); circle.setAttribute("filter", "url(#lineGlow)");
        var anim = document.createElementNS(SVGNS, "animateMotion");
        anim.setAttribute("dur", "2.5s"); anim.setAttribute("repeatCount", "indefinite"); anim.setAttribute("begin", (i * 0.2) + "s");
        var pathEl = document.createElementNS(SVGNS, "path");
        pathEl.setAttribute("id", "orbit-path-" + i); pathEl.setAttribute("d", "M" + nx + "," + ny + " L" + cx + "," + cy); pathEl.setAttribute("fill", "none");
        defs.appendChild(pathEl);
        var mpath = document.createElementNS(SVGNS, "mpath");
        mpath.setAttributeNS("http://www.w3.org/1999/xlink", "href", "#orbit-path-" + i);
        anim.appendChild(mpath); circle.appendChild(anim); svg.appendChild(circle);
      });
    }

    var obs = new IntersectionObserver(function (e) {
      if (e[0].isIntersecting) { hub.classList.add("orbit-visible"); layout(); obs.disconnect(); }
    }, { threshold: 0.1 });
    obs.observe(hub);

    var t;
    window.addEventListener("resize", function () { clearTimeout(t); t = setTimeout(function () { if (hub.classList.contains("orbit-visible")) layout(); }, 150); });

    nodes.forEach(function (node) {
      node.addEventListener("mouseenter", function () {
        nodes.forEach(function (n) { n.classList.remove("orbit-node--active", "orbit-node--dimmed"); });
        node.classList.add("orbit-node--active");
        nodes.forEach(function (n) { if (n !== node) n.classList.add("orbit-node--dimmed"); });
      });
      node.addEventListener("mouseleave", function () {
        nodes.forEach(function (n) { n.classList.remove("orbit-node--active", "orbit-node--dimmed"); });
      });
    });
  })();
</script>
