---
// Newsletter — card navy com glow laranja, layout horizontal.
// (Integração Mailchimp/Pages Function: a fazer.)
---

<section class="nl section--cream">
  <div class="container xl">
    <div class="nl-card">
      <div class="nl-glow" aria-hidden="true"></div>
      <div class="nl-left">
        <span class="tag-pill tag-pill--glow">Newsletter</span>
        <h2>Insights de gestão e certificação <em class="accent">no seu e-mail</em></h2>
        <p>Conteúdos práticos para liderar, organizar a empresa e tomar decisões melhores. Sem spam — cancele quando quiser.</p>
      </div>
      <div class="nl-right">
        <form class="nl-form" data-newsletter>
          <div class="nl-field">
            <iconify-icon icon="solar:letter-linear"></iconify-icon>
            <input type="email" name="email" placeholder="Seu melhor e-mail" required aria-label="E-mail" />
          </div>
          <button type="submit" class="btn btn--primary btn--lg btn--block">Quero receber <iconify-icon icon="solar:arrow-right-linear"></iconify-icon></button>
          <span class="nl-note">Ao se inscrever, você concorda em receber e-mails da Templum.</span>
        </form>
        <p class="nl-ok" data-newsletter-ok hidden><iconify-icon icon="solar:check-circle-bold"></iconify-icon> Pronto! Você está inscrito.</p>
      </div>
    </div>
  </div>
</section>

<style>
  .nl { padding: 96px 0; }
  .nl-card { position: relative; overflow: hidden; background: var(--surface-deep); border-radius: var(--r-32); padding: clamp(36px, 5vw, 60px); display: grid; grid-template-columns: 1.1fr 0.9fr; gap: clamp(32px, 5vw, 64px); align-items: center; box-shadow: var(--shadow-lift); }
  .nl-glow { position: absolute; inset: 0; pointer-events: none; background: radial-gradient(520px 320px at 90% 10%, rgba(255,89,37,0.28), transparent 60%), radial-gradient(360px 260px at 0% 100%, rgba(255,89,37,0.12), transparent 60%); }
  .nl-left, .nl-right { position: relative; z-index: 1; }

  .nl-left .tag-pill { margin-bottom: 16px; }
  .nl-left h2 { font-size: clamp(26px, 2.8vw, 38px); font-weight: 800; letter-spacing: -0.025em; line-height: 1.12; color: var(--cream); }
  .nl-left p { font-size: 15.5px; color: rgba(255,244,221,0.7); margin-top: 14px; line-height: 1.6; max-width: 440px; }

  .nl-form { display: flex; flex-direction: column; gap: 12px; }
  .nl-field { position: relative; display: flex; align-items: center; }
  .nl-field iconify-icon { position: absolute; left: 18px; font-size: 20px; color: var(--text-soft); }
  .nl-field input { width: 100%; font-family: var(--font-sans); font-size: 15px; font-weight: 500; padding: 16px 18px 16px 48px; border-radius: 50px; border: 1px solid transparent; background: var(--surface); color: var(--text); transition: box-shadow .2s; }
  .nl-field input:focus { outline: none; box-shadow: 0 0 0 3px rgba(255,89,37,0.4); }
  .nl-note { font-size: 12px; color: rgba(255,244,221,0.5); text-align: center; line-height: 1.5; }
  .nl-form[hidden], .nl-ok[hidden] { display: none; }
  .nl-ok { display: flex; align-items: center; justify-content: center; gap: 8px; color: #fff; font-weight: 700; font-size: 16px; padding: 20px; }
  .nl-ok iconify-icon { color: #4ADE80; font-size: 22px; }

  @media (max-width: 820px) {
    .nl-card { grid-template-columns: 1fr; gap: 28px; text-align: center; }
    .nl-left .tag-pill { margin-left: auto; margin-right: auto; }
    .nl-left p { margin-left: auto; margin-right: auto; }
    .nl { padding: 72px 0; }
  }
  @media (max-width: 480px) {
    .nl { padding: 60px 0; }
    .nl-card { padding: 28px 20px; border-radius: var(--r-24); }
  }
</style>

<script is:inline>
  (function () {
    const f = document.querySelector("[data-newsletter]");
    if (!f) return;
    f.addEventListener("submit", (e) => {
      e.preventDefault();
      // TODO: integrar com Mailchimp via Pages Function (igual projeto iscas)
      f.hidden = true;
      const ok = f.parentElement.querySelector("[data-newsletter-ok]");
      if (ok) ok.hidden = false;
    });
  })();
</script>
