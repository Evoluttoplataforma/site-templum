---
import Base from "../layouts/Base.astro";
import PageHero from "../components/PageHero.astro";

// Copy real de "site atual/Drops - Templum Consultoria.html" (Cashback + Templum Rewards).
const programas = [
  { icon: "solar:wad-of-money-bold", t: "Cashback Templum", d: "Acumule drops e converta em vale-compras para usar nos sites operados pela Americanas, após a certificação da sua empresa. Cada 250 drops equivalem a R$ 25,00." },
  { icon: "solar:cup-star-bold", t: "Templum Rewards", d: "Os interlocutores que mais acumulam drops disputam prêmios mensais e trimestrais — troque pontos por vale-compras e concorra a prêmios de até R$ 1.000." },
];
const premios = [
  { valor: "R$ 500", quando: "Todo mês, no dia 01", regra: "Para o interlocutor que mais acumulou drops no mês anterior." },
  { valor: "R$ 1.000", quando: "A cada trimestre", regra: "Sorteio entre os 10 interlocutores que mais acumularam drops no período." },
];
const comoAcumular = [
  { d: "1", t: "por conteúdo lido" },
  { d: "10", t: "por finalizar cada fase do projeto" },
  { d: "10", t: "por incluir foto no onboarding" },
  { d: "50", t: "por participar dos treinamentos semanais" },
  { d: "50", t: "por concluir o mês com o cronograma em dia" },
  { d: "100", t: "por concluir o mês com o cronograma adiantado" },
  { d: "100", t: "por realizar auditoria interna" },
  { d: "100", t: "por publicar um depoimento no Google sobre a Templum" },
  { d: "100", t: "por indicar novos clientes" },
  { d: "200", t: "por divulgar o programa nas redes sociais" },
  { d: "300", t: "por conquistar a certificação" },
  { d: "400", t: "se a indicação resultar em fechamento de contrato" },
  { d: "400", t: "por renovação de contrato" },
];
const regras = [
  "Válido apenas para clientes adimplentes no momento do resgate.",
  "Todos os interlocutores cadastrados na plataforma Templum são elegíveis.",
  "Para renovação, considera-se o contrato completo de 12 meses.",
  "O resgate com vale Americanas pode ser feito após a certificação, mediante entrega da carta de recomendação.",
  "Os prêmios são pessoais e intransferíveis — drops não são transferidos entre interlocutores.",
  "Consulte e acompanhe seu saldo em tempo real no Menu Perfil, dentro da plataforma.",
];
---

<Base
  title="Drops — Programas de premiação Cashback e Templum Rewards"
  description="Seja premiado pelo seu sucesso. Acumule drops nas atividades da consultoria e troque por vale-compras e prêmios de até R$ 1.000 com o Cashback Templum e o Templum Rewards."
>
  <PageHero
    tag="Programas de premiação Templum"
    sub="Fazendo juntos, conquistando resultados. Acumule drops ao longo da sua jornada de consultoria e troque por vale-compras e prêmios de até R$ 1.000."
    image="/assets/img/paginas/drops-hero.webp"
    badge="Templum Rewards"
    icon="solar:cup-star-bold"
    chips={["Cashback em vale-compras", "Prêmios mensais e trimestrais", "Para clientes Templum"]}
  >
    <Fragment slot="title">Seja <em class="accent">premiado</em> pelo seu sucesso</Fragment>
    <Fragment slot="cta">
      <a href="/form/" class="btn btn--primary btn--lg">Quero participar <iconify-icon icon="solar:arrow-right-linear"></iconify-icon></a>
    </Fragment>
  </PageHero>

  <section class="section section--cream">
    <div class="container">
      <div class="section-header">
        <span class="tag-pill">Como funciona</span>
        <h2>Dois programas, <em class="accent">muitas recompensas</em></h2>
      </div>
      <div class="dr-prog">
        {programas.map((p) => (
          <div class="eco-card">
            <span class="dr-ico"><iconify-icon icon={p.icon}></iconify-icon></span>
            <h3>{p.t}</h3>
            <p>{p.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="tag-pill">Premiações</span>
        <h2>Os que mais acumulam, <em class="accent">mais ganham</em></h2>
      </div>
      <div class="dr-premios">
        {premios.map((p) => (
          <div class="dr-premio">
            <div class="dr-premio-val">{p.valor}</div>
            <strong>{p.quando}</strong>
            <p>{p.regra}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--navy">
    <div class="container lg">
      <div class="section-header">
        <span class="tag-pill tag-pill--glow">Como acumular drops</span>
        <h2>Cada atitude <em class="accent">vale pontos</em></h2>
      </div>
      <div class="dr-acc">
        {comoAcumular.map((c) => (
          <div class="dr-acc-item">
            <span class="dr-acc-num">{c.d}<small>drops</small></span>
            <span class="dr-acc-txt">{c.t}</span>
          </div>
        ))}
      </div>
      <p class="dr-acc-note">Drops adicionais podem ser acumulados em campanhas especiais promovidas ao longo dos meses.</p>
    </div>
  </section>

  <section class="section section--cream">
    <div class="container md">
      <div class="section-header">
        <span class="tag-pill">Regulamento</span>
        <h2>Regras de <em class="accent">elegibilidade</em></h2>
      </div>
      <ul class="check-list dr-regras">
        {regras.map((r) => (
          <li class="check-item"><span class="check-circle"><iconify-icon icon="solar:check-read-linear"></iconify-icon></span>{r}</li>
        ))}
      </ul>
    </div>
  </section>

  <section class="cta-band">
    <div class="container md">
      <h2>Comece a <em>acumular drops</em> hoje</h2>
      <p>Já é cliente Templum? Acompanhe seu saldo no Menu Perfil da plataforma. Ainda não é? Fale com a gente e comece sua jornada.</p>
      <a href="/form/" class="btn btn--dark btn--lg">Falar com a Templum <iconify-icon icon="solar:arrow-right-linear"></iconify-icon></a>
    </div>
  </section>
</Base>

<style>
  .dr-prog { display: grid; grid-template-columns: repeat(2, 1fr); gap: 22px; margin-top: 44px; }
  @media (max-width: 760px) { .dr-prog { grid-template-columns: 1fr; } }
  .dr-ico { width: 54px; height: 54px; border-radius: 14px; display: grid; place-items: center; font-size: 28px; color: var(--orange); background: rgba(255,89,37,0.10); margin-bottom: 16px; }

  .dr-premios { display: grid; grid-template-columns: repeat(2, 1fr); gap: 22px; margin-top: 44px; }
  @media (max-width: 760px) { .dr-premios { grid-template-columns: 1fr; } }
  .dr-premio { text-align: center; background: var(--surface); border: 1px solid var(--border); border-radius: var(--r-24); padding: 40px 32px; box-shadow: var(--shadow-card); }
  .dr-premio-val { font-size: clamp(40px, 6vw, 60px); font-weight: 800; letter-spacing: -0.04em; color: var(--orange); line-height: 1; margin-bottom: 12px; }
  .dr-premio strong { display: block; font-size: 17px; font-weight: 800; color: var(--text); margin-bottom: 6px; }
  .dr-premio p { font-size: 14px; color: var(--text-mid); line-height: 1.55; }

  .dr-acc { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; margin-top: 44px; }
  @media (max-width: 880px) { .dr-acc { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) { .dr-acc { grid-template-columns: 1fr; } }
  .dr-acc-item { display: flex; align-items: center; gap: 14px; padding: 16px 18px; background: rgba(255,244,221,0.04); border: 1px solid rgba(255,244,221,0.12); border-radius: var(--r-16); }
  .dr-acc-num { flex-shrink: 0; min-width: 58px; display: flex; flex-direction: column; align-items: center; font-size: 24px; font-weight: 800; color: var(--orange); line-height: 1; }
  .dr-acc-num small { font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: rgba(255,244,221,0.5); margin-top: 3px; }
  .dr-acc-txt { font-size: 14px; color: rgba(255,244,221,0.82); line-height: 1.4; }
  .dr-acc-note { text-align: center; font-size: 14px; color: rgba(255,244,221,0.6); margin-top: 28px; font-style: italic; }

  .dr-regras { max-width: 720px; margin: 40px auto 0; display: grid; gap: 14px; }
</style>
