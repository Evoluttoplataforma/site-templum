---
import Base from "../../layouts/Base.astro";
import { getCollection } from "astro:content";

const artigos = (await getCollection("blog")).sort(
  (a, b) => new Date(b.data.dataISO).getTime() - new Date(a.data.dataISO).getTime()
);

const categorias = ["Todos", ...new Set(artigos.map((a) => a.data.categoria))];
---

<Base
  title="Blog — Qualidade, ISO e Gestão para Empresas | Templum"
  description="Conteúdos práticos sobre ISO 9001, ISO 14001, ISO 27001, gestão da qualidade e certificações. Aprenda com quem já certificou mais de 2.000 empresas."
>
  <!-- HERO -->
  <section class="blog-hero">
    <div class="container md">
      <span class="tag-pill">Blog Templum</span>
      <h1>Conteúdos para quem quer <em class="accent">crescer com gestão</em></h1>
      <p>Materiais práticos sobre ISO, qualidade e gestão — escritos por quem já certificou mais de 2.000 empresas.</p>
    </div>
  </section>

  <!-- FILTROS + GRID -->
  <section class="section section--cream blog-sec">
    <div class="container xl">

      <div class="blog-filters" id="blogFilters">
        {categorias.map((c, i) => (
          <button class={`blog-filter ${i === 0 ? "active" : ""}`} data-cat={c}>{c}</button>
        ))}
      </div>

      <div class="blog-grid" id="blogGrid">
        {artigos.map((a) => (
          <a class="blog-card" href={`/blog/${a.slug}`} data-cat={a.data.categoria}>
            <div class="blog-thumb">
              <span class="blog-fallback">Templum<em>!</em></span>
              {a.data.capa && (
                <img src={a.data.capa} alt={a.data.titulo} loading="lazy" />
              )}
              <span class="blog-cat-badge">{a.data.categoria}</span>
            </div>
            <div class="blog-body">
              <h2>{a.data.titulo}</h2>
              <p>{a.data.descricao}</p>
              <div class="blog-meta">
                <span>{a.data.data}</span>
                <span class="blog-read">Ler artigo →</span>
              </div>
            </div>
          </a>
        ))}
      </div>

      {artigos.length === 0 && (
        <p class="blog-empty">Nenhum artigo publicado ainda. Volte em breve!</p>
      )}
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-band">
    <div class="container md">
      <h2>Pronto para <em>certificar</em> sua empresa?</h2>
      <p>Fale com um especialista da Templum e receba um diagnóstico gratuito.</p>
      <a href="/form/" class="btn btn--dark btn--lg">Solicitar diagnóstico gratuito <iconify-icon icon="solar:arrow-right-linear"></iconify-icon></a>
    </div>
  </section>
</Base>

<style>
  /* ── HERO ── */
  .blog-hero {
    background: var(--navy); color: var(--cream);
    padding: clamp(72px, 8vw, 110px) 0 clamp(56px, 6vw, 80px);
    text-align: center;
  }
  .blog-hero .tag-pill { margin-bottom: 20px; }
  .blog-hero h1 {
    font-size: clamp(32px, 4.5vw, 58px); font-weight: 800;
    letter-spacing: -0.03em; line-height: 1.1; margin-bottom: 16px; color: var(--cream);
  }
  .blog-hero p { font-size: 17px; color: rgba(255,244,221,0.7); max-width: 560px; margin: 0 auto; line-height: 1.7; }

  /* ── FILTROS ── */
  .blog-filters {
    display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 40px;
  }
  .blog-filter {
    font-size: 13px; font-weight: 700; padding: 8px 18px; border-radius: 999px;
    border: 1.5px solid var(--border-2); background: var(--surface); color: var(--text-2);
    cursor: pointer; transition: background .25s, color .25s, border-color .25s;
  }
  .blog-filter:hover { border-color: var(--orange); color: var(--orange); }
  .blog-filter.active { background: var(--orange); border-color: var(--orange); color: #fff; }

  /* ── GRID ── */
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }
  @media (max-width: 960px) { .blog-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 580px) { .blog-grid { grid-template-columns: 1fr; } }

  .blog-card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--r-20); overflow: hidden;
    transition: transform .35s var(--ease-soft), box-shadow .35s var(--ease-soft), border-color .35s;
    display: flex; flex-direction: column;
  }
  .blog-card:hover { transform: translateY(-5px); box-shadow: var(--shadow-card); border-color: var(--border-2); }
  .blog-card.hidden { display: none; }

  .blog-thumb {
    position: relative; aspect-ratio: 16/9;
    background: linear-gradient(135deg, var(--navy), var(--surface-deep));
    overflow: hidden;
  }
  .blog-fallback {
    position: absolute; inset: 0; display: grid; place-items: center;
    font-size: 32px; font-weight: 800; color: rgba(255,244,221,0.08);
  }
  .blog-fallback em { font-style: normal; color: rgba(255,89,37,0.3); }
  .blog-thumb img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .blog-cat-badge {
    position: absolute; top: 12px; left: 12px;
    font-size: 10.5px; font-weight: 700; letter-spacing: 0.05em; text-transform: uppercase;
    color: #fff; background: rgba(255,89,37,0.9); padding: 4px 10px; border-radius: 999px;
  }

  .blog-body { padding: 22px 20px 20px; display: flex; flex-direction: column; flex: 1; }
  .blog-body h2 { font-size: 17px; font-weight: 800; color: var(--text); line-height: 1.35; margin-bottom: 10px; letter-spacing: -0.01em; }
  .blog-body p { font-size: 13.5px; color: var(--text-mid); line-height: 1.65; flex: 1; margin-bottom: 16px; }
  .blog-meta { display: flex; justify-content: space-between; align-items: center; font-size: 12px; color: var(--text-soft); margin-top: auto; }
  .blog-read { color: var(--orange); font-weight: 700; font-size: 13px; }

  .blog-empty { text-align: center; color: var(--text-mid); padding: 48px 0; font-size: 16px; }
</style>

<script is:inline>
  (function () {
    const filters = document.querySelectorAll(".blog-filter");
    const cards = document.querySelectorAll(".blog-card");
    filters.forEach((btn) => {
      btn.addEventListener("click", () => {
        filters.forEach((b) => b.classList.remove("active"));
        btn.classList.add("active");
        const cat = btn.dataset.cat;
        cards.forEach((card) => {
          card.classList.toggle("hidden", cat !== "Todos" && card.dataset.cat !== cat);
        });
      });
    });
  })();
</script>
