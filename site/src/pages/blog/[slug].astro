---
import Base from "../../layouts/Base.astro";
import Newsletter from "../../components/Newsletter.astro";
import { artigos } from "../../data/artigos.js";

export function getStaticPaths() {
  return artigos.map((a) => ({ params: { slug: a.slug }, props: { artigo: a } }));
}

const { artigo } = Astro.props;
const relacionados = artigos.filter((a) => a.slug !== artigo.slug).slice(0, 3);
---

<Base title={`${artigo.titulo} — Blog Templum`} description={artigo.titulo}>
  <article class="bp">
    <div class="bp-hero section--navy">
      <div class="container md bp-hero-inner">
        <a href="/blog" class="bp-back"><iconify-icon icon="solar:alt-arrow-left-linear"></iconify-icon> Voltar ao blog</a>
        <span class="tag-pill tag-pill--glow">{artigo.categoria}</span>
        <h1>{artigo.titulo}</h1>
        <span class="bp-meta"><iconify-icon icon="solar:calendar-minimalistic-bold"></iconify-icon> {artigo.data}</span>
      </div>
    </div>

    <div class="section">
      <div class="container md bp-body">
        <div class="bp-soon">
          <iconify-icon icon="solar:pen-new-square-bold"></iconify-icon>
          <div>
            <h2>Conteúdo em produção</h2>
            <p>Nosso time editorial está finalizando este artigo. Enquanto isso, fale com um especialista ou assine a newsletter para receber quando publicarmos.</p>
            <div class="bp-soon-cta">
              <a href="/form" class="btn btn--primary btn--lg">Falar com um especialista <iconify-icon icon="solar:arrow-right-linear"></iconify-icon></a>
              <a href="/consultoria" class="btn btn--secondary btn--lg">Ver consultorias</a>
            </div>
          </div>
        </div>
      </div>
    </div>

    <section class="section section--cream">
      <div class="container">
        <div class="section-header"><span class="tag-pill">Continue lendo</span><h2>Outros <em class="accent">artigos</em></h2></div>
        <div class="bp-rel">
          {relacionados.map((r) => (
            <a class="bp-rel-card" href={`/blog/${r.slug}`}>
              <span class="bp-rel-cat">{r.categoria}</span>
              <h3>{r.titulo}</h3>
              <span class="bp-rel-date">{r.data}</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <Newsletter />
  </article>
</Base>

<style>
  .bp-hero { padding: clamp(56px, 9vh, 96px) 0 clamp(40px, 6vh, 64px); }
  .bp-hero-inner { position: relative; }
  .bp-back { display: inline-flex; align-items: center; gap: 6px; font-size: 14px; font-weight: 600; color: rgba(255,244,221,0.7); margin-bottom: 22px; }
  .bp-back:hover { color: var(--orange); }
  .bp-hero .tag-pill { margin-bottom: 18px; }
  .bp-hero h1 { font-size: clamp(28px, 4vw, 46px); font-weight: 800; line-height: 1.12; letter-spacing: -0.025em; color: var(--cream); }
  .bp-meta { display: inline-flex; align-items: center; gap: 7px; margin-top: 18px; font-size: 14px; color: rgba(255,244,221,0.6); }
  .bp-meta iconify-icon { color: var(--orange); }

  .bp-soon { display: flex; gap: 20px; align-items: flex-start; background: var(--surface); border: 1px solid var(--border); border-radius: var(--r-24); padding: clamp(28px, 4vw, 44px); box-shadow: var(--shadow-card); }
  .bp-soon > iconify-icon { font-size: 40px; color: var(--orange); flex-shrink: 0; }
  .bp-soon h2 { font-size: 22px; font-weight: 800; letter-spacing: -0.02em; margin-bottom: 10px; }
  .bp-soon p { font-size: 16px; color: var(--text-mid); line-height: 1.6; margin-bottom: 22px; }
  .bp-soon-cta { display: flex; gap: 12px; flex-wrap: wrap; }

  .bp-rel { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 40px; }
  @media (max-width: 880px) { .bp-rel { grid-template-columns: 1fr; } }
  .bp-rel-card { display: flex; flex-direction: column; gap: 8px; background: var(--surface); border: 1px solid var(--border); border-radius: var(--r-20); padding: 26px 24px; transition: transform .3s var(--ease-soft), box-shadow .3s var(--ease-soft); }
  .bp-rel-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-card); }
  .bp-rel-cat { font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: var(--orange); }
  .bp-rel-card h3 { font-size: 17px; font-weight: 800; letter-spacing: -0.01em; line-height: 1.3; flex: 1; }
  .bp-rel-date { font-size: 13px; color: var(--text-soft); }
</style>
