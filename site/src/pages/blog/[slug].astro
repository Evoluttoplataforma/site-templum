---
import Base from "../../layouts/Base.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const artigos = await getCollection("blog");
  return artigos.map((a) => ({
    params: { slug: a.slug },
    props: { artigo: a },
  }));
}

const { artigo } = Astro.props;
const { Content } = await artigo.render();

const titulo = artigo.data.titulo;
const descricao = artigo.data.descricao;
const categoria = artigo.data.categoria;
const data = artigo.data.data;
const dataISO = artigo.data.dataISO;
const autor = artigo.data.autor || "Equipe Templum";
const capa = artigo.data.capa || "";
const keywords = artigo.data.keywords || [];

const SITE = "https://templum.com.br";
const url = `${SITE}/blog/${artigo.slug}`;

const schemaArticle = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: titulo,
  description: descricao,
  author: { "@type": "Organization", name: "Templum Consultoria", url: SITE },
  publisher: {
    "@type": "Organization",
    name: "Templum Consultoria",
    logo: { "@type": "ImageObject", url: `${SITE}/assets/logo/templum.png` },
  },
  datePublished: dataISO,
  dateModified: dataISO,
  url,
  keywords: keywords.join(", "),
  mainEntityOfPage: { "@type": "WebPage", "@id": url },
};

const schemaBreadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: SITE },
    { "@type": "ListItem", position: 2, name: "Blog", item: `${SITE}/blog` },
    { "@type": "ListItem", position: 3, name: titulo, item: url },
  ],
};
---

<Base
  title={`${titulo} | Blog Templum`}
  description={descricao}
  ogImage={capa || "/assets/og/templum-og.jpg"}
  schemas={[schemaArticle, schemaBreadcrumb]}
>

  <nav class="breadcrumb-bar" aria-label="Navegação estrutural">
    <div class="container lg">
      <ol class="breadcrumb">
        <li><a href="/">Home</a></li>
        <li aria-hidden="true">›</li>
        <li><a href="/blog">Blog</a></li>
        <li aria-hidden="true">›</li>
        <li aria-current="page">{titulo}</li>
      </ol>
    </div>
  </nav>

  <header class="art-hero">
    <div class="container md">
      <span class="tag-pill">{categoria}</span>
      <h1>{titulo}</h1>
      <p class="art-desc">{descricao}</p>
      <div class="art-meta">
        <span class="art-autor">
          <iconify-icon icon="solar:user-circle-bold"></iconify-icon>
          {autor}
        </span>
        <span class="art-data">
          <iconify-icon icon="solar:calendar-bold"></iconify-icon>
          {data}
        </span>
        <span class="art-cat">{categoria}</span>
      </div>
    </div>
  </header>

  {capa && (
    <div class="art-capa-wrap">
      <div class="container lg">
        <img class="art-capa" src={capa} alt={titulo} loading="eager" />
      </div>
    </div>
  )}

  <div class="art-layout container lg">
    <article class="art-content prose">
      <Content />
    </article>

    <aside class="art-sidebar">
      <div class="sidebar-cta">
        <span class="tag-pill" style="margin-bottom:16px">Diagnóstico gratuito</span>
        <p>Descubra o que falta para o seu laboratório conquistar a ISO 9001.</p>
        <a href="/iso-9001-laboratorios#diagnostico" class="btn btn--primary btn--block btn--lg" style="margin-top:18px">
          Quero meu diagnóstico <iconify-icon icon="solar:arrow-right-linear"></iconify-icon>
        </a>
        <ul class="sidebar-selos">
          <li><iconify-icon icon="solar:shield-check-bold"></iconify-icon> Garantia de 200%</li>
          <li><iconify-icon icon="solar:clock-circle-bold"></iconify-icon> Resposta em 1 dia útil</li>
          <li><iconify-icon icon="solar:medal-ribbons-star-bold"></iconify-icon> +2.000 certificados</li>
        </ul>
      </div>
    </aside>
  </div>

  <section class="cta-band">
    <div class="container md">
      <h2>Pronto para <em>certificar</em> seu laboratório?</h2>
      <p>Agende uma conversa com um especialista da Templum. Sem compromisso.</p>
      <a href="/iso-9001-laboratorios#diagnostico" class="btn btn--dark btn--lg">
        Solicitar diagnóstico gratuito <iconify-icon icon="solar:arrow-right-linear"></iconify-icon>
      </a>
    </div>
  </section>

</Base>

<style>
  .breadcrumb-bar { background: var(--bg); border-bottom: 1px solid var(--border); padding: 12px 0; }
  .breadcrumb { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; font-size: 13px; color: var(--text-soft); }
  .breadcrumb a { color: var(--text-mid); transition: color .2s; }
  .breadcrumb a:hover { color: var(--orange); }
  .breadcrumb li:last-child { color: var(--text); font-weight: 600; }

  .art-hero {
    background: var(--navy); color: var(--cream);
    padding: clamp(56px, 7vw, 96px) 0 clamp(40px, 5vw, 64px);
    text-align: center;
  }
  .art-hero .tag-pill { margin-bottom: 20px; }
  .art-hero h1 {
    font-size: clamp(28px, 4vw, 52px); font-weight: 800;
    letter-spacing: -0.03em; line-height: 1.1; color: var(--cream); margin-bottom: 16px;
  }
  .art-desc { font-size: 18px; color: rgba(255,244,221,0.72); line-height: 1.7; max-width: 680px; margin: 0 auto 28px; }
  .art-meta { display: flex; align-items: center; justify-content: center; gap: 20px; flex-wrap: wrap; font-size: 13px; color: rgba(255,244,221,0.55); }
  .art-meta iconify-icon { font-size: 15px; }
  .art-autor, .art-data { display: flex; align-items: center; gap: 6px; }
  .art-cat { background: rgba(255,89,37,0.25); color: var(--orange); padding: 3px 10px; border-radius: 999px; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; }

  .art-capa-wrap { background: var(--navy); }
  .art-capa { width: 100%; border-radius: var(--r-20) var(--r-20) 0 0; aspect-ratio: 16/6; object-fit: cover; display: block; }

  .art-layout {
    display: grid; grid-template-columns: 1fr 320px;
    gap: clamp(40px, 5vw, 72px);
    padding-top: 56px; padding-bottom: 72px; align-items: start;
  }
  @media (max-width: 960px) { .art-layout { grid-template-columns: 1fr; } }

  .prose { color: var(--text); font-size: 17px; line-height: 1.8; }
  .prose :global(h2) { font-size: clamp(22px, 2.8vw, 30px); font-weight: 800; letter-spacing: -0.02em; margin: 48px 0 18px; color: var(--text); }
  .prose :global(h3) { font-size: 19px; font-weight: 700; margin: 32px 0 12px; color: var(--text); }
  .prose :global(p) { margin-bottom: 22px; }
  .prose :global(strong) { font-weight: 700; color: var(--text); }
  .prose :global(ul), .prose :global(ol) { margin: 18px 0 22px 24px; display: flex; flex-direction: column; gap: 10px; }
  .prose :global(ul) { list-style: disc; }
  .prose :global(ol) { list-style: decimal; }
  .prose :global(hr) { border: none; border-top: 1px solid var(--border); margin: 40px 0; }
  .prose :global(a) { color: var(--orange); font-weight: 600; text-decoration: underline; text-underline-offset: 3px; }
  .prose :global(a:hover) { color: var(--orange-dark); }
  .prose :global(blockquote) { border-left: 3px solid var(--orange); padding: 14px 20px; margin: 28px 0; background: rgba(255,89,37,0.05); border-radius: 0 8px 8px 0; font-style: italic; color: var(--text-mid); }

  .art-sidebar { position: sticky; top: 100px; }
  .sidebar-cta { background: var(--navy); color: var(--cream); border-radius: var(--r-20); padding: 28px 24px; border: 1px solid rgba(255,244,221,0.08); }
  .sidebar-cta p { font-size: 15px; color: rgba(255,244,221,0.72); line-height: 1.65; }
  .sidebar-selos { margin-top: 16px; display: flex; flex-direction: column; gap: 10px; }
  .sidebar-selos li { display: flex; align-items: center; gap: 8px; font-size: 13px; color: rgba(255,244,221,0.7); }
  .sidebar-selos iconify-icon { color: var(--orange); font-size: 16px; flex-shrink: 0; }
</style>
