---
import Base from "../layouts/Base.astro";
import PageHero from "../components/PageHero.astro";

// NOTA: copy provisória (não há página de carreira no site atual) — validar com o cliente.
const beneficios = [
  { icon: "solar:graph-up-bold", t: "Crescimento real", d: "Plano de desenvolvimento, trilhas de carreira e aprendizado constante — aprender faz parte do caminho." },
  { icon: "solar:home-wifi-bold", t: "Flexibilidade", d: "Trabalho com autonomia e foco em resultado, não em horas de cadeira." },
  { icon: "solar:hand-heart-bold", t: "Time que é família", d: "Mais que colegas: laços de confiança e respeito que vão além do trabalho." },
  { icon: "solar:cup-star-bold", t: "Sucesso celebrado", d: "Cada conquista, pequena ou grande, é reconhecida e comemorada junto." },
];
---

<Base
  title="Carreira — Venha crescer com a Templum"
  description="Faça parte de um time de mais de 50 profissionais apaixonados por fortalecer empresas. Conheça a cultura Templum e as oportunidades de carreira."
>
  <PageHero
    tag="Trabalhe na Templum"
    sub="Somos um time de mais de 50 profissionais que acreditam que o crescimento do país passa pelo fortalecimento das suas empresas. Se você tem o olho brilhando e vontade de fazer o melhor sempre, seu lugar é aqui."
    image="/assets/img/hero/templum-consultoria-socios.webp"
    badge="Time Templum"
    icon="solar:users-group-rounded-bold"
    chips={["+50 profissionais", "Time que é família", "Crescimento real"]}
  >
    <Fragment slot="title">Apaixonados por <em class="accent">fortalecer empresas</em></Fragment>
    <Fragment slot="cta">
      <a href="https://wa.me/5519993521270?text=Ol%C3%A1!%20Tenho%20interesse%20em%20trabalhar%20na%20Templum." target="_blank" rel="noopener" class="btn btn--primary btn--lg">Enviar meu currículo <iconify-icon icon="solar:arrow-right-linear"></iconify-icon></a>
      <a href="/quem-somos/valores" class="btn btn--onDark btn--lg">Nossos valores</a>
    </Fragment>
  </PageHero>

  <section class="section section--cream">
    <div class="container">
      <div class="section-header">
        <span class="tag-pill">Por que a Templum</span>
        <h2>Um lugar para <em class="accent">crescer de verdade</em></h2>
      </div>
      <div class="cr-grid">
        {beneficios.map((b) => (
          <div class="eco-card">
            <span class="cr-ico"><iconify-icon icon={b.icon}></iconify-icon></span>
            <h3>{b.t}</h3>
            <p>{b.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="cta-band">
    <div class="container md">
      <h2>Vamos <em>crescer juntos</em>?</h2>
      <p>Envie seu currículo pelo WhatsApp e conte um pouco sobre você. Estamos sempre em busca de gente apaixonada pelo que faz.</p>
      <a href="https://wa.me/5519993521270?text=Ol%C3%A1!%20Tenho%20interesse%20em%20trabalhar%20na%20Templum." target="_blank" rel="noopener" class="btn btn--dark btn--lg">Enviar currículo pelo WhatsApp <iconify-icon icon="solar:arrow-right-linear"></iconify-icon></a>
    </div>
  </section>
</Base>

<style>
  .cr-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 22px; margin-top: 44px; }
  @media (max-width: 980px) { .cr-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) { .cr-grid { grid-template-columns: 1fr; } }
  .cr-ico { width: 50px; height: 50px; border-radius: 13px; display: grid; place-items: center; font-size: 25px; color: var(--orange); background: rgba(255,89,37,0.10); margin-bottom: 14px; }
</style>
