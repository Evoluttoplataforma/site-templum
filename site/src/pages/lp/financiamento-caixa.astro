<script is:inline>
  (function () {
    var link = document.querySelector(".fc-case-video[data-vimeo]");
    var lb = document.querySelector("[data-case-lightbox]");
    var frame = lb && lb.querySelector("[data-case-lb-frame]");
    if (!link || !lb || !frame) return;
    function open(id) {
      frame.innerHTML = '<iframe src="https://player.vimeo.com/video/' + id + '?autoplay=1&title=0&byline=0&portrait=0" allow="autoplay; fullscreen; picture-in-picture" allowfullscreen></iframe>';
      lb.hidden = false; document.body.style.overflow = "hidden";
    }
    function close() { lb.hidden = true; frame.innerHTML = ""; document.body.style.overflow = ""; }
    link.addEventListener("click", function (e) { e.preventDefault(); open(link.dataset.vimeo); });
    lb.addEventListener("click", function (e) { if (e.target === lb || e.target.closest("[data-case-lb-close]")) close(); });
    document.addEventListener("keydown", function (e) { if (e.key === "Escape" && !lb.hidden) close(); });
  })();
</script>
