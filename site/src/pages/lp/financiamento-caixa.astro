---
import LpBase from "../../layouts/LpBase.astro";
import SeloImplementando from "../../components/SeloImplementando.astro";
import Especialistas from "../../components/Especialistas.astro";
import Testimonials from "../../components/Testimonials.astro";
import DepoimentosTexto from "../../components/DepoimentosTexto.astro";
import ClientLogos from "../../components/ClientLogos.astro";
import LeadForm from "../../components/LeadForm.astro";

const marketStats = [
  { num: "R$ 1 tri", label: "em crédito imobiliário na carteira da Caixa — marca histórica alcançada em 2026" },
  { num: "+16%", label: "de crescimento previsto no financiamento imobiliário em 2026 (SBPE + FGTS), segundo a Abecip" },
  { num: "R$ 250 bi", label: "em concessões da Caixa projetadas para 2026 — recorde absoluto da série" },
  { num: "+2,9 mi", label: "trabalhadores formais na construção civil em 2025, 2º setor que mais empregou no país (CBIC)" },
];

const analiseCaixa = [
  { icon: "solar:document-text-bold", t: "Documentação", d: "Registro do terreno, projeto aprovado, alvará e licenças ambientais em dia." },
  { icon: "solar:case-round-bold", t: "Situação fiscal e societária", d: "Regularidade na Receita Federal, Fazenda, trabalhista e junto a órgãos de proteção ao crédito." },
  { icon: "solar:chart-2-bold", t: "Capacidade financeira", d: "Saúde econômico-financeira e solidez para sustentar a obra até a liberação por etapas." },
  { icon: "solar:medal-star-bold", t: "Histórico de entregas", d: "Capacidade técnica comprovada: obras anteriores, prazos e qualidade de execução." },
  { icon: "solar:users-group-rounded-bold", t: "Equipe técnica", d: "Responsável técnico e estrutura de gestão dedicados ao empreendimento." },
  { icon: "solar:shield-check-bold", t: "Sistema de gestão da qualidade", d: "Processos de obra organizados e comprovados — é aqui que entra o PBQP-H." },
];

const timeline = [
  { n: "01", t: "Escolha do empreendimento", d: "Você define o terreno e o produto: o tipo de empreendimento que vai construir e vender." },
  { n: "02", t: "Estudos", d: "Viabilidade técnica, jurídica e financeira do projeto — para saber se a conta fecha antes de entrar na fila do banco." },
  { n: "03", t: "Documentação", d: "Registro do terreno, projeto aprovado, alvará e licenças ambientais, além das viabilidades de água, esgoto e energia." },
  { n: "04", t: "Cadastro", d: "Sua construtora entra no cadastro da Caixa, com situação fiscal, trabalhista e societária regularizada." },
  { n: "05", t: "GERIC", d: "A Caixa avalia o histórico e a capacidade técnica da sua empresa nesta triagem — é aqui que a maioria trava." },
  { n: "06", t: "Adequação da empresa", d: "Ajustamos processos internos, controles e organização para atender aos critérios de análise de risco do banco." },
  { n: "07", t: "PBQP-H", d: "A certificação de qualidade exigida pela Caixa entra em cena, comprovando que sua obra segue um sistema de gestão reconhecido." },
  { n: "08", t: "Aprovação", d: "Com tudo em ordem, o projeto e a empresa passam pela análise final de crédito." },
  { n: "09", t: "Contratação", d: "Assinatura do contrato de financiamento, com prazos e condições definidas para a obra." },
  { n: "10", t: "Liberação dos recursos", d: "O dinheiro entra por etapas, conforme o avanço físico da obra é medido e comprovado." },
];

const templumSteps = [
  { t: "Diagnóstico", d: "Avaliamos o cenário atual da sua construtora e o que falta para chegar pronta na Caixa." },
  { t: "Plano de ação", d: "Montamos um cronograma realista, com prioridades e responsáveis para cada etapa." },
  { t: "Preparação documental", d: "Organizamos a documentação técnica, jurídica e financeira exigida no processo." },
  { t: "Implantação do PBQP-H", d: "Estruturamos o sistema de gestão da qualidade da obra conforme o SiAC." },
  { t: "Preparação para o GERIC", d: "Deixamos a empresa alinhada aos critérios de análise de risco do banco." },
  { t: "Acompanhamento", d: "Seguimos ao lado da sua equipe até a submissão e a resposta da Caixa." },
  { t: "Empresa pronta", d: "Sua construtora habilitada a acessar financiamento sempre que precisar — não só uma vez." },
];

const semTemplum = [
  "Projeto travado no GERIC sem entender o motivo",
  "Documentação incompleta descoberta na hora errada",
  "PBQP-H tratado como burocracia de última hora",
  "Meses de atraso até a primeira parcela ser liberada",
  "Reprovação silenciosa, sem retorno claro do banco",
];
const comTemplum = [
  "Diagnóstico prévio mostra exatamente o que falta",
  "Documentação organizada antes de entrar na fila",
  "PBQP-H implantado com método e prazo definidos",
  "Empresa entra no GERIC já qualificada",
  "Acompanhamento até a liberação dos recursos",
];

const faqs = [
  { q: "Toda construtora consegue financiamento da Caixa?", a: "Não automaticamente. O crédito para produção imobiliária existe e está em expansão, mas a Caixa qualifica a empresa antes de liberar qualquer valor — avaliando gestão, documentação, capacidade financeira e histórico. É exatamente esse preparo que decide quem acessa o recurso e quem fica de fora." },
  { q: "O PBQP-H é obrigatório para financiar com a Caixa?", a: "É frequentemente exigido. O PBQP-H comprova que a sua obra segue um sistema de gestão da qualidade reconhecido, e costuma aparecer como requisito no cadastro e na homologação da construtora — especialmente em programas como o Apoio à Produção e o Minha Casa Minha Vida." },
  { q: "O que é o GERIC?", a: "GERIC é a área da Caixa Econômica Federal responsável por avaliar e homologar as construtoras aptas a operar com financiamento e recursos do banco. É uma triagem que vai muito além do terreno e do projeto — analisa aspectos tributários, trabalhistas, societários, técnicos e de licenciamento." },
  { q: "Quanto tempo demora todo o processo, do diagnóstico à liberação dos recursos?", a: "Varia conforme o nível de organização da empresa e a complexidade do empreendimento. Construtoras já com PBQP-H e documentação em dia avançam mais rápido; quem parte do zero costuma levar alguns meses de preparação antes mesmo de submeter o cadastro à Caixa." },
  { q: "Posso financiar obras comerciais, ou só empreendimentos habitacionais?", a: "A maior parte dos programas da Caixa é voltada à produção habitacional, mas existem linhas de apoio à produção para outros perfis de empreendimento. Um especialista pode indicar a linha mais adequada ao seu projeto." },
  { q: "Minha construtora nunca trabalhou com a Caixa. Dá para começar do zero?", a: "Sim. A maioria das construtoras que atendemos está nessa situação. O caminho é mais longo, mas perfeitamente possível: começa pelo diagnóstico, passa pela organização da empresa e do PBQP-H, e termina no cadastro e submissão ao GERIC." },
  { q: "Quais são os níveis do PBQP-H e qual eu preciso ter?", a: "O SiAC (sistema do PBQP-H para obras) tem níveis evolutivos — D, C, B e A. O nível exigido varia conforme o programa e o valor do financiamento buscado; por isso o diagnóstico avalia o seu caso específico antes de definir a meta." },
  { q: "O que a Caixa analisa além do projeto e do terreno?", a: "Situação cadastral e fiscal da empresa, regularidade trabalhista e societária, saúde econômico-financeira, histórico de obras entregues, qualificação técnica da equipe e o sistema de gestão da qualidade — normalmente comprovado pelo PBQP-H." },
  { q: "Quanto custa preparar minha empresa para o GERIC e o PBQP-H?", a: "O investimento varia conforme o porte da construtora e o quanto falta organizar. O diagnóstico inicial é gratuito, e a partir dele apresentamos uma proposta sob medida para o seu cenário." },
  { q: "O financiamento cobre 100% do custo da obra?", a: "Programas de apoio à produção podem financiar uma parcela significativa do custo de obra a executar, combinado com outras fontes de recurso do empreendimento. As condições exatas dependem da análise de cada operação." },
  { q: "O que é o 'Apoio à Produção' da Caixa?", a: "É a linha da Caixa voltada a financiar a construção de empreendimentos habitacionais, liberando recursos por etapas conforme a obra avança — desde que a construtora esteja qualificada e o projeto aprovado." },
  { q: "Como funciona o diagnóstico da minha construtora?", a: "Você preenche o formulário nesta página com os dados básicos da sua empresa. Um especialista da Templum analisa gratuitamente o cenário — PBQP-H, tempo de mercado, histórico com a Caixa — e retorna com o que falta para chegar pronta na análise de crédito." },
];

const schemaService = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: "Preparação de construtoras para financiamento Caixa (GERIC e PBQP-H)",
  description: "A Templum prepara construtoras e incorporadoras para acessar linhas de financiamento e crédito imobiliário da Caixa Econômica Federal, do diagnóstico à homologação no GERIC, incluindo a implantação do PBQP-H.",
  provider: { "@type": "Organization", name: "Templum Consultoria", url: "https://templum.com.br" },
  areaServed: { "@type": "Country", name: "Brasil" },
  serviceType: "Consultoria PBQP-H e preparação para GERIC",
  audience: { "@type": "Audience", audienceType: "Construtoras, incorporadoras e empreiteiras" },
};

const schemaFaq = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({ "@type": "Question", name: f.q, acceptedAnswer: { "@type": "Answer", text: f.a } })),
};
---

<LpBase
  title="Financiamento Caixa para Construtoras — Como Conseguir | Templum"
  description="Descubra como construtoras acessam linhas de financiamento e crédito imobiliário da Caixa. Fale com um especialista e entenda o caminho — do GERIC ao PBQP-H — até a liberação dos recursos."
  formAnchor="#diagnostico"
  noindex={false}
  schemas={[schemaService, schemaFaq]}
>
  <!-- HERO -->
  <section class="fc-hero">
    <div class="fc-hero-bg" aria-hidden="true"></div>
    <div class="container xl fc-hero-grid">
      <div class="fc-hero-text">
        <span class="tag-pill tag-pill--glow">Financiamento Caixa · Construtoras</span>
        <h1 class="fc-hero-title">Construa utilizando recursos da <em class="accent">Caixa</em></h1>
        <p class="fc-hero-sub">Descubra como centenas de construtoras conseguem acessar linhas de financiamento para produção imobiliária — e o que muda quando sua empresa está pronta para ser aprovada.</p>
        <div class="fc-hero-chips">
          <span class="fc-hero-chip"><iconify-icon icon="solar:check-circle-bold"></iconify-icon>Crédito para produção imobiliária</span>
          <span class="fc-hero-chip"><iconify-icon icon="solar:check-circle-bold"></iconify-icon>Método aplicado em +500 construtoras</span>
          <span class="fc-hero-chip"><iconify-icon icon="solar:check-circle-bold"></iconify-icon>Diagnóstico sem custo</span>
        </div>
        <a href="#mercado" class="fc-hero-link">Ver dados do mercado <iconify-icon icon="solar:arrow-down-linear"></iconify-icon></a>
      </div>
      <div class="fc-hero-form">
        <LeadForm norma="Financiamento Caixa" titulo="EXCLUSIVO PARA CONSTRUTORAS" sub="Fale com um especialista e descubra o caminho até o crédito da Caixa. Não aplicável para pessoa física." cta="Quero entender como funciona" obrigado="/lp/financiamento-caixa-obrigado" simples={true} faturamento={true} labelEmpresa="Nome da Construtora" cargo={true} />
      </div>
    </div>
  </section>

  <!-- DADOS DO MERCADO -->
  <section id="mercado" class="section section--cream">
    <div class="container xl">
      <div class="section-header">
        <span class="tag-pill">O mercado agora</span>
        <h2>O crédito para construção está em <em class="accent">expansão histórica</em></h2>
        <p>A Caixa é o principal financiador da produção imobiliária no Brasil — e o volume de crédito disponível nunca foi tão alto.</p>
      </div>
      <div class="numbers-grid fc-stats">
        {marketStats.map((s) => (
          <div class="number-card reveal"><div class="value"><em>{s.num}</em></div><div class="label">{s.label}</div></div>
        ))}
      </div>
      <p class="src-note">
        Fontes:
        <a href="https://credited.com.br/noticias/2026/07/02/caixa-economica-alcanca-r-1-trilhao-em-credito-imobiliario/" target="_blank" rel="noopener">Caixa Econômica Federal (2026)</a> ·
        <a href="https://prognum.com.br/abecip-financiamentos-imobiliarios-com-recursos-das-cadernetas-do-sbpe-somaram-em-abril-r-1698-bilhoes/" target="_blank" rel="noopener">Abecip (abr/2026)</a> ·
        <a href="https://cbic.org.br/construcao-civil-projeta-2026-mais-positivo-que-2025-impulsionado-por-credito-e-investimentos/" target="_blank" rel="noopener">CBIC (2026)</a>
      </p>
    </div>
  </section>

  <!-- PROBLEMA -->
  <section class="section section--navy">
    <div class="container xl">
      <div class="section-header">
        <span class="tag-pill tag-pill--glow">O que ninguém te conta</span>
        <h2>O dinheiro existe. <em class="accent">Poucas construtoras conseguem acessar.</em></h2>
        <p>Enquanto o crédito para o comprador final bate recorde, o financiamento direto à produção — o dinheiro que entra na sua obra — segue muito mais seletivo. Não é falta de recurso: é que a Caixa avalia muito mais do que o terreno e o projeto.</p>
      </div>
      <div class="eco-grid fc-analise">
        {analiseCaixa.map((a) => (
          <div class="eco-card reveal"><span class="fc-ico"><iconify-icon icon={a.icon}></iconify-icon></span><h3>{a.t}</h3><p>{a.d}</p></div>
        ))}
      </div>
    </div>
  </section>

  <!-- SELO -->
  <SeloImplementando ctaHref="#diagnostico" ctaTexto="Quero meu diagnóstico gratuito" />

  <!-- TIMELINE — COMO FUNCIONA -->
  <section id="como-funciona" class="section section--cream fc-passos-sec">
    <div class="container lg">
      <div class="section-header">
        <span class="tag-pill">O caminho até o crédito</span>
        <h2>10 etapas entre a ideia e o <em class="accent">dinheiro na obra</em></h2>
        <p>Cada empreendimento passa por uma sequência parecida — quem entende o caminho evita surpresas e atrasos.</p>
      </div>
      <div class="fc-passos-list">
        {timeline.map((p) => (
          <div class="fc-passo-item reveal">
            <div class="fc-passo-num">{p.n}</div>
            <div class="fc-passo-connector" aria-hidden="true"></div>
            <div class="fc-passo-body"><h3>{p.t}</h3><p>{p.d}</p></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- GERIC -->
  <section class="section section--navy">
    <div class="container md fc-intro">
      <span class="tag-pill tag-pill--glow">GERIC · Caixa Econômica</span>
      <h2>GERIC: a etapa que trava a <em class="accent">maioria das construtoras</em></h2>
      <p>O GERIC é a área da Caixa responsável por avaliar e homologar as construtoras aptas a operar com financiamento e recursos do banco. Ele existe para proteger o dinheiro que a Caixa está prestes a colocar na sua obra — garantindo que a empresa do outro lado tem capacidade real de entregar.</p>
      <p>É por isso que a análise vai muito além do projeto: aspectos tributários, trabalhistas, societários, registros do terreno, qualificação técnica, licenciamento ambiental e as minutas de contrato entram todos na mesma triagem. A maioria das construtoras trava aqui não porque falta obra boa — falta organização que comprove isso ao banco.</p>
    </div>
  </section>

  <!-- PBQP-H -->
  <section class="section section--cream">
    <div class="container md fc-intro">
      <span class="tag-pill">PBQP-H</span>
      <h2>PBQP-H: o requisito que aparece no meio do caminho</h2>
      <p>O PBQP-H (Programa Brasileiro da Qualidade e Produtividade do Habitat) é um sistema de gestão da qualidade voltado para a construção civil. Ele organiza os processos da obra — do controle de materiais à qualificação da mão de obra — e comprova ao mercado que a empresa segue um padrão reconhecido.</p>
      <p>Costuma aparecer como requisito no cadastro da construtora junto à Caixa e em programas como o Apoio à Produção e o Minha Casa Minha Vida — exatamente porque é a forma mais objetiva de o banco verificar a capacidade de gestão da empresa antes de liberar o crédito.</p>
    </div>
    <div class="container xl">
      <ul class="check-list fc-pbqp-list">
        <li class="check-item"><span class="check-circle"><iconify-icon icon="solar:check-read-linear"></iconify-icon></span>Ajuda a comprovar capacidade técnica e de gestão na análise de risco da Caixa</li>
        <li class="check-item"><span class="check-circle"><iconify-icon icon="solar:check-read-linear"></iconify-icon></span>Reduz desperdício, retrabalho e custos dentro do canteiro de obras</li>
        <li class="check-item"><span class="check-circle"><iconify-icon icon="solar:check-read-linear"></iconify-icon></span>Abre portas para participação em licitações públicas</li>
        <li class="check-item"><span class="check-circle"><iconify-icon icon="solar:check-read-linear"></iconify-icon></span>Organiza processos e qualifica a mão de obra da construtora</li>
      </ul>
      <div class="fc-intro-cta"><a href="#diagnostico" class="btn btn--outline">Quero saber se minha construtora está apta <iconify-icon icon="solar:arrow-right-linear"></iconify-icon></a></div>
    </div>
  </section>

  <!-- PAPEL DA TEMPLUM -->
  <section class="section section--navy">
    <div class="container xl">
      <div class="section-header">
        <span class="tag-pill tag-pill--glow">Onde a Templum atua</span>
        <h2>Preparamos sua construtora para <em class="accent">chegar pronta</em> na Caixa</h2>
        <p>Não financiamos a sua obra — preparamos a sua empresa para ser aprovada por quem financia.</p>
      </div>
      <div class="step-grid fc-templum-grid">
        {templumSteps.map((p, i) => (
          <div class="step-card reveal"><span class="step-num">{String(i + 1).padStart(2, "0")}</span><h3>{p.t}</h3><p>{p.d}</p></div>
        ))}
      </div>
    </div>
  </section>

  <!-- ESPECIALISTAS -->
  <Especialistas sub="Consultores que conhecem o mercado da construção civil e o processo de qualificação junto à Caixa — de perto." />

  <!-- CASES -->
  <section class="section section--cream">
    <div class="container md fc-case">
      <span class="tag-pill">Case de sucesso</span>
      <h2>Construtora Carvalho Forte: <em class="accent">crescimento na obra</em></h2>
      <a class="fc-case-video" href="https://vimeo.com/103908164" data-vimeo="103908164">
        <img src="https://vumbnail.com/103908164.jpg" alt="Depoimento da Construtora Carvalho Forte" loading="lazy" />
        <span class="fc-case-play"><iconify-icon icon="solar:play-bold"></iconify-icon></span>
        <span class="fc-case-tag">PBQP-H</span>
      </a>
      <p class="fc-case-cap">Assista ao depoimento sobre como a certificação PBQP-H impulsionou o crescimento da obra.</p>
    </div>

    <!-- lightbox -->
    <div class="fc-case-lb" data-case-lightbox hidden>
      <button class="fc-case-lb-close" data-case-lb-close aria-label="Fechar"><iconify-icon icon="solar:close-circle-linear"></iconify-icon></button>
      <div class="fc-case-lb-frame" data-case-lb-frame></div>
    </div>
  </section>

  <Testimonials nota="4,9" ctaTexto="Quero saber se minha construtora está apta" ctaHref="#diagnostico" />
  <DepoimentosTexto />
  <ClientLogos dark={true} titulo="Construtoras que crescem com a Templum" />

  <!-- PROVA SOCIAL -->
  <section class="section section--cream">
    <div class="container xl">
      <div class="section-header"><span class="tag-pill">Números que sustentam a experiência</span><h2>Não é a primeira vez que <em class="accent">fazemos isso</em></h2></div>
      <div class="numbers-grid fc-stats">
        <div class="number-card reveal"><div class="value"><em>+500</em></div><div class="label">construtoras atendidas</div></div>
        <div class="number-card reveal"><div class="value"><em>+2.000</em></div><div class="label">empresas atendidas pela Templum</div></div>
        <div class="number-card reveal"><div class="value"><em>+30</em></div><div class="label">anos de experiência</div></div>
        <div class="number-card reveal"><div class="value"><em>200%</em></div><div class="label">de garantia registrada em contrato</div></div>
      </div>
    </div>
  </section>

  <!-- DIFERENCIAIS -->
  <section class="section section--navy">
    <div class="container lg">
      <div class="section-header"><span class="tag-pill tag-pill--glow">A diferença de chegar preparada</span><h2>Sem preparação <em class="accent">vs.</em> Com a Templum</h2></div>
      <div class="fc-vs">
        <div class="fc-vs-col fc-vs-bad">
          <h3><iconify-icon icon="solar:close-circle-bold"></iconify-icon> Sem preparação</h3>
          <ul>{semTemplum.map((s) => <li><iconify-icon icon="solar:close-circle-linear"></iconify-icon>{s}</li>)}</ul>
        </div>
        <div class="fc-vs-col fc-vs-good">
          <h3><iconify-icon icon="solar:check-circle-bold"></iconify-icon> Com apoio da Templum</h3>
          <ul>{comTemplum.map((s) => <li><iconify-icon icon="solar:check-circle-linear"></iconify-icon>{s}</li>)}</ul>
        </div>
      </div>
    </div>
  </section>

  <!-- DIAGNÓSTICO / FORMULÁRIO -->
  <section id="diagnostico" class="fc-form section--navy">
    <div class="container lg fc-form-grid">
      <div class="fc-form-pitch">
        <span class="tag-pill tag-pill--glow">Comece agora</span>
        <h2>Descubra se a sua construtora está <em class="accent">apta</em> para a Caixa</h2>
        <p>Um especialista da Templum analisa o cenário da sua empresa — PBQP-H, tempo de mercado, histórico com a Caixa — e mostra exatamente o que falta para chegar pronta na análise de crédito.</p>
        <ul class="check-list">
          <li class="check-item"><span class="check-circle"><iconify-icon icon="solar:check-read-linear"></iconify-icon></span> Diagnóstico gratuito e sem compromisso</li>
          <li class="check-item"><span class="check-circle"><iconify-icon icon="solar:check-read-linear"></iconify-icon></span> Plano de ação sob medida para o seu momento</li>
          <li class="check-item"><span class="check-circle"><iconify-icon icon="solar:check-read-linear"></iconify-icon></span> Preparação completa: GERIC, PBQP-H e documentação</li>
        </ul>
      </div>
      <LeadForm norma="Financiamento Caixa" titulo="Fale com um especialista" sub="Resposta em até 1 dia útil. Sem compromisso." cta="Quero meu diagnóstico gratuito" obrigado="/lp/financiamento-caixa-obrigado" simples={true} faturamento={true} labelEmpresa="Nome da Construtora" cargo={true} />
    </div>
