  .fc-case-lb[hidden] { display: none; }
  .fc-case-lb-frame { position: relative; width: min(960px, 94vw); aspect-ratio: 16/9; border-radius: var(--r-16); overflow: hidden; box-shadow: var(--shadow-lift); background: #000; }
  .fc-case-lb-frame :global(iframe) { position: absolute; inset: 0; width: 100%; height: 100%; border: 0; }
