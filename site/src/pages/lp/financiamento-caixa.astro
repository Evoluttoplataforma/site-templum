  .fc-case-play { position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); width: 64px; height: 64px; border-radius: 999px; background: rgba(255,255,255,0.92); color: var(--navy); display: grid; place-items: center; font-size: 26px; z-index: 2; transition: background .3s, transform .3s; }
