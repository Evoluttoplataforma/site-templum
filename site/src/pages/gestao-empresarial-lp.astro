---
import LpBase from "../layouts/LpBase.astro";
import SeloImplementando from "../components/SeloImplementando.astro";
import Especialistas from "../components/Especialistas.astro";
import Testimonials from "../components/Testimonials.astro";
import DepoimentosTexto from "../components/DepoimentosTexto.astro";
import ClientLogos from "../components/ClientLogos.astro";
import LeadForm from "../components/LeadForm.astro";

// Dados específicos desta campanha — linguagem dor/qualidade, sem mencionar ISO
const d = {
  hero: {
    titulo: ["Sua empresa parou de crescer porque ", "tudo depende de você", "?"],
    sub: "Organizamos a gestão da sua empresa do diagnóstico à certificação — com método próprio e garantia de 200% em contrato.",
    garantia: "Ao concluir todas as etapas da nossa consultoria e ainda assim não obter o resultado acordado, devolvemos 200% do valor investido.",
    chips: ["30 anos de experiência", "Sem limite de horas", "Resultados comprovados"],
  },
  motivos: [
    { t: "Pare de ser o gargalo da sua empresa", d: "Quando os processos existem no papel e na prática, a equipe resolve. Menos decisões chegam até você — e o negócio cresce sem precisar que você esteja em tudo." },
    { t: "Reduza retrabalho e desperdício", d: "Processos padronizados eliminam erros repetidos, reduzem custos operacionais e liberam tempo do time para o que realmente importa: gerar resultado." },
    { t: "Abra portas para novos mercados e clientes", d: "Grandes clientes, empresas públicas e grupos internacionais exigem fornecedores com gestão comprovada. Uma empresa organizada e certificada vende mais e melhor." },
  ],
  beneficios: [
    "Equipe que resolve sem depender de você",
    "Processos documentados e replicáveis",
    "Menos retrabalho e desperdício de recursos",
    "Cultura de qualidade no dia a dia",
    "Acesso a clientes e mercados maiores",
    "Credibilidade comprovada para o mercado",
    "Gestão por indicadores, não por intuição",
    "Crescimento sustentável e escalável",
    "Garantia de 200% registrada em contrato",
    "Certificação reconhecida nacional e internacionalmente",
    "Atração e retenção de talentos",
    "Base sólida para franquia, expansão ou venda da empresa",
  ],
  passos: [
    { t: "Diagnóstico gratuito da sua operação", d: "Nosso especialista mapeia como sua empresa funciona hoje, onde estão os gargalos e qual é o caminho mais rápido para organizar a gestão." },
    { t: "Cronograma sob medida", d: "Calculamos o plano de implementação conforme o tamanho e ritmo da sua empresa — sem pressão, sem atalhos." },
    { t: "Documentos feitos por nós", d: "Nunca delegamos a você o que deve ser feito por nós. Elaboramos todos os documentos e procedimentos do jeito que funciona para o seu negócio." },
    { t: "Checkpoints e acompanhamento", d: "Você passa por checkpoints obrigatórios com o consultor para garantir que cada etapa está realmente implementada — não só no papel." },
    { t: "Especialistas sempre disponíveis", d: "Todos os dias, em horário comercial, você tira dúvidas com seu consultor em tempo real. Sem deixar travar." },
    { t: "Selo reconhecido pelo mercado", d: "Enquanto implementa, emitimos um selo e atestado para comprovar ao mercado que sua empresa já está em transformação." },
    { t: "Certificação e garantia em contrato", d: "Se passar por todas as etapas e ainda assim não certificar, devolvemos 200% do seu investimento. Sem letras miúdas." },
  ],
  porques: [
    { icon: "solar:medal-star-bold", t: "30 anos de experiência real", d: "Mais de 30 anos atuando exclusivamente com sistemas de gestão — em todos os setores e tamanhos de empresa." },
    { icon: "solar:shield-check-bold", t: "Garantia de 200% em contrato", d: "Devolvemos o dobro do investimento se sua empresa não atingir o resultado acordado. É a única garantia assim no Brasil." },
    { icon: "solar:hand-heart-bold", t: "Do diagnóstico à certificação", d: "Acompanhamos cada fase do processo — sem deixar você sozinho em nenhum momento." },
  ],
  stats: [
    { num: "+2.000", label: "empresas organizadas" },
    { num: "+1,5 mi", label: "de interações com especialistas" },
    { num: "R$ 3,3 bi", label: "em ganhos gerados aos clientes" },
    { num: "4,9", label: "de nota no Google" },
  ],
  cobertura: "De onde você estiver, a Templum chega. Mais de 8.000 contratos em todo o Brasil, Portugal e África — 100% online, sem deslocamento, sem custo extra.",
  paraQuem: [
    { icon: "solar:factory-bold", t: "Indústria e manufatura" },
    { icon: "solar:case-round-bold", t: "Serviços e consultorias" },
    { icon: "solar:cart-large-2-bold", t: "Comércio e distribuição" },
    { icon: "solar:buildings-2-bold", t: "Construção civil" },
    { icon: "solar:code-square-bold", t: "Tecnologia e software" },
    { icon: "solar:health-bold", t: "Saúde e laboratórios" },
  ],
  incluso: [
    "Consultor dedicado, sem limite de horas",
    "Plataforma Templum OS para organizar toda a gestão",
    "Todos os documentos elaborados por nós",
    "Suporte diário com especialistas em horário comercial",
    "Selo "Estamos Implementando" para exibir ao mercado",
    "Garantia de 200% registrada em contrato",
  ],
  detalhes: {
    titulo: "Perguntas sobre a consultoria de gestão",
    sub: "Tudo o que você precisa saber antes de começar a organizar sua empresa.",
    faq: [
      { q: "Minha empresa é pequena. Isso é para mim?", a: "Sim. Atendemos empresas de todos os tamanhos — desde negócios com 5 colaboradores até grandes indústrias. O método se adapta ao seu contexto." },
      { q: "Quanto tempo leva para ver resultado?", a: "Os primeiros impactos na operação aparecem ainda nas primeiras semanas de implementação. A certificação depende do escopo, mas nosso cronograma é calculado para ser o mais ágil possível." },
      { q: "Preciso parar a operação da empresa para implementar?", a: "Não. A consultoria é feita em paralelo com o dia a dia — sem interromper a produção ou o atendimento ao cliente." },
      { q: "Minha equipe vai precisar dedicar muito tempo?", a: "Fazemos o trabalho pesado por você. A equipe participa pontualmente para validar e aplicar o que desenvolvemos juntos." },
      { q: "Como funciona a garantia de 200%?", a: "Se sua empresa cumprir todas as etapas da consultoria e mesmo assim não atingir o resultado acordado, devolvemos o dobro do valor investido. Está em contrato." },
      { q: "O atendimento é presencial ou online?", a: "100% online — via plataforma própria, videoconferência e suporte em tempo real. Atendemos todo o Brasil, Portugal e África." },
      { q: "Quais setores vocês atendem?", a: "Todos. Industria, serviços, comércio, tecnologia, saúde, construção civil, alimentação, logística — qualquer empresa que queira organizar sua gestão e crescer com base sólida." },
      { q: "Vocês fazem a auditoria de certificação?", a: "A auditoria de certificação é realizada por um organismo certificador independente. Nós preparamos sua empresa para chegar 100% pronta — e acompanhamos o processo." },
    ],
  },
};

const c = "var(--orange)";
---

<LpBase
  title="Sua empresa ainda depende demais de você? | Templum"
  description="Organizamos a gestão da sua empresa do diagnóstico à certificação — com método próprio, 30 anos de experiência e garantia de 200% em contrato."
  formAnchor="#contato"
>
  <div class="cs-page" style={`--accent:${c}`}>

    <!-- HERO -->
    <section class="cs-hero">
      <div class="cs-hero-bg" aria-hidden="true"></div>
      <div class="container xl cs-hero-grid">
        <div class="cs-hero-text">
          <span class="tag-pill tag-pill--glow">Gestão Empresarial · Para donos de empresa</span>
          <h1 class="cs-title">{d.hero.titulo[0]}<span class="cs-hl">{d.hero.titulo[1]}</span>{d.hero.titulo[2]}</h1>
          <p class="cs-sub">{d.hero.sub}</p>
          <p class="cs-guarantee"><iconify-icon icon="solar:shield-check-bold"></iconify-icon> {d.hero.garantia}</p>
          <div class="cs-chips">{d.hero.chips.map((ch) => <span class="cs-chip"><iconify-icon icon="solar:check-circle-bold"></iconify-icon>{ch}</span>)}</div>
          <a href="#metodo" class="cs-ver-metodo">Ver o método <iconify-icon icon="solar:arrow-down-linear"></iconify-icon></a>
        </div>
        <div class="cs-hero-form">
          <LeadForm
            norma="Gestão Empresarial"
            titulo="Agende agora uma reunião"
            sub="Preencha o formulário e um especialista entrará em contato."
            cta="Falar com Especialista"
            obrigado="/gestao-empresarial-obrigado"
            simples={true}
          />
        </div>
      </div>
    </section>

    <!-- MOTIVOS + BENEFÍCIOS -->
    <section class="section section--cream">
      <div class="container xl">
        <div class="section-header">
          <span class="tag-pill">Por que organizar agora</span>
          <h2>Motivos para estruturar a gestão da sua <em class="accent">empresa</em></h2>
        </div>
        <div class="cs-motivos">
          {d.motivos.map((m, i) => (
            <div class="cs-motivo reveal">
              <span class="cs-motivo-n">{String(i + 1).padStart(2, "0")}</span>
              <h3>{m.t}</h3>
              <p>{m.d}</p>
            </div>
          ))}
        </div>
        <div class="cs-benef">
          <h3 class="cs-benef-h">Benefícios para a sua empresa</h3>
          <ul class="check-list cs-benef-list">
            {d.beneficios.map((b) => (
              <li class="check-item"><span class="check-circle"><iconify-icon icon="solar:check-read-linear"></iconify-icon></span>{b}</li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <!-- SELO -->
    <SeloImplementando />

    <!-- MÉTODO 7 PASSOS -->
    <section id="metodo" class="section section--cream">
      <div class="container xl">
        <div class="section-header">
          <span class="tag-pill">Como implementamos</span>
          <h2>7 passos até a sua empresa <em class="accent">funcionar sem depender de você</em></h2>
          <p>Facilitamos cada etapa para que o resultado seja real — não só no papel.</p>
        </div>
        <div class="step-grid">
          {d.passos.map((p, i) => (
            <div class="step-card reveal">
              <span class="step-num">{String(i + 1).padStart(2, "0")}</span>
              <h3>{p.t}</h3>
              <p>{p.d}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- POR QUE TEMPLUM -->
    <section class="section section--navy">
      <div class="container lg">
        <div class="section-header">
          <span class="tag-pill tag-pill--glow">Por que a Templum</span>
          <h2>Segurança, experiência e <em class="accent">garantia em contrato</em></h2>
        </div>
        <div class="why-grid">
          {d.porques.map((p) => (
            <div class="why-card reveal">
              <span class="why-ico"><iconify-icon icon={p.icon}></iconify-icon></span>
              <h3>{p.t}</h3>
              <p>{p.d}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- GARANTIA 200% -->
    <section class="section">
      <div class="container xl">
        <div class="split">
          <div class="split-text">
            <span class="tag-pill">Garantia de 200%</span>
            <h2 class="h1">Resultado garantido ou o <em class="accent">dobro</em> do dinheiro de volta</h2>
            <p class="paragraph">Somos a única consultoria no Brasil que devolve o dobro do investimento se você não obtiver o resultado acordado seguindo o nosso método.</p>
            <a href="#contato" class="btn btn--primary btn--lg">Quero a garantia de 200% <iconify-icon icon="solar:arrow-right-linear"></iconify-icon></a>
          </div>
          <div class="split-img reveal">
            <img src="/assets/img/garantia-200.webp" alt="Selo de garantia de 200% da Templum" width="640" height="658" loading="lazy" decoding="async" />
          </div>
        </div>
      </div>
    </section>

    <!-- STATS -->
    <section class="section section--cream">
      <div class="container xl">
        <div class="section-header">
          <span class="tag-pill">Empresas fortalecidas pela Templum</span>
          <h2>Resultados que <em class="accent">comprovam</em></h2>
        </div>
        <div class="numbers-grid cs-stats">
          {d.stats.map((s) => (
            <div class="number-card reveal">
              <div class="value"><em>{s.num}</em></div>
              <div class="label">{s.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- COBERTURA + MAPA -->
    <section class="cs-cover section--navy">
      <div class="cs-cover-bg" aria-hidden="true"></div>
      <div class="container md">
        <span class="cs-cover-ico"><iconify-icon icon="solar:map-point-wave-bold"></iconify-icon></span>
        <h2>De onde você estiver, <em class="accent">a Templum chega.</em></h2>
        <p>{d.cobertura}</p>
        <img class="cs-cover-map" src="/assets/img/mapa-cobertura.avif" alt="Mapa de atendimento da Templum — Brasil, Portugal e África" loading="lazy" />
      </div>
    </section>

    <!-- DEPOIMENTOS EM VÍDEO -->
    <Testimonials nota="4,9" ctaTexto="Quero organizar minha empresa" ctaHref="#contato" />

    <!-- DEPOIMENTOS EM TEXTO -->
    <DepoimentosTexto />

    <!-- LOGOS DE CLIENTES -->
    <ClientLogos dark={true} titulo="Empresas que transformaram sua gestão com a Templum" />

    <!-- PARA QUEM SERVE + O QUE ESTÁ INCLUSO -->
    <section class="section section--cream">
      <div class="container xl cs-pqi">
        <div class="cs-pq">
          <span class="tag-pill">Para quem serve</span>
          <h2 class="h2">Para empresas de <em class="accent">qualquer setor</em></h2>
          <p class="reg-l" style="margin:10px 0 22px">{d.detalhes.sub}</p>
          <div class="cs-pq-grid">
            {d.paraQuem.map((s) => (
              <div class="cs-pq-item"><iconify-icon icon={s.icon}></iconify-icon>{s.t}</div>
            ))}
          </div>
        </div>
        <div class="cs-incluso">
          <span class="tag-pill">O que está incluso</span>
          <ul class="check-list" style="margin-top:18px">
            {d.incluso.map((i) => (
              <li class="check-item"><span class="check-circle"><iconify-icon icon="solar:check-read-linear"></iconify-icon></span>{i}</li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <!-- ESPECIALISTAS -->
    <Especialistas />

    <!-- FAQ -->
    <section class="section section--cream">
      <div class="container md">
        <div class="section-header">
          <span class="tag-pill">Tire suas dúvidas</span>
          <h2>{d.detalhes.titulo}</h2>
          <p>{d.detalhes.sub}</p>
        </div>
        <div class="faq-list">
          {d.detalhes.faq.map((f) => (
            <details class="faq-item">
              <summary class="faq-question">{f.q}<span class="faq-arrow">+</span></summary>
              <div class="faq-answer">{f.a}</div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- FORMULÁRIO -->
    <section id="contato" class="cs-form section--navy">
      <div class="container lg cs-form-grid">
        <div class="cs-form-pitch">
          <span class="tag-pill tag-pill--glow">Comece agora</span>
          <h2>Receba um <em class="accent">diagnóstico gratuito</em> da sua gestão empresarial</h2>
          <p>Um especialista analisa o cenário da sua empresa e mostra o caminho mais curto para você parar de ser o gargalo — sem compromisso.</p>
          <ul class="check-list">
            <li class="check-item"><span class="check-circle"><iconify-icon icon="solar:check-read-linear"></iconify-icon></span> Diagnóstico e cronograma sob medida</li>
            <li class="check-item"><span class="check-circle"><iconify-icon icon="solar:check-read-linear"></iconify-icon></span> Garantia de 200% em contrato</li>
            <li class="check-item"><span class="check-circle"><iconify-icon icon="solar:check-read-linear"></iconify-icon></span> Atendimento 100% online</li>
          </ul>
        </div>
        <LeadForm
          norma="Gestão Empresarial"
          titulo="Fale com um especialista"
          sub="Resposta em até 1 dia útil. Sem compromisso."
          cta="Falar com Especialista"
          obrigado="/gestao-empresarial-obrigado"
          simples={true}
        />
      </div>
    </section>

    <!-- CTA BAND -->
    <section class="cta-band">
      <div class="container md">
        <h2>Transforme sua empresa em um negócio que <em>funciona sem você no centro</em></h2>
        <p>Resultado garantido em contrato ou o dobro do seu investimento de volta.</p>
        <a href="#contato" class="btn btn--dark btn--lg">Falar com um especialista <iconify-icon icon="solar:arrow-right-linear"></iconify-icon></a>
      </div>
    </section>

  </div>
</LpBase>

<style>
  .cs-page { --accent-lt: color-mix(in srgb, var(--accent) 58%, #ffffff); }

  .cs-page .cs-cover,
  .cs-page .cs-form,
  .cs-page .section--navy { background: color-mix(in srgb, var(--accent) 22%, #0f1216); }
  .cs-page .cs-hero { background: linear-gradient(120deg, color-mix(in srgb, var(--accent) 42%, #0c0e12) 0%, color-mix(in srgb, var(--accent) 20%, #0c0e12) 48%, #0c0e12 100%); }

  .cs-page .section:not(.section--navy) .accent { color: var(--accent); font-style: italic; }
  .cs-page .section:not(.section--navy) .tag-pill { color: var(--accent); border-color: var(--accent); background: color-mix(in srgb, var(--accent) 12%, transparent); }
  .cs-page .section:not(.section--navy) .number-card .value em { color: var(--accent); }
  .cs-page .section:not(.section--navy) .step-card .step-num { background: color-mix(in srgb, var(--accent) 14%, transparent); color: var(--accent); }
  .cs-page .section:not(.section--navy) .check-circle { background: color-mix(in srgb, var(--accent) 14%, transparent); color: var(--accent); }
  .cs-page .section:not(.section--navy) .faq-question:hover { color: var(--accent); }
  .cs-page .section:not(.section--navy) .faq-item[open] .faq-question .faq-arrow { color: var(--accent); }
  .cs-page .section:not(.section--navy) .cs-pq-item iconify-icon { color: var(--accent); }

  .cs-hero { position: relative; background: var(--navy); color: var(--cream); overflow: hidden; padding: clamp(48px, 6vw, 80px) 0; }
  .cs-hero-bg { position: absolute; inset: 0; pointer-events: none; background: radial-gradient(720px 460px at 12% 0%, color-mix(in srgb, var(--accent) 30%, transparent), transparent 60%), radial-gradient(560px 380px at 100% 100%, color-mix(in srgb, var(--accent) 16%, transparent), transparent 60%); }
  .cs-hero-grid { position: relative; z-index: 1; display: grid; grid-template-columns: 1.05fr 0.95fr; gap: clamp(32px, 5vw, 64px); align-items: center; }
  .cs-hero-text { max-width: 600px; }
  .cs-hero .tag-pill { margin-bottom: 20px; }
  .cs-title { font-size: clamp(32px, 4.4vw, 54px); font-weight: 800; line-height: 1.07; letter-spacing: -0.03em; color: var(--cream); }
  .cs-hl { color: var(--accent-lt); }
  .cs-sub { font-size: 17px; color: rgba(255,244,221,0.82); margin-top: 18px; max-width: 520px; }
  .cs-guarantee { display: flex; align-items: flex-start; gap: 9px; margin-top: 14px; font-size: 13.5px; color: rgba(255,244,221,0.62); max-width: 520px; line-height: 1.5; }
  .cs-guarantee iconify-icon { color: var(--accent-lt); font-size: 19px; flex-shrink: 0; margin-top: 1px; }
  .cs-chips { display: flex; gap: 20px; flex-wrap: wrap; margin-top: 26px; padding-top: 22px; border-top: 1px solid rgba(255,244,221,0.14); }
  .cs-chip { display: inline-flex; align-items: center; gap: 8px; font-size: 13.5px; font-weight: 600; color: rgba(255,244,221,0.82); }
  .cs-chip iconify-icon { color: var(--accent-lt); font-size: 18px; }
  .cs-hero-form { align-self: start; }
  .cs-ver-metodo { display: inline-flex; align-items: center; gap: 7px; margin-top: 22px; font-size: 14px; font-weight: 600; color: rgba(255,244,221,0.55); text-decoration: none; transition: color .2s; }
  .cs-ver-metodo:hover { color: var(--accent-lt); }

  .cs-stats { grid-template-columns: repeat(4, 1fr); }
  @media (max-width: 980px) { .cs-stats { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) { .cs-stats { grid-template-columns: 1fr; } }

  .why-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
  .why-card { background: rgba(255,255,255,0.04); border: 1px solid rgba(255,244,221,0.12); border-radius: var(--r-20); padding: 30px 26px; }
  .why-ico { width: 56px; height: 56px; border-radius: var(--r-16); display: grid; place-items: center; font-size: 28px; color: var(--accent-lt); background: color-mix(in srgb, var(--accent) 20%, transparent); margin-bottom: 18px; }
  .why-card h3 { font-size: 19px; font-weight: 800; color: var(--cream); margin-bottom: 8px; }
  .why-card p { font-size: 14.5px; color: rgba(255,244,221,0.7); line-height: 1.6; }

  .cs-motivos { display: grid; grid-template-columns: repeat(3, 1fr); gap: 22px; margin-top: 12px; }
  @media (max-width: 880px) { .cs-motivos { grid-template-columns: 1fr; } }
  .cs-motivo { background: var(--surface); border: 1px solid var(--border); border-radius: var(--r-20); padding: 30px 28px; }
  .cs-motivo-n { display: inline-grid; place-items: center; width: 44px; height: 44px; border-radius: 50%; font-size: 18px; font-weight: 800; color: var(--accent); background: color-mix(in srgb, var(--accent) 12%, transparent); margin-bottom: 16px; }
  .cs-motivo h3 { font-size: 18px; font-weight: 800; letter-spacing: -0.01em; margin-bottom: 8px; }
  .cs-motivo p { font-size: 14.5px; color: var(--text-mid); line-height: 1.6; }
  .cs-benef { margin-top: 36px; background: var(--surface); border: 1px solid var(--border); border-radius: var(--r-24); padding: 32px clamp(24px,4vw,40px); }
  .cs-benef-h { font-size: 17px; font-weight: 800; margin-bottom: 18px; }
  .cs-benef-list { display: grid; grid-template-columns: repeat(2, 1fr); gap: 14px 32px; }
  @media (max-width: 700px) { .cs-benef-list { grid-template-columns: 1fr; } }

  .cs-cover { position: relative; padding: 80px 0; text-align: center; overflow: hidden; }
  .cs-cover-bg { position: absolute; inset: 0; pointer-events: none; background: radial-gradient(620px 400px at 50% 120%, color-mix(in srgb, var(--accent) 18%, transparent), transparent 60%); }
  .cs-cover .container { position: relative; z-index: 1; }
