---
import Base from "../layouts/Base.astro";
import PageHero from "../components/PageHero.astro";
import OrbitPlatform from "../components/OrbitPlatform.astro";

const beneficios = [
  { icon: "solar:bolt-circle-bold", t: "Decisões mais rápidas", d: "A Olívia cruza dados de toda a operação e entrega insights acionáveis em tempo real." },
  { icon: "solar:checklist-minimalistic-bold", t: "Gestão sem planilhas", d: "Processos, responsáveis e prazos organizados em um só lugar, do diagnóstico à auditoria." },
  { icon: "solar:shield-check-bold", t: "Conformidade contínua", d: "Os agentes monitoram riscos, indicadores e não conformidades antes que virem problema." },
];
---

<Base
  title="Soluções de IA — Olívia e o Templum OS | Templum"
  description="Conheça a Olívia: 12 agentes de IA no Templum OS que organizam a gestão da sua empresa. Até 40% menos tempo de execução, 85% menos erros e 65% mais produtividade."
>
  <PageHero
    tag="Soluções de IA · Olívia"
    sub="A Olívia é o cérebro do Templum OS: 12 agentes de IA que trabalham juntos para mapear processos, treinar equipes, monitorar indicadores e antecipar riscos — acelerando o caminho até a certificação e além."
    image="/assets/img/olivia.webp"
    badge="Olívia · IA"
    icon="solar:cpu-bolt-bold"
    chips={["12 agentes de IA", "Até 40% menos tempo", "85% menos erros"]}
  >
    <Fragment slot="title">Inteligência artificial que <em class="accent">organiza a sua gestão</em></Fragment>
    <Fragment slot="cta">
      <a href="/form" class="btn btn--primary btn--lg">Quero conhecer a Olívia <iconify-icon icon="solar:arrow-right-linear"></iconify-icon></a>
      <a href="/metodologia" class="btn btn--onDark btn--lg">Ver o método</a>
    </Fragment>
  </PageHero>

  <section class="section section--cream">
    <div class="container">
      <div class="section-header">
        <span class="tag-pill">Por que IA na gestão</span>
        <h2>Tecnologia a serviço do <em class="accent">seu resultado</em></h2>
      </div>
      <div class="ia-grid">
        {beneficios.map((b) => (
          <div class="eco-card">
            <span class="ia-ico"><iconify-icon icon={b.icon}></iconify-icon></span>
            <h3>{b.t}</h3>
            <p>{b.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <OrbitPlatform />

  <section class="cta-band">
    <div class="container md">
      <h2>Pronto para <em>colocar a IA</em> a trabalhar pela sua empresa?</h2>
      <p>Fale com um especialista e veja a Olívia e o Templum OS na prática.</p>
      <a href="/form" class="btn btn--dark btn--lg">Agendar uma demonstração <iconify-icon icon="solar:arrow-right-linear"></iconify-icon></a>
    </div>
  </section>
</Base>

<style>
  .ia-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 22px; margin-top: 44px; }
  @media (max-width: 880px) { .ia-grid { grid-template-columns: 1fr; } }
  .ia-ico { width: 52px; height: 52px; border-radius: 14px; display: grid; place-items: center; font-size: 26px; color: var(--orange); background: rgba(255,89,37,0.10); margin-bottom: 16px; }
</style>
