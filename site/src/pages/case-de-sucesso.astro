---
import Base from "../layouts/Base.astro";
import PageHero from "../components/PageHero.astro";
import Testimonials from "../components/Testimonials.astro";
import DepoimentosTexto from "../components/DepoimentosTexto.astro";
import ClientLogos from "../components/ClientLogos.astro";

const numeros = [
  { value: "+2.000", label: "clientes certificados", icon: "solar:medal-star-bold" },
  { value: "+8.000", label: "empresas fortalecidas", icon: "solar:buildings-3-bold" },
  { value: "R$ 3,3 bi", label: "em ganhos gerados aos clientes", icon: "solar:dollar-minimalistic-bold" },
  { value: "4,9", label: "de nota no Google", icon: "solar:star-bold" },
];
---

<Base
  title="Cases de sucesso — Empresas que certificaram com a Templum"
  description="Conheça histórias reais de empresas que organizaram a gestão e conquistaram a certificação com a Templum. Depoimentos em vídeo e resultados comprovados."
>
  <PageHero
    tag="Cases de sucesso"
    sub="Empresas de todos os portes e setores organizaram seus processos e conquistaram a certificação com o método Templum. Veja quem já viveu essa jornada."
    image="/assets/img/paginas/case-de-sucesso-hero.webp"
    badge="Cases de sucesso"
    icon="solar:cup-star-bold"
    chips={["+2.000 certificados", "4,9 de nota no Google", "Garantia de 200%"]}
  >
    <Fragment slot="title">Histórias reais de quem <em class="accent">transformou a gestão</em></Fragment>
    <Fragment slot="cta">
      <a href="/form" class="btn btn--primary btn--lg">Quero ser o próximo case <iconify-icon icon="solar:arrow-right-linear"></iconify-icon></a>
      <a href="/consultoria" class="btn btn--onDark btn--lg">Ver normas</a>
    </Fragment>
  </PageHero>

  <section class="section section--cream cs-nums-sec">
    <div class="container">
      <div class="cs-nums">
        {numeros.map((n) => (
          <div class="number-card">
            <span class="number-ico"><iconify-icon icon={n.icon}></iconify-icon></span>
            <div class="value">{n.value}</div>
            <div class="label">{n.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Testimonials nota="4,9" />

  <DepoimentosTexto />

  <ClientLogos titulo="Mais de 2.000 empresas já confiam na Templum" />

  <section class="cta-band">
    <div class="container md">
      <h2>Sua empresa pode ser <em>o próximo case</em></h2>
      <p>Fale com um especialista e descubra o caminho mais curto até a sua certificação — com garantia de 200% em contrato.</p>
      <a href="/form" class="btn btn--dark btn--lg">Falar com um especialista <iconify-icon icon="solar:arrow-right-linear"></iconify-icon></a>
    </div>
  </section>
</Base>

<style>
  .cs-nums-sec { padding-top: 56px; padding-bottom: 56px; }
  .cs-nums { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; }
  @media (max-width: 880px) { .cs-nums { grid-template-columns: repeat(2, 1fr); } }
</style>
