---
import Base from "../layouts/Base.astro";
---

<Base
  title="Vaga confirmada — Webserie ISO 9001:2026 | Templum"
  description="Sua inscrição na Webserie ISO 9001:2026 + IA está confirmada. Entre no grupo do WhatsApp para receber o link de acesso e todos os avisos."
  hideWpp={true}
  noindex={true}
  noHeaderFooter={true}
>

  <!-- ── HERO CONFIRMAÇÃO ── -->
  <section class="ob-hero">
    <div class="ob-hero-glow"></div>
    <div class="container sm ob-hero-inner">
      <div class="ob-check">
        <iconify-icon icon="solar:check-circle-bold"></iconify-icon>
      </div>
      <span class="ob-badge">Inscrição confirmada</span>
      <h1>Vaga garantida!<br /><em>Agora entre no grupo.</em></h1>
      <p class="ob-lead">Toda comunicação — link de acesso, avisos e materiais — acontece <strong>pelo grupo do WhatsApp</strong>. Entre agora para não perder nada.</p>

      <a
        href="https://chat.whatsapp.com/CdQVRjKLyeuAYBGa5hrOKn"
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn--wpp btn--lg"
      >
        <iconify-icon icon="mdi:whatsapp"></iconify-icon>
        Entrar no grupo do WhatsApp
      </a>
      <p class="ob-wpp-hint">Grupo exclusivo · gratuito · saia quando quiser</p>
    </div>
  </section>

  <!-- Conversão: dispara Lead (Meta Pixel + Google Ads + CAPI) -->
  <script is:inline>
    (function () {
      var raw = null;
      try { raw = sessionStorage.getItem("tpl_lead_pending"); } catch (_) {}
      if (!raw) return;
      try { sessionStorage.removeItem("tpl_lead_pending"); } catch (_) {}
      var d = {}; try { d = JSON.parse(raw) || {}; } catch (_) {}
      var SECOND_PIXEL = "4177249519256900";
      var done = false;
      function fire() {
        if (done) return; done = true;
        try { if (window.trk && typeof window.trk.lead === "function") window.trk.lead({ email: d.email, phone: d.phone, name: d.name }); } catch (_) {}
        try { if (window.fbq) window.fbq("trackSingle", SECOND_PIXEL, "Lead"); } catch (_) {}
      }
      var n = 0, t = setInterval(function () {
        n++;
        var ready = window.trk && typeof window.trk.lead === "function";
        if (ready || n > 60) { clearInterval(t); fire(); }
      }, 100);
    })();
  </script>

</Base>

<style>
  /* ── HERO ── */
  .ob-hero {
    background: var(--navy);
    position: relative;
    overflow: hidden;
    padding: clamp(72px, 10vw, 110px) 0;
    text-align: center;
  }
  .ob-hero-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at center, rgba(255,89,37,0.12) 0%, transparent 65%);
    pointer-events: none;
  }
  .ob-hero-inner {
    position: relative;
    z-index: 1;
  }
  .ob-check {
    font-size: 64px;
    color: #22c55e;
    margin-bottom: 20px;
    display: flex;
    justify-content: center;
  }
  .ob-badge {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: #22c55e;
    background: rgba(34,197,94,0.12);
    border: 1px solid rgba(34,197,94,0.3);
    padding: 5px 14px;
    border-radius: 100px;
    margin-bottom: 24px;
  }
  .ob-hero h1 {
    font-size: clamp(28px, 4vw, 46px);
    font-weight: 800;
    color: var(--cream);
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin-bottom: 20px;
  }
  .ob-hero h1 em {
    font-style: normal;
    color: var(--orange);
  }
  .ob-lead {
    font-size: 17px;
    color: rgba(255,244,221,0.75);
    line-height: 1.7;
    max-width: 480px;
    margin: 0 auto 36px;
  }
  .ob-lead strong { color: var(--cream); }

  /* ── WHATSAPP ── */
  .ob-wpp-hint {
    font-size: 13px;
    color: rgba(255,244,221,0.4);
    margin-top: 14px;
    line-height: 1.5;
  }
  .btn--wpp {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: #25D366;
    color: #fff;
    font-weight: 800;
    padding: 18px 36px;
    border-radius: 50px;
    font-size: 16px;
    white-space: nowrap;
    transition: opacity .2s, transform .15s;
    box-shadow: 0 4px 24px rgba(37,211,102,0.35);
  }
  .btn--wpp:hover { opacity: 0.92; transform: translateY(-1px); }
  .btn--wpp iconify-icon { font-size: 22px; }
</style>
