---
import Base from "../layouts/Base.astro";
import SeloImplementando from "../components/SeloImplementando.astro";
import { baseConsultoria } from "../data/consultoria/_base.js";

const { passos, incluso } = baseConsultoria;
const fases = [
  { icon: "solar:magnifer-zoom-in-bold", t: "Diagnóstico", d: "Entendemos o cenário da sua empresa e desenhamos um cronograma sob medida." },
  { icon: "solar:document-add-bold", t: "Documentação", d: "Elaboramos todos os documentos por você, do jeito mais útil para o seu negócio." },
  { icon: "solar:routing-2-bold", t: "Implementação", d: "Você dita o ritmo, com checkpoints obrigatórios e suporte diário do consultor." },
  { icon: "solar:verified-check-bold", t: "Auditoria", d: "Preparamos sua empresa e acompanhamos até a auditoria da certificadora." },
];
---

<Base
  title="Metodologia Templum — Método próprio para certificar com garantia"
  description="Conheça o método próprio da Templum: 7 passos do diagnóstico à auditoria, com documentos feitos por nós, plataforma de gestão Orbit, suporte diário e garantia de 200% em contrato."
>
  <!-- HERO -->
  <section class="section section--navy mt-hero">
    <div class="mt-hero-bg" aria-hidden="true"></div>
    <div class="container mt-hero-inner">
      <span class="tag-pill tag-pill--glow">Método próprio · +30 anos</span>
      <h1>Um método à prova de falhas até a sua <em class="accent">certificação</em></h1>
      <p>Refinado em mais de 30 anos e +2.000 certificações, nosso método organiza toda a jornada — do diagnóstico à auditoria — com documentos feitos por nós, ritmo definido por você e garantia de 200% em contrato.</p>
      <div class="mt-hero-cta">
        <a href="/form" class="btn btn--primary btn--lg">Receber diagnóstico gratuito <iconify-icon icon="solar:arrow-right-linear"></iconify-icon></a>
        <a href="/consultoria" class="btn btn--onDark btn--lg">Ver normas</a>
      </div>
    </div>
  </section>

  <!-- 4 FASES -->
  <section class="section section--cream">
    <div class="container">
      <div class="section-header">
        <span class="tag-pill">Visão geral</span>
        <h2>Quatro fases, <em class="accent">um caminho claro</em></h2>
        <p>Do primeiro diagnóstico ao certificado na mão, sem planilhas soltas e sem surpresas.</p>
      </div>
      <div class="mt-fases">
        {fases.map((f, i) => (
          <div class="mt-fase">
            <span class="mt-fase-num">{String(i + 1).padStart(2, "0")}</span>
            <span class="mt-fase-ico"><iconify-icon icon={f.icon}></iconify-icon></span>
            <h3>{f.t}</h3>
            <p>{f.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 7 PASSOS -->
  <section class="section">
    <div class="container xl">
      <div class="section-header">
        <span class="tag-pill">Como implementamos</span>
        <h2>Os 7 passos do <em class="accent">método Templum</em></h2>
        <p>Facilitamos a transmissão do conhecimento para a sua empresa certificar com segurança.</p>
      </div>
      <div class="step-grid">
        {passos.map((p, i) => (
          <div class="step-card reveal"><span class="step-num">{String(i + 1).padStart(2, "0")}</span><h3>{p.t}</h3><p>{p.d}</p></div>
        ))}
      </div>
    </div>
  </section>

  <!-- O QUE ESTÁ INCLUSO -->
  <section class="section section--navy">
    <div class="container lg">
      <div class="section-header">
        <span class="tag-pill tag-pill--glow">O que está incluso</span>
        <h2>Tudo o que você recebe <em class="accent">na consultoria</em></h2>
      </div>
      <ul class="check-list mt-incluso">
        {incluso.map((item) => (
          <li class="check-item"><span class="check-circle"><iconify-icon icon="solar:check-read-linear"></iconify-icon></span>{item}</li>
        ))}
      </ul>
    </div>
  </section>

  <!-- SELO -->
  <SeloImplementando dark={false} />

  <!-- CTA -->
  <section class="cta-band">
    <div class="container md">
      <h2>Pronto para começar com <em>o método certo</em>?</h2>
      <p>Fale com um especialista e receba um diagnóstico gratuito com o caminho mais curto até a sua certificação.</p>
      <a href="/form" class="btn btn--dark btn--lg">Quero meu diagnóstico gratuito <iconify-icon icon="solar:arrow-right-linear"></iconify-icon></a>
    </div>
  </section>
</Base>

<style>
  .mt-hero { position: relative; overflow: hidden; padding-top: clamp(72px, 12vh, 120px); padding-bottom: clamp(72px, 12vh, 120px); }
  .mt-hero-bg { position: absolute; inset: 0; pointer-events: none;
    background: radial-gradient(720px 440px at 82% -10%, rgba(255,89,37,0.20), transparent 60%),
                radial-gradient(560px 400px at 6% 110%, rgba(20,167,175,0.10), transparent 60%); }
  .mt-hero-inner { position: relative; z-index: 1; max-width: 760px; }
  .mt-hero .tag-pill { margin-bottom: 22px; }
  .mt-hero h1 { font-size: clamp(34px, 5vw, 56px); font-weight: 800; line-height: 1.06; letter-spacing: -0.03em; color: var(--cream); margin-bottom: 20px; }
  .mt-hero p { font-size: 17px; line-height: 1.65; color: rgba(255,244,221,0.82); max-width: 620px; margin-bottom: 30px; }
  .mt-hero-cta { display: flex; gap: 12px; flex-wrap: wrap; }

  .mt-fases { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-top: 44px; }
  @media (max-width: 880px) { .mt-fases { grid-template-columns: repeat(2, 1fr); } }
  .mt-fase { position: relative; background: var(--surface); border: 1px solid var(--border); border-radius: var(--r-20); padding: 30px 26px; }
  .mt-fase-num { position: absolute; top: 18px; right: 22px; font-size: 28px; font-weight: 800; color: var(--border-3); letter-spacing: -0.03em; }
  .mt-fase-ico { width: 50px; height: 50px; border-radius: 13px; display: grid; place-items: center; font-size: 25px; color: var(--orange); background: rgba(255,89,37,0.10); margin-bottom: 16px; }
  .mt-fase h3 { font-size: 18px; font-weight: 800; letter-spacing: -0.01em; margin-bottom: 8px; }
  .mt-fase p { font-size: 14px; color: var(--text-mid); line-height: 1.55; }

  .mt-incluso { max-width: 760px; margin: 40px auto 0; display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px 32px; }
  .mt-incluso .check-item { color: var(--cream); }
  @media (max-width: 700px) { .mt-incluso { grid-template-columns: 1fr; } }
</style>
