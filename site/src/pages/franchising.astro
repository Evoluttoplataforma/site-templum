---
import Base from "../layouts/Base.astro";
import PageHero from "../components/PageHero.astro";

// NOTA: copy provisória (não há página de franquias no site atual) — validar com o cliente.
const vantagens = [
  { icon: "solar:medal-star-bold", t: "Marca consolidada", d: "Mais de 30 anos de mercado e +2.000 empresas certificadas dão autoridade ao seu negócio desde o primeiro dia." },
  { icon: "solar:cpu-bolt-bold", t: "Método e plataforma", d: "Você opera com o método próprio da Templum e a plataforma de gestão que organiza toda a jornada do cliente." },
  { icon: "solar:square-academic-cap-bold", t: "Treinamento completo", d: "Capacitação inicial e contínua para você e seu time dominarem a operação e as normas." },
  { icon: "solar:hand-shake-bold", t: "Suporte permanente", d: "Apoio comercial, técnico e de marketing para acelerar seus resultados." },
];
---

<Base
  title="Franquias Templum — Empreenda com a maior consultoria de certificação"
  description="Seja um franqueado Templum: marca consolidada em +30 anos, método próprio, plataforma de gestão, treinamento e suporte completo. Empreenda em um mercado em crescimento."
>
  <PageHero
    tag="Franquias Templum"
    sub="Leve a maior consultoria de certificação do Brasil para a sua região. Com método próprio, plataforma de gestão e suporte completo, você empreende em um mercado essencial e em crescimento."
    image="/assets/img/hero/templum-consultoria-industria.webp"
    badge="Franquias Templum"
    icon="solar:shop-2-bold"
    chips={["+30 anos de marca", "Método e plataforma", "Suporte completo"]}
  >
    <Fragment slot="title">Empreenda com uma marca que <em class="accent">já provou resultado</em></Fragment>
    <Fragment slot="cta">
      <a href="/form" class="btn btn--primary btn--lg">Quero ser franqueado <iconify-icon icon="solar:arrow-right-linear"></iconify-icon></a>
      <a href="/quem-somos/sobre" class="btn btn--onDark btn--lg">Conhecer a Templum</a>
    </Fragment>
  </PageHero>

  <section class="section section--cream">
    <div class="container">
      <div class="section-header">
        <span class="tag-pill">Por que franquear</span>
        <h2>Você não <em class="accent">começa do zero</em></h2>
      </div>
      <div class="fr-grid">
        {vantagens.map((v) => (
          <div class="eco-card">
            <span class="fr-ico"><iconify-icon icon={v.icon}></iconify-icon></span>
            <h3>{v.t}</h3>
            <p>{v.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="cta-band">
    <div class="container md">
      <h2>Pronto para <em>empreender com a Templum</em>?</h2>
      <p>Deixe seus dados e nosso time de expansão entrará em contato para apresentar o modelo de franquia.</p>
      <a href="/form" class="btn btn--dark btn--lg">Falar com o time de expansão <iconify-icon icon="solar:arrow-right-linear"></iconify-icon></a>
    </div>
  </section>
</Base>

<style>
  .fr-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 22px; margin-top: 44px; }
  @media (max-width: 760px) { .fr-grid { grid-template-columns: 1fr; } }
  .fr-ico { width: 52px; height: 52px; border-radius: 14px; display: grid; place-items: center; font-size: 26px; color: var(--orange); background: rgba(255,89,37,0.10); margin-bottom: 16px; }
</style>
