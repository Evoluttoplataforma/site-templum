---
// Página interna — noindex, sem layout principal
---
<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Leads · Templum</title>
  <link rel="icon" type="image/png" href="/favicon.png" />
  <link rel="preload" as="font" type="font/woff2" href="/fonts/montserrat-500.woff2" crossorigin />
  <link rel="preload" as="font" type="font/woff2" href="/fonts/montserrat-800.woff2" crossorigin />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    @font-face { font-family: Montserrat; src: url(/fonts/montserrat-500.woff2) format('woff2'); font-weight: 500; font-display: swap; }
    @font-face { font-family: Montserrat; src: url(/fonts/montserrat-800.woff2) format('woff2'); font-weight: 800; font-display: swap; }

    :root {
      --orange: #FF5925;
      --navy:   #222831;
      --bg:     #f4f6fa;
      --surface: #ffffff;
      --surface2: #f9fafb;
      --border: #e5e9f0;
      --text:   #222831;
      --text-mid: #6b7280;
      --text-dim: #9ca3af;
    }

    html, body {
      min-height: 100vh;
      background: var(--bg);
      font-family: Montserrat, system-ui, sans-serif;
      font-weight: 500;
      color: var(--text);
    }

    /* ── LOGIN ── */
    #login {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 24px;
      background: var(--bg);
    }
    .login-box {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 40px 36px;
      width: 100%;
      max-width: 380px;
      display: flex;
      flex-direction: column;
      gap: 20px;
      box-shadow: 0 4px 24px rgba(0,0,0,0.08);
    }
    .login-logo { font-size: 22px; font-weight: 800; color: var(--navy); letter-spacing: -0.02em; }
    .login-logo span { color: var(--orange); }
    .login-box h1 { font-size: 16px; font-weight: 800; color: var(--navy); }
    .login-box p { font-size: 13px; color: var(--text-mid); }
    .field { display: flex; flex-direction: column; gap: 6px; }
    .field label { font-size: 12px; font-weight: 800; color: var(--text-mid); text-transform: uppercase; letter-spacing: 1px; }
    .field input {
      background: var(--surface2);
      border: 1.5px solid var(--border);
      border-radius: 10px;
      padding: 12px 14px;
      font-size: 15px;
      font-family: inherit;
      color: var(--navy);
      outline: none;
      transition: border-color .2s;
    }
    .field input:focus { border-color: var(--orange); background: #fff; }
    .login-err { font-size: 13px; color: #dc2626; display: none; }
    .btn-login {
      background: var(--orange);
      color: #fff;
      font-family: inherit;
      font-weight: 800;
      font-size: 15px;
      border: none;
      border-radius: 10px;
      padding: 13px;
      cursor: pointer;
      transition: opacity .2s;
    }
    .btn-login:hover { opacity: 0.88; }

    /* ── APP ── */
    #app { display: none; flex-direction: column; min-height: 100vh; }

    /* Header */
    .app-header {
      background: var(--navy);
      border-bottom: 1px solid rgba(255,255,255,0.08);
      padding: 0 clamp(16px, 3vw, 32px);
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 60px;
      position: sticky;
      top: 0;
      z-index: 10;
    }
    .app-logo { font-size: 18px; font-weight: 800; color: #fff; letter-spacing: -0.02em; }
    .app-logo span { color: var(--orange); }
    .app-meta { font-size: 12px; color: rgba(255,255,255,0.5); }
    .btn-logout {
      background: rgba(255,255,255,0.08);
      border: 1px solid rgba(255,255,255,0.12);
      border-radius: 8px;
      padding: 7px 14px;
      font-size: 12px;
      font-weight: 800;
      color: rgba(255,255,255,0.6);
      cursor: pointer;
      font-family: inherit;
      transition: color .2s, background .2s;
    }
    .btn-logout:hover { color: #fff; background: rgba(255,255,255,0.14); }

    /* Filters */
    .filters {
      padding: 12px clamp(16px, 3vw, 32px);
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      align-items: center;
      border-bottom: 1px solid var(--border);
      background: var(--surface);
      box-shadow: 0 1px 4px rgba(0,0,0,0.05);
    }
    .filters input, .filters select {
      background: var(--surface2);
      border: 1.5px solid var(--border);
      border-radius: 8px;
      padding: 8px 12px;
      font-size: 13px;
      font-family: inherit;
      color: var(--navy);
      outline: none;
      transition: border-color .2s;
    }
    .filters input:focus, .filters select:focus { border-color: var(--orange); }
    .filters input { min-width: 220px; }
    .filters select { min-width: 150px; }
    #filter-search { min-width: 260px; }
    .filter-label { font-size: 11px; font-weight: 800; color: var(--text-dim); text-transform: uppercase; letter-spacing: 1px; white-space: nowrap; }
    .filters-count { margin-left: auto; font-size: 12px; color: var(--text-mid); white-space: nowrap; font-weight: 700; }
    .btn-refresh {
      background: rgba(255,89,37,0.08);
      border: 1.5px solid rgba(255,89,37,0.2);
      border-radius: 8px;
      padding: 8px 14px;
      font-size: 12px;
      font-weight: 800;
      color: var(--orange);
      cursor: pointer;
      font-family: inherit;
      transition: background .2s;
      white-space: nowrap;
    }
    .btn-refresh:hover { background: rgba(255,89,37,0.15); }

    /* Table */
    .table-wrap {
      flex: 1;
      overflow: auto;
      padding: 16px clamp(16px, 3vw, 32px) 32px;
    }
    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 13px;
      min-width: 1100px;
      background: var(--surface);
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 1px 8px rgba(0,0,0,0.06);
    }
    thead th {
      padding: 11px 14px;
      text-align: left;
      font-size: 11px;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.8px;
      color: var(--text-mid);
      background: var(--surface2);
      border-bottom: 1.5px solid var(--border);
      white-space: nowrap;
      cursor: pointer;
      user-select: none;
    }
    thead th:hover { color: var(--navy); }
    thead th.sort-asc::after  { content: " ↓"; color: var(--orange); }
    thead th.sort-desc::after { content: " ↑"; color: var(--orange); }
    tbody tr { border-bottom: 1px solid var(--border); transition: background .12s; }
    tbody tr:last-child { border-bottom: none; }
    tbody tr:hover { background: #fff8f5; }
    tbody td { padding: 11px 14px; color: var(--text); vertical-align: top; }
    tbody td:first-child { color: var(--text-mid); font-size: 11px; white-space: nowrap; }
    .td-name { font-weight: 800; color: var(--navy); }
    .td-email a { color: var(--orange); text-decoration: none; font-weight: 600; }
    .td-email a:hover { text-decoration: underline; }
    .td-tel a { color: var(--text); text-decoration: none; }
    .td-tel a:hover { color: var(--navy); }
    .td-norma .pill {
      display: inline-block;
      font-size: 11px; font-weight: 800;
      padding: 3px 10px; border-radius: 100px;
      background: rgba(255,89,37,0.1);
      color: var(--orange);
      white-space: nowrap;
    }
    .td-pagina { font-size: 11px; color: var(--text-mid); max-width: 160px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .td-utm { font-size: 11px; }
    .utm-block { display: flex; flex-direction: column; gap: 3px; }
    .utm-row { display: flex; gap: 6px; align-items: baseline; white-space: nowrap; }
    .utm-key { font-size: 10px; font-weight: 800; color: var(--text-dim); text-transform: uppercase; letter-spacing: .5px; min-width: 28px; }
    .utm-val { font-size: 11px; color: var(--navy); font-weight: 600; overflow: hidden; text-overflow: ellipsis; max-width: 160px; }
    .td-msg { max-width: 200px; font-size: 12px; color: var(--text-mid); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

    /* Ações */
    .td-actions { white-space: nowrap; }
    .btn-delete {
      background: rgba(220,38,38,0.08);
      border: 1.5px solid rgba(220,38,38,0.25);
      border-radius: 8px;
      padding: 6px 12px;
      font-size: 12px;
      font-weight: 800;
      color: #dc2626;
      cursor: pointer;
      font-family: inherit;
      white-space: nowrap;
      transition: background .15s;
    }
    .btn-delete:hover:not(:disabled) { background: rgba(220,38,38,0.16); }
    .btn-delete:disabled { opacity: .5; cursor: default; }

    /* Seleção em massa */
    .checkbox-cell { width: 36px; text-align: center; }
    .checkbox-cell input { width: 15px; height: 15px; accent-color: var(--orange); cursor: pointer; }
    .bulk-bar {
      display: none;
      align-items: center;
      gap: 12px;
      padding: 10px clamp(16px, 3vw, 32px);
      background: rgba(220,38,38,0.06);
      border-bottom: 1px solid rgba(220,38,38,0.15);
    }
    .bulk-bar.show { display: flex; }
    .bulk-count { font-size: 13px; font-weight: 800; color: var(--navy); }
    .btn-bulk-clear {
      background: transparent;
      border: none;
      font-family: inherit;
      font-size: 12px;
      font-weight: 700;
      color: var(--text-mid);
      cursor: pointer;
      text-decoration: underline;
    }
    .btn-bulk-clear:hover { color: var(--navy); }

    /* Pipedrive CRM */
    .crm-val { color: var(--navy); font-weight: 700; font-size: 12px; }
    .crm-val.status-open   { color: #1a56db; }
    .crm-val.status-won    { color: #059669; }
    .crm-val.status-lost   { color: #dc2626; }
    .crm-none { font-size: 11px; color: var(--text-dim); }
    .crm-loading { font-size: 11px; color: var(--text-dim); }

    /* Paginação */
    .pagination {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
      padding: 20px 0 8px;
      flex-wrap: wrap;
    }
    .pg-btn {
      min-width: 34px;
      height: 34px;
      padding: 0 10px;
      border: 1.5px solid var(--border);
      border-radius: 8px;
      background: var(--surface);
      font-family: inherit;
      font-size: 13px;
      font-weight: 700;
      color: var(--navy);
      cursor: pointer;
      transition: all .15s;
    }
    .pg-btn:hover:not(:disabled) { border-color: var(--orange); color: var(--orange); }
    .pg-btn.active { background: var(--orange); border-color: var(--orange); color: #fff; }
    .pg-btn:disabled { opacity: .35; cursor: default; }
    .pg-info { font-size: 12px; color: var(--text-mid); font-weight: 600; padding: 0 8px; }

    /* Empty / Loading states */
    .state {
      text-align: center;
      padding: 64px 24px;
      color: var(--text-mid);
      font-size: 14px;
      background: var(--surface);
      border-radius: 12px;
      margin-top: 16px;
      box-shadow: 0 1px 8px rgba(0,0,0,0.06);
    }
    .state strong { display: block; font-size: 18px; font-weight: 800; color: var(--navy); margin-bottom: 8px; }
    .spinner {
      display: inline-block;
      width: 24px; height: 24px;
      border: 3px solid rgba(255,89,37,0.15);
      border-top-color: var(--orange);
      border-radius: 50%;
      animation: spin .7s linear infinite;
      margin-bottom: 12px;
    }
    @keyframes spin { to { transform: rotate(360deg); } }
  </style>
</head>
<body>

<!-- ── LOGIN ── -->
<div id="login">
  <div class="login-box">
    <div class="login-logo">Templum<span>!</span></div>
    <div>
      <h1>Painel de Leads</h1>
      <p style="margin-top:4px">Acesso restrito à equipe interna.</p>
    </div>
    <div class="field">
      <label>Senha</label>
      <input type="password" id="pwd" placeholder="Digite a senha" autocomplete="current-password" />
    </div>
    <p class="login-err" id="login-err">Senha incorreta.</p>
    <button class="btn-login" id="btn-login">Entrar</button>
  </div>
</div>

<!-- ── APP ── -->
<div id="app">
  <header class="app-header">
    <div class="app-logo">Templum<span>!</span> <span style="font-size:13px;font-weight:500;color:var(--text-dim)">/ Leads</span></div>
    <div style="display:flex;align-items:center;gap:16px">
      <span class="app-meta" id="meta-total"></span>
      <button class="btn-logout" id="btn-logout">Sair</button>
    </div>
  </header>

  <div class="filters">
    <input type="search" id="filter-search" placeholder="🔍  Buscar nome, e-mail, empresa..." />
    <select id="filter-norma">
      <option value="">Todas as normas</option>
    </select>
    <select id="filter-source">
      <option value="">Todas as fontes</option>
    </select>
    <select id="filter-pagina">
      <option value="">Todas as páginas</option>
    </select>
    <input type="date" id="filter-de" title="De" />
    <input type="date" id="filter-ate" title="Até" />
    <button class="btn-refresh" id="btn-refresh">↻ Atualizar</button>
    <span class="filters-count" id="filters-count"></span>
  </div>

  <div class="bulk-bar" id="bulk-bar">
    <span class="bulk-count" id="bulk-count"></span>
    <button class="btn-delete" id="btn-bulk-delete">🗑️ Excluir selecionados</button>
    <button class="btn-bulk-clear" id="btn-bulk-clear">Limpar seleção</button>
  </div>

  <div class="table-wrap">
    <div id="table-state" class="state">
      <div class="spinner"></div><br>Carregando leads…
    </div>
    <table id="leads-table" style="display:none">
      <thead>
        <tr>
          <th class="checkbox-cell"><input type="checkbox" id="select-all" title="Selecionar todos desta página" /></th>
          <th data-col="created_at">Data</th>
          <th data-col="nome" class="td-name">Nome</th>
          <th data-col="email">E-mail</th>
          <th data-col="telefone">Telefone</th>
          <th data-col="empresa">Empresa</th>
          <th data-col="norma">Norma</th>
          <th data-col="pagina">Página</th>
          <th data-col="utm_source">Fonte</th>
          <th data-col="utm_medium">Meio</th>
          <th data-col="utm_campaign">Campanha</th>
          <th data-col="utm_content">Conteúdo</th>
          <th data-col="utm_term">Termo</th>
          <th>Status CRM</th>
          <th>Etapa CRM</th>
          <th>Motivo Arq.</th>
          <th>Ações</th>
        </tr>
      </thead>
      <tbody id="leads-body"></tbody>
    </table>
    <div class="pagination" id="pagination"></div>
  </div>
</div>

<script is:inline>
(function () {
  // ── Config ──
  var API = "/api/leads"; // Worker verifica a senha server-side

  // ── Session ──
  var SESSION_KEY = "tpl_leads_auth";
  var SESSION_PWD = "tpl_leads_pwd";
  function isAuth() { return sessionStorage.getItem(SESSION_KEY) === "1"; }
  function setAuth(pwd) { sessionStorage.setItem(SESSION_KEY, "1"); sessionStorage.setItem(SESSION_PWD, pwd); }
  function clearAuth() { sessionStorage.removeItem(SESSION_KEY); sessionStorage.removeItem(SESSION_PWD); }
  function savedPwd() { return sessionStorage.getItem(SESSION_PWD) || ""; }

  // ── Elements ──
  var loginEl = document.getElementById("login");
  var appEl = document.getElementById("app");
  var pwdEl = document.getElementById("pwd");
  var errEl = document.getElementById("login-err");
  var btnLogin = document.getElementById("btn-login");
  var btnLogout = document.getElementById("btn-logout");
  var btnRefresh = document.getElementById("btn-refresh");
  var metaTotal = document.getElementById("meta-total");
  var filtersCount = document.getElementById("filters-count");
  var tableEl = document.getElementById("leads-table");
  var stateEl = document.getElementById("table-state");
  var bodyEl = document.getElementById("leads-body");
  var selectAllEl = document.getElementById("select-all");
  var bulkBarEl = document.getElementById("bulk-bar");
  var bulkCountEl = document.getElementById("bulk-count");
  var btnBulkDelete = document.getElementById("btn-bulk-delete");
  var btnBulkClear = document.getElementById("btn-bulk-clear");

  // Filters
  var fSearch = document.getElementById("filter-search");
  var fNorma = document.getElementById("filter-norma");
  var fSource = document.getElementById("filter-source");
  var fPagina = document.getElementById("filter-pagina");
  var fDe = document.getElementById("filter-de");
  var fAte = document.getElementById("filter-ate");

  // ── Auth ──
  if (isAuth()) { showApp(); }

  btnLogin.addEventListener("click", async function() {
    btnLogin.disabled = true;
    btnLogin.textContent = "Verificando…";
    var pwd = pwdEl.value;
    try {
      var res = await fetch(API + "?token=" + encodeURIComponent(pwd) + "&limit=1");
      if (res.ok) {
        errEl.style.display = "none";
        setAuth(pwd);
        showApp();
      } else {
        errEl.style.display = "block";
      }
    } catch(_) { errEl.textContent = "Erro de conexão."; errEl.style.display = "block"; }
    btnLogin.disabled = false;
    btnLogin.textContent = "Entrar";
  });
  pwdEl.addEventListener("keydown", function(e) { if (e.key === "Enter") btnLogin.click(); });

  btnLogout.addEventListener("click", function() {
    clearAuth();
    allLeads = [];
    loginEl.style.display = "flex";
    appEl.style.display = "none";
    pwdEl.value = "";
  });

  btnRefresh.addEventListener("click", function() { loadLeads(); });

  function showApp() {
    loginEl.style.display = "none";
    appEl.style.display = "flex";
    loadLeads();
  }

  // ── Data ──
  var allLeads = [];
  var sortCol = "created_at";
  var sortDir = 1; // 1 = desc (mais novos primeiro — padrão)
  var selectedIds = new Set(); // seleção persiste entre páginas/filtros até "Limpar seleção"
  var lastPageData = [];

  async function loadLeads() {
    stateEl.innerHTML = '<div class="spinner"></div><br>Carregando leads…';
    stateEl.style.display = "block";
    tableEl.style.display = "none";
    selectedIds.clear();
    updateBulkBar();

    try {
      var res = await fetch(API + "?token=" + encodeURIComponent(savedPwd()));
      if (res.status === 401) {
        // Sessão inválida — força novo login
        clearAuth();
        appEl.style.display = "none";
        loginEl.style.display = "flex";
        errEl.textContent = "Sessão expirada. Entre novamente.";
        errEl.style.display = "block";
        return;
      }
      if (!res.ok) {
        var e = await res.json().catch(function(){ return {}; });
        throw new Error("HTTP " + res.status + (e.detail ? " — " + e.detail : ""));
      }
      var body = await res.json();
      allLeads = body.data || [];
      metaTotal.textContent = (body.total || allLeads.length) + " leads no total";
      buildFilters();
      fSource.value = "facebook"; // padrão: Meta (facebook + fb + ig)
      render();
    } catch(e) {
      stateEl.innerHTML = '<strong>Erro ao carregar</strong>' + e.message;
    }
  }

  // Normaliza fontes Meta: fb → facebook, ig → facebook
  var SOURCE_MAP = { fb: "facebook", ig: "facebook" };
  function normSource(s) { return SOURCE_MAP[s] || s; }

  function buildFilters() {
    // Normas
    var normas = [...new Set(allLeads.map(function(l){ return l.norma || ""; }).filter(Boolean))].sort();
    fNorma.innerHTML = '<option value="">Todas as normas</option>';
    normas.forEach(function(n) { fNorma.innerHTML += '<option value="' + esc(n) + '">' + esc(n) + '</option>'; });

    // Sources — normaliza fb/ig → facebook, ignora variáveis não resolvidas ({{...}})
    var sources = [...new Set(
      allLeads
        .map(function(l){ return normSource(l.utm_source || ""); })
        .filter(function(s){ return s && !s.startsWith("{{"); })
    )].sort();
    fSource.innerHTML = '<option value="">Todas as fontes</option>';
    sources.forEach(function(s) { fSource.innerHTML += '<option value="' + esc(s) + '">' + esc(s) + '</option>'; });

    // Páginas
    var paginas = [...new Set(allLeads.map(function(l){ return l.pagina || ""; }).filter(Boolean))].sort();
    fPagina.innerHTML = '<option value="">Todas as páginas</option>';
    paginas.forEach(function(p) { fPagina.innerHTML += '<option value="' + esc(p) + '">' + esc(p) + '</option>'; });
  }

  // Sort listeners
  document.querySelectorAll("thead th[data-col]").forEach(function(th) {
    th.addEventListener("click", function() {
      var col = th.getAttribute("data-col");
      if (sortCol === col) { sortDir *= -1; }
      else { sortCol = col; sortDir = -1; }
      document.querySelectorAll("thead th").forEach(function(t){ t.className = ""; });
      th.className = sortDir === 1 ? "sort-desc" : "sort-asc";
      render();
    });
  });
  // Indicador de ordenação aplicado na primeira renderização via render()

  var PAGE_SIZE = 25;
  var currentPage = 1;
  var lastFiltered = [];

  // Ao mudar filtro, volta pra página 1
  [fSearch, fNorma, fSource, fPagina, fDe, fAte].forEach(function(el) {
    el.addEventListener("input",  function() { currentPage = 1; render(); });
    el.addEventListener("change", function() { currentPage = 1; render(); });
  });

  function render() {
    var q = fSearch.value.toLowerCase().trim();
    var norma = fNorma.value;
    var source = fSource.value;
    var pagina = fPagina.value;
    var de = fDe.value ? new Date(fDe.value) : null;
    var ate = fAte.value ? new Date(fAte.value + "T23:59:59") : null;

    var filtered = allLeads.filter(function(l) {
      if (norma && (l.norma || "") !== norma) return false;
      if (source && normSource(l.utm_source || "") !== source) return false;
      if (pagina && (l.pagina || "") !== pagina) return false;
      if (de && new Date(l.created_at) < de) return false;
      if (ate && new Date(l.created_at) > ate) return false;
      if (q) {
        var hay = [(l.nome||""), (l.email||""), (l.empresa||""), (l.telefone||"")].join(" ").toLowerCase();
        if (!hay.includes(q)) return false;
      }
      return true;
    });

    filtered.sort(function(a, b) {
      var av = a[sortCol] || "", bv = b[sortCol] || "";
      if (av < bv) return sortDir; if (av > bv) return -sortDir; return 0;
    });

    lastFiltered = filtered;

    // Atualiza indicador visual do th ativo
    document.querySelectorAll("thead th").forEach(function(t){ t.className = ""; });
    var activeTh = document.querySelector('thead th[data-col="' + sortCol + '"]');
    if (activeTh) activeTh.className = sortDir === -1 ? "sort-desc" : "sort-asc";

    var totalPages = Math.max(1, Math.ceil(filtered.length / PAGE_SIZE));
    currentPage = Math.min(currentPage, totalPages);

    filtersCount.textContent = filtered.length + " resultado" + (filtered.length !== 1 ? "s" : "");

    if (filtered.length === 0) {
      stateEl.innerHTML = '<strong>Nenhum lead encontrado</strong>Tente ajustar os filtros.';
      stateEl.style.display = "block";
      tableEl.style.display = "none";
      document.getElementById("pagination").innerHTML = "";
      lastPageData = [];
      updateSelectAllState();
      return;
    }

    var pageData = filtered.slice((currentPage - 1) * PAGE_SIZE, currentPage * PAGE_SIZE);
    lastPageData = pageData;

    stateEl.style.display = "none";
    tableEl.style.display = "table";

    bodyEl.innerHTML = pageData.map(function(l) {
      var dt = l.created_at ? new Date(l.created_at) : null;
      var dtStr = dt ? dt.toLocaleDateString("pt-BR") + "<br><small>" + dt.toLocaleTimeString("pt-BR", {hour:"2-digit",minute:"2-digit"}) + "</small>" : "—";
      var emailAttr = l.email ? " data-email='" + esc(l.email) + "'" : "";
      var checked = selectedIds.has(String(l.id)) ? " checked" : "";
      return "<tr" + emailAttr + ">" +
        "<td class='checkbox-cell'><input type='checkbox' class='row-check' data-id='" + esc(l.id) + "'" + checked + "></td>" +
        "<td>" + dtStr + "</td>" +
        "<td class='td-name'>" + esc(l.nome || "—") + "</td>" +
        "<td class='td-email'>" + (l.email ? "<a href='mailto:" + esc(l.email) + "'>" + esc(l.email) + "</a>" : "—") + "</td>" +
        "<td class='td-tel'>" + (l.telefone ? "<a href='tel:" + esc(l.telefone) + "'>" + esc(l.telefone) + "</a>" : "—") + "</td>" +
        "<td>" + esc(l.empresa || "—") + "</td>" +
        "<td class='td-norma'>" + (l.norma ? "<span class='pill'>" + esc(l.norma) + "</span>" : "—") + "</td>" +
        "<td class='td-pagina' title='" + esc(l.pagina || "") + "'>" + esc(l.pagina || "—") + "</td>" +
        "<td class='td-utm'>" + esc(l.utm_source   || "—") + "</td>" +
        "<td class='td-utm'>" + esc(l.utm_medium   || "—") + "</td>" +
        "<td class='td-utm'>" + esc(l.utm_campaign || "—") + "</td>" +
        "<td class='td-utm'>" + esc(l.utm_content  || "—") + "</td>" +
        "<td class='td-utm'>" + esc(l.utm_term     || "—") + "</td>" +
        "<td class='td-crm-status'><span class='crm-loading'>…</span></td>" +
        "<td class='td-crm-stage'><span class='crm-loading'>…</span></td>" +
        "<td class='td-crm-motivo'><span class='crm-loading'>…</span></td>" +
        "<td class='td-actions'><button class='btn-delete' data-id='" + esc(l.id) + "' data-email='" + esc(l.email || "") + "' title='Excluir lead'>🗑️ Excluir</button></td>" +
        "</tr>";
    }).join("");

    renderPagination(currentPage, totalPages, filtered.length);
    updateSelectAllState();
    loadCrmForPage(pageData);
  }

  // ── Seleção em massa ──
  function updateBulkBar() {
    if (selectedIds.size > 0) {
      bulkBarEl.classList.add("show");
      bulkCountEl.textContent = selectedIds.size + " selecionado" + (selectedIds.size !== 1 ? "s" : "");
    } else {
      bulkBarEl.classList.remove("show");
    }
  }

  function updateSelectAllState() {
    if (!lastPageData.length) {
      selectAllEl.checked = false;
      selectAllEl.indeterminate = false;
      return;
    }
    var selectedOnPage = lastPageData.filter(function(l) { return selectedIds.has(String(l.id)); }).length;
    selectAllEl.checked = selectedOnPage === lastPageData.length;
    selectAllEl.indeterminate = selectedOnPage > 0 && selectedOnPage < lastPageData.length;
  }

  bodyEl.addEventListener("change", function(e) {
    var chk = e.target.closest(".row-check");
    if (!chk) return;
    var id = chk.getAttribute("data-id");
    if (chk.checked) selectedIds.add(id); else selectedIds.delete(id);
    updateSelectAllState();
    updateBulkBar();
  });

  selectAllEl.addEventListener("change", function() {
    lastPageData.forEach(function(l) {
      if (selectAllEl.checked) selectedIds.add(String(l.id)); else selectedIds.delete(String(l.id));
    });
    render();
    updateBulkBar();
  });

  btnBulkClear.addEventListener("click", function() {
    selectedIds.clear();
    render();
    updateBulkBar();
  });

  btnBulkDelete.addEventListener("click", async function() {
    var ids = Array.from(selectedIds);
    if (!ids.length) return;
    var msg = "Excluir definitivamente " + ids.length + " lead" + (ids.length !== 1 ? "s" : "") + "?\n\nIsso remove os registros do Supabase e não pode ser desfeito.";
    if (!window.confirm(msg)) return;

    btnBulkDelete.disabled = true;
    btnBulkDelete.textContent = "Excluindo…";
    try {
      var results = await Promise.all(ids.map(async function(id) {
        try {
          var res = await fetch(API + "?token=" + encodeURIComponent(savedPwd()) + "&id=" + encodeURIComponent(id), { method: "DELETE" });
          var data = await res.json().catch(function() { return {}; });
          return { id: id, ok: res.ok && data.ok };
        } catch (_) {
          return { id: id, ok: false };
        }
      }));

      var okIds = results.filter(function(r) { return r.ok; }).map(function(r) { return r.id; });
      var failCount = results.length - okIds.length;

      allLeads = allLeads.filter(function(l) { return okIds.indexOf(String(l.id)) === -1; });
      okIds.forEach(function(id) { selectedIds.delete(id); });
      metaTotal.textContent = allLeads.length + " leads no total";
      render();

      if (failCount > 0) alert(failCount + " lead(s) não puderam ser excluídos. Tente novamente.");
    } finally {
      btnBulkDelete.disabled = false;
      btnBulkDelete.textContent = "🗑️ Excluir selecionados";
      updateBulkBar();
    }
  });

  function renderPagination(page, total, count) {
    var pg = document.getElementById("pagination");
    if (total <= 1) { pg.innerHTML = ""; return; }
    var html = "";
    html += "<button class='pg-btn' " + (page <= 1 ? "disabled" : "") + " onclick='goPage(" + (page-1) + ")'>&#8592;</button>";

    // Janela de páginas
    var start = Math.max(1, page - 2);
    var end   = Math.min(total, page + 2);
    if (start > 1) html += "<button class='pg-btn' onclick='goPage(1)'>1</button>" + (start > 2 ? "<span class='pg-info'>…</span>" : "");
    for (var i = start; i <= end; i++) {
      html += "<button class='pg-btn" + (i === page ? " active" : "") + "' onclick='goPage(" + i + ")'>" + i + "</button>";
    }
    if (end < total) html += (end < total - 1 ? "<span class='pg-info'>…</span>" : "") + "<button class='pg-btn' onclick='goPage(" + total + ")'>" + total + "</button>";

    html += "<button class='pg-btn' " + (page >= total ? "disabled" : "") + " onclick='goPage(" + (page+1) + ")'>&#8594;</button>";
    html += "<span class='pg-info'>" + count + " registros</span>";
    pg.innerHTML = html;
  }

  window.goPage = function(p) {
    currentPage = p;
    render();
    document.getElementById("leads-table").scrollIntoView({ behavior: "smooth", block: "start" });
  };

  // ── Excluir lead (Supabase) ──
  bodyEl.addEventListener("click", function(e) {
    var btn = e.target.closest(".btn-delete");
    if (!btn) return;
    var id = btn.getAttribute("data-id");
    var email = btn.getAttribute("data-email");
    deleteLead(id, email, btn);
  });

  async function deleteLead(id, email, btn) {
    if (!id) return;
    var msg = "Excluir definitivamente o lead" + (email ? " de " + email : "") + "?\n\nIsso remove o registro do Supabase e não pode ser desfeito.";
    if (!window.confirm(msg)) return;

    if (btn) { btn.disabled = true; btn.textContent = "Excluindo…"; }
    try {
      var res = await fetch(API + "?token=" + encodeURIComponent(savedPwd()) + "&id=" + encodeURIComponent(id), {
        method: "DELETE",
      });
      var data = await res.json().catch(function() { return {}; });
      if (!res.ok || !data.ok) {
        alert("Erro ao excluir: " + (data.error || ("HTTP " + res.status)));
        if (btn) { btn.disabled = false; btn.textContent = "🗑️ Excluir"; }
        return;
      }
      allLeads = allLeads.filter(function(l) { return String(l.id) !== String(id); });
      selectedIds.delete(String(id));
      metaTotal.textContent = allLeads.length + " leads no total";
      render();
      updateBulkBar();
    } catch (e) {
      alert("Erro de conexão ao excluir.");
      if (btn) { btn.disabled = false; btn.textContent = "🗑️ Excluir"; }
    }
  }

  // ── Carrega dados CRM do Pipedrive para a página atual ──
  async function loadCrmForPage(pageData) {
    var emails = pageData.map(function(l) { return l.email; }).filter(Boolean);
    if (!emails.length) {
      pageData.forEach(function() { /* sem email, limpa loading */ });
      document.querySelectorAll(".td-crm-status, .td-crm-stage, .td-crm-motivo").forEach(function(td) {
        td.innerHTML = "<span class='crm-none'>—</span>";
      });
      return;
    }

    try {
      var res = await fetch("/api/pipedrive-batch", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ token: savedPwd(), emails: emails })
      });
      var data = await res.json();

      var statusClass = { "Em andamento": "status-open", "Ganho": "status-won", "Perdido": "status-lost" };

      // Atualiza linhas sem email
      document.querySelectorAll("tr:not([data-email])").forEach(function(tr) {
        var s = tr.querySelector(".td-crm-status");
        var e = tr.querySelector(".td-crm-stage");
        var m = tr.querySelector(".td-crm-motivo");
        if (s) s.innerHTML = "<span class='crm-none'>—</span>";
        if (e) e.innerHTML = "<span class='crm-none'>—</span>";
        if (m) m.innerHTML = "<span class='crm-none'>—</span>";
      });

      if (!data.ok) {
        document.querySelectorAll(".td-crm-status").forEach(function(td) { td.innerHTML = "<span class='crm-none'>erro</span>"; });
        document.querySelectorAll(".td-crm-stage, .td-crm-motivo").forEach(function(td) { td.innerHTML = "<span class='crm-none'>—</span>"; });
        return;
      }

      emails.forEach(function(email) {
        var row = document.querySelector("tr[data-email='" + email.replace(/'/g, "\\'") + "']");
        if (!row) return;
        var crm = (data.results || {})[email];
        var sCell = row.querySelector(".td-crm-status");
        var eCell = row.querySelector(".td-crm-stage");
        var mCell = row.querySelector(".td-crm-motivo");

        if (!crm || !crm.found || crm.no_deals) {
          if (sCell) sCell.innerHTML = "<span class='crm-none'>—</span>";
          if (eCell) eCell.innerHTML = "<span class='crm-none'>—</span>";
          if (mCell) mCell.innerHTML = "<span class='crm-none'>—</span>";
          return;
        }

        var cls = statusClass[crm.status] || "";
        if (sCell) sCell.innerHTML = "<span class='crm-val " + cls + "'>" + esc(crm.status || "—") + "</span>";
        if (eCell) eCell.innerHTML = "<span class='crm-val'>" + esc(crm.stage || "—") + "</span>";
        if (mCell) mCell.innerHTML = "<span class='crm-val'>" + esc(crm.lost_reason || "—") + "</span>";
      });
    } catch(_) {
      document.querySelectorAll(".td-crm-status, .td-crm-stage, .td-crm-motivo").forEach(function(td) {
        td.innerHTML = "<span class='crm-none'>—</span>";
      });
    }
  }

  function esc(s) {
    return String(s)
      .replace(/&/g,"&amp;")
      .replace(/</g,"&lt;")
      .replace(/>/g,"&gt;")
      .replace(/"/g,"&quot;");
  }
})();
</script>

</body>
</html>
