---
import Base from "../../layouts/Base.astro";
---

<Base
  title="Diagnóstico solicitado — LGPD | Templum"
  description="Recebemos sua solicitação. Um especialista em LGPD entrará em contato em breve."
  noindex={true}
  noHeaderFooter={true}
  hideWpp={true}
>

  <section class="ob9-hero">
    <div class="ob9-glow" aria-hidden="true"></div>
    <div class="ob9-inner">
      <div class="ob9-check">
        <iconify-icon icon="solar:check-circle-bold"></iconify-icon>
      </div>
      <span class="ob9-badge">LGPD · Diagnóstico solicitado</span>
      <h1>Ótimo! Recebemos<br /><em>sua solicitação.</em></h1>
      <p class="ob9-lead">Um especialista em LGPD da Templum entrará em contato em <strong>até 1 hora útil</strong> pelo WhatsApp ou telefone que você informou.</p>

      <div class="ob9-next">
        <div class="ob9-next-item">
          <span class="ob9-next-n">1</span>
          <div>
            <strong>Especialista analisa seu perfil</strong>
            <span>Com base nos dados que você informou.</span>
          </div>
        </div>
        <div class="ob9-next-item">
          <span class="ob9-next-n">2</span>
          <div>
            <strong>Diagnóstico gratuito</strong>
            <span>Apresentamos o caminho mais curto até a certificação.</span>
          </div>
        </div>
        <div class="ob9-next-item">
          <span class="ob9-next-n">3</span>
          <div>
            <strong>Proposta personalizada</strong>
            <span>Cronograma e investimento sob medida para o seu negócio.</span>
          </div>
        </div>
      </div>

      <a
        href="https://wa.me/5519993521270?text=Ol%C3%A1%2C%20acabei%20de%20solicitar%20um%20diagn%C3%B3stico%20de%20ISO%209001"
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn--wpp btn--lg"
      >
        <iconify-icon icon="mdi:whatsapp"></iconify-icon>
        Falar agora pelo WhatsApp
      </a>
      <p class="ob9-hint">Prefere aguardar? Retornaremos em até 1 hora útil.</p>
    </div>
  </section>

  <!-- Dispara Lead (Meta Pixel + Google Ads + CAPI) -->
  <script is:inline>
    (function () {
      var raw = null;
      try { raw = sessionStorage.getItem("tpl_lead_pending"); } catch (_) {}
      if (!raw) return;
      try { sessionStorage.removeItem("tpl_lead_pending"); } catch (_) {}
      var d = {}; try { d = JSON.parse(raw) || {}; } catch (_) {}
      var PRODUCT = { content_name: 'LGPD', content_category: 'Proteção de Dados' };
      var done = false;
      function fire() {
        if (done) return; done = true;
        try { if (window.trk && typeof window.trk.lead === "function") window.trk.lead({ email: d.email, phone: d.phone, name: d.name, content_name: PRODUCT.content_name, content_category: PRODUCT.content_category }); } catch (_) {}
        try { if (window.fbq) window.fbq('track', 'Lead', PRODUCT); } catch (_) {}
      }
      var n = 0, t = setInterval(function () {
        n++;
        if ((window.trk && typeof window.trk.lead === "function") || n > 60) { clearInterval(t); fire(); }
      }, 100);
    })();
  </script>

</Base>

<style>
  html, body { background: var(--navy); min-height: 100%; }

  .ob9-hero {
    background: var(--navy);
    position: relative;
    overflow: hidden;
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: clamp(64px, 10vw, 100px) clamp(16px, 4vw, 40px);
    text-align: center;
  }
  .ob9-glow {
    position: absolute; inset: 0; pointer-events: none;
    background: radial-gradient(ellipse at center top, rgba(255,89,37,0.14) 0%, transparent 60%);
  }
  .ob9-inner {
    position: relative; z-index: 1;
    max-width: 600px; margin: 0 auto;
    display: flex; flex-direction: column; align-items: center; gap: 0;
  }
  .ob9-check {
    font-size: 64px; color: #22c55e;
    margin-bottom: 20px;
    display: flex; justify-content: center;
  }
  .ob9-badge {
    display: inline-block;
    font-size: 11px; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase;
    color: #22c55e;
    background: rgba(34,197,94,0.12);
    border: 1px solid rgba(34,197,94,0.3);
    padding: 5px 14px; border-radius: 100px;
    margin-bottom: 22px;
  }
  .ob9-inner h1 {
    font-size: clamp(28px, 4vw, 46px); font-weight: 800;
    color: var(--cream); line-height: 1.1; letter-spacing: -0.03em;
    margin-bottom: 18px;
  }
  .ob9-inner h1 em { font-style: normal; color: var(--orange); }
  .ob9-lead {
    font-size: 17px; color: rgba(255,244,221,0.72); line-height: 1.65;
    max-width: 480px; margin-bottom: 36px;
  }
  .ob9-lead strong { color: var(--cream); }

  /* próximos passos */
  .ob9-next {
    width: 100%; text-align: left;
    display: flex; flex-direction: column; gap: 0;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,244,221,0.10);
    border-radius: 16px; padding: 8px 0;
    margin-bottom: 36px;
  }
  .ob9-next-item {
    display: flex; align-items: flex-start; gap: 16px;
    padding: 16px 24px;
    border-bottom: 1px solid rgba(255,244,221,0.08);
  }
  .ob9-next-item:last-child { border-bottom: none; }
  .ob9-next-n {
    width: 32px; height: 32px; border-radius: 50%; flex-shrink: 0;
    display: grid; place-items: center;
    font-size: 14px; font-weight: 800;
    color: var(--orange); background: rgba(255,89,37,0.14);
  }
  .ob9-next-item strong { display: block; font-size: 14.5px; font-weight: 700; color: var(--cream); margin-bottom: 3px; }
  .ob9-next-item span { font-size: 13px; color: rgba(255,244,221,0.55); }

  /* botão wpp */
  .btn--wpp {
    display: inline-flex; align-items: center; gap: 10px;
    background: #25D366; color: #fff; font-weight: 800;
    padding: 18px 36px; border-radius: 50px; font-size: 16px;
    white-space: nowrap;
    box-shadow: 0 4px 24px rgba(37,211,102,0.35);
    transition: opacity .2s, transform .15s;
  }
  .btn--wpp:hover { opacity: 0.92; transform: translateY(-1px); }
  .btn--wpp iconify-icon { font-size: 22px; }
  .ob9-hint {
    font-size: 13px; color: rgba(255,244,221,0.38); margin-top: 14px; line-height: 1.5;
  }
</style>
