---
import LpBase from "../../layouts/LpBase.astro";
import LeadForm from "../../components/LeadForm.astro";
import data from "../../data/consultoria/iso-9001.js";

const norma = "ISO 9001";
---

<LpBase
  title="Consultoria ISO 9001 com Garantia de 200% — Templum"
  description="Certifique sua empresa na ISO 9001 com a Templum: método próprio, consultores dedicados e garantia em contrato — certifique ou receba o dobro de volta."
  formAnchor="#form"
>

  <!-- ══════════════════════════════════════════════
       HERO (dark + gradiente laranja)
  ════════════════════════════════════════════════ -->
  <section class="lp-hero">
    <div class="lp-hero-glow" aria-hidden="true"></div>
    <div class="lp-hero-inner">
      <div class="lp-hero-text">
        <span class="lp-badge">Consultoria · Gestão da Qualidade</span>
        <h1>Certifique sua empresa na <em>ISO 9001</em> — com garantia em contrato</h1>
        <p class="lp-hero-sub">Do diagnóstico à auditoria, a Templum conduz todo o processo. Você não precisa saber nada sobre a norma para começar.</p>
        <ul class="lp-hero-checks">
          <li><iconify-icon icon="solar:check-circle-bold"></iconify-icon> Consultor dedicado, sem limite de horas</li>
          <li><iconify-icon icon="solar:check-circle-bold"></iconify-icon> Todos os documentos elaborados por nós</li>
          <li><iconify-icon icon="solar:check-circle-bold"></iconify-icon> Garantia de 200%: certifique ou devolvemos o dobro</li>
          <li><iconify-icon icon="solar:check-circle-bold"></iconify-icon> Atendimento 100% online, em todo o Brasil</li>
        </ul>
        <div class="lp-hero-trust">
          <div class="lp-trust-item"><strong>+30</strong><span>anos de experiência</span></div>
          <div class="lp-trust-sep"></div>
          <div class="lp-trust-item"><strong>+2.000</strong><span>empresas certificadas</span></div>
          <div class="lp-trust-sep"></div>
          <div class="lp-trust-item"><strong>4,9 ★</strong><span>no Google</span></div>
        </div>
      </div>
      <div id="form" class="lp-hero-form">
        <LeadForm
          norma={norma}
          titulo="Receba um diagnóstico gratuito"
          sub="Preencha e um especialista entra em contato em até 1 hora útil."
          cta="Quero meu diagnóstico gratuito"
        />
        <!-- Sobrescreve destino do form via atributo -->
        <script is:inline>
          document.addEventListener("DOMContentLoaded", function () {
            var forms = document.querySelectorAll(".lp-hero-form form[data-trk-event]");
            forms.forEach(function (f) { f.setAttribute("data-obrigado", "/consultoria/iso-9001-obrigado"); });
          });
        </script>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════
       BARRA DE NÚMEROS (escuro)
  ════════════════════════════════════════════════ -->
  <section class="lp-stats">
    <div class="lp-stats-inner">
      {data.stats.map((s) => (
        <div class="lp-stat-item">
          <strong>{s.num}</strong>
          <span>{s.label}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- ══════════════════════════════════════════════
       POR QUE CERTIFICAR (creme)
  ════════════════════════════════════════════════ -->
  <section class="lp-section lp-section--cream">
    <div class="lp-container">
      <div class="lp-sec-header">
        <span class="lp-tag">Por que certificar</span>
        <h2>O que a ISO 9001 faz pela <em>sua empresa</em></h2>
        <p>Mais do que um certificado na parede — é a base operacional que permite crescer sem perder qualidade.</p>
      </div>
      <div class="lp-motivos">
        {data.motivos.slice(0, 6).map((m, i) => (
          <div class="lp-motivo reveal">
            <span class="lp-motivo-n">{String(i + 1).padStart(2, "0")}</span>
            <h3>{m.t}</h3>
            <p>{m.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════
       O QUE ESTÁ INCLUSO (escuro)
  ════════════════════════════════════════════════ -->
  <section class="lp-section lp-section--navy">
    <div class="lp-container lp-incluso-grid">
      <div class="lp-incluso-text">
        <span class="lp-tag lp-tag--glow">O que você recebe</span>
        <h2>Tudo o que precisa para <em>certificar com segurança</em></h2>
        <p>Sem surpresas, sem terceirizar decisões para você. A Templum entrega o processo completo.</p>
        <a href="#form" class="btn btn--primary btn--lg lp-cta-scroll">
          Quero começar agora <iconify-icon icon="solar:arrow-right-linear"></iconify-icon>
        </a>
      </div>
      <ul class="lp-incluso-list">
        {data.incluso.map((item) => (
          <li class="lp-incluso-item reveal">
            <span class="lp-check-ico"><iconify-icon icon="solar:check-read-linear"></iconify-icon></span>
            {item}
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════
       GARANTIA 200% (laranja)
  ════════════════════════════════════════════════ -->
  <section class="lp-garantia">
    <div class="lp-container lp-garantia-inner">
      <div class="lp-garantia-badge">
        <iconify-icon icon="solar:shield-check-bold"></iconify-icon>
        <span>Garantia<br />200%</span>
      </div>
      <div class="lp-garantia-text">
        <h2>Certificação garantida — ou o dobro do dinheiro de volta</h2>
        <p>Somos a única consultoria no Brasil com essa garantia em contrato. Se você seguir o nosso método e ainda assim não certificar, devolvemos 200% do valor investido. Sem asteriscos.</p>
        <a href="#form" class="btn btn--dark btn--lg">Quero a garantia em contrato <iconify-icon icon="solar:arrow-right-linear"></iconify-icon></a>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════
       7 PASSOS (creme)
  ════════════════════════════════════════════════ -->
  <section class="lp-section lp-section--cream">
    <div class="lp-container">
      <div class="lp-sec-header">
        <span class="lp-tag">Como funciona</span>
        <h2>7 passos até a sua <em>certificação ISO 9001</em></h2>
        <p>Um método à prova de falhas, com checkpoints obrigatórios e consultor disponível todos os dias.</p>
      </div>
      <div class="lp-passos">
        {data.passos.map((p, i) => (
          <div class="lp-passo reveal">
            <span class="lp-passo-n">{String(i + 1).padStart(2, "0")}</span>
            <div>
              <h3>{p.t}</h3>
              <p>{p.d}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════
       FAQ (branco)
  ════════════════════════════════════════════════ -->
  <section class="lp-section">
    <div class="lp-container lp-container--sm">
      <div class="lp-sec-header">
        <span class="lp-tag">Dúvidas frequentes</span>
        <h2>Tudo sobre a <em>ISO 9001</em></h2>
      </div>
      <div class="lp-faq">
        {data.detalhes.faq.map((f) => (
          <details class="lp-faq-item">
            <summary class="lp-faq-q">{f.q}<span class="lp-faq-ico">+</span></summary>
            <div class="lp-faq-a">{f.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════
       FORMULÁRIO FINAL (escuro)
  ════════════════════════════════════════════════ -->
  <section class="lp-section lp-section--navy lp-form-section">
    <div class="lp-container lp-form-grid">
      <div class="lp-form-pitch">
        <span class="lp-tag lp-tag--glow">Comece hoje</span>
        <h2>Receba um <em>diagnóstico gratuito</em> da sua certificação ISO 9001</h2>
        <p>Um especialista analisa o cenário da sua empresa e mostra o caminho mais curto até o certificado — sem compromisso.</p>
        <ul class="lp-form-checks">
          <li><iconify-icon icon="solar:check-circle-bold"></iconify-icon> Diagnóstico e cronograma sob medida</li>
          <li><iconify-icon icon="solar:check-circle-bold"></iconify-icon> Resposta em até 1 hora útil</li>
          <li><iconify-icon icon="solar:check-circle-bold"></iconify-icon> Sem compromisso</li>
        </ul>
      </div>
      <div class="lp-form-wrap">
        <LeadForm
          norma={norma}
          titulo="Fale com um especialista"
          sub="Preencha e entramos em contato."
          cta="Quero meu diagnóstico"
        />
        <script is:inline>
          document.addEventListener("DOMContentLoaded", function () {
            var forms = document.querySelectorAll(".lp-form-wrap form[data-trk-event]");
            forms.forEach(function (f) { f.setAttribute("data-obrigado", "/consultoria/iso-9001-obrigado"); });
          });
        </script>
      </div>
    </div>
  </section>

</LpBase>

<style>
  /* ── TOKENS LP ── */
  :root {
    --lp-accent: var(--norm-iso9001, var(--orange));
  }

  /* ── HERO ── */
  .lp-hero {
    position: relative;
    background: var(--navy);
    padding: clamp(48px, 7vw, 88px) clamp(16px, 4vw, 40px);
    overflow: hidden;
  }
  .lp-hero-glow {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(720px 420px at 0% 0%, color-mix(in srgb, var(--lp-accent) 28%, transparent), transparent 65%),
      radial-gradient(480px 320px at 100% 100%, color-mix(in srgb, var(--lp-accent) 14%, transparent), transparent 60%);
  }
  .lp-hero-inner {
    position: relative;
    z-index: 1;
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: clamp(32px, 5vw, 72px);
    align-items: start;
  }
  .lp-badge {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--lp-accent);
    background: color-mix(in srgb, var(--lp-accent) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--lp-accent) 35%, transparent);
    padding: 5px 14px;
    border-radius: 100px;
    margin-bottom: 20px;
  }
  .lp-hero-text h1 {
    font-size: clamp(30px, 4vw, 52px);
    font-weight: 800;
    line-height: 1.08;
    letter-spacing: -0.03em;
    color: var(--cream);
    margin-bottom: 18px;
  }
  .lp-hero-text h1 em { font-style: normal; color: var(--lp-accent); }
  .lp-hero-sub {
    font-size: 17px;
    color: rgba(255,244,221,0.78);
    line-height: 1.65;
    max-width: 520px;
    margin-bottom: 26px;
  }
  .lp-hero-checks {
    list-style: none;
    padding: 0;
    margin: 0 0 30px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .lp-hero-checks li {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 15px;
    font-weight: 600;
    color: rgba(255,244,221,0.88);
  }
  .lp-hero-checks iconify-icon { font-size: 20px; color: var(--lp-accent); flex-shrink: 0; }

  .lp-hero-trust {
    display: flex;
    align-items: center;
    gap: 20px;
    padding-top: 22px;
    border-top: 1px solid rgba(255,244,221,0.12);
    flex-wrap: wrap;
  }
  .lp-trust-item { display: flex; flex-direction: column; }
  .lp-trust-item strong { font-size: 22px; font-weight: 800; color: var(--cream); line-height: 1.1; }
  .lp-trust-item span { font-size: 12px; color: rgba(255,244,221,0.52); margin-top: 2px; }
  .lp-trust-sep { width: 1px; height: 36px; background: rgba(255,244,221,0.15); }

  .lp-hero-form { align-self: start; position: sticky; top: 80px; }

  @media (max-width: 880px) {
    .lp-hero-inner { grid-template-columns: 1fr; }
    .lp-hero-form { position: static; }
  }

  /* ── STATS BAR ── */
  .lp-stats {
    background: color-mix(in srgb, var(--lp-accent) 18%, #0c0e12);
    padding: 28px clamp(16px, 4vw, 40px);
  }
  .lp-stats-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-around;
    gap: 20px;
    flex-wrap: wrap;
    text-align: center;
  }
  .lp-stat-item { display: flex; flex-direction: column; gap: 4px; }
  .lp-stat-item strong { font-size: clamp(22px, 3vw, 32px); font-weight: 800; color: var(--cream); line-height: 1; }
  .lp-stat-item span { font-size: 13px; color: rgba(255,244,221,0.6); }

  /* ── SEÇÕES ── */
  .lp-section { padding: clamp(56px, 8vw, 96px) clamp(16px, 4vw, 40px); }
  .lp-section--cream { background: var(--cream, #FFFAEB); }
  .lp-section--navy { background: var(--navy); }
  .lp-container { max-width: 1200px; margin: 0 auto; }
  .lp-container--sm { max-width: 780px; }

  .lp-sec-header { text-align: center; max-width: 680px; margin: 0 auto 48px; }
  .lp-tag {
    display: inline-block;
    font-size: 11px; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase;
    color: var(--lp-accent);
    background: color-mix(in srgb, var(--lp-accent) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--lp-accent) 30%, transparent);
    padding: 4px 14px; border-radius: 100px; margin-bottom: 16px;
  }
  .lp-tag--glow { box-shadow: 0 0 12px color-mix(in srgb, var(--lp-accent) 30%, transparent); }
  .lp-sec-header h2 {
    font-size: clamp(26px, 3.4vw, 42px); font-weight: 800; line-height: 1.1;
    letter-spacing: -0.025em; margin-bottom: 14px;
  }
  .lp-section--cream .lp-sec-header h2 { color: var(--navy); }
  .lp-section--navy .lp-sec-header h2 { color: var(--cream); }
  .lp-sec-header h2 em { font-style: normal; color: var(--lp-accent); }
  .lp-sec-header p { font-size: 16px; line-height: 1.65; color: var(--text-mid, #555); }
  .lp-section--navy .lp-sec-header p { color: rgba(255,244,221,0.65); }

  /* ── MOTIVOS ── */
  .lp-motivos {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  @media (max-width: 880px) { .lp-motivos { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 560px) { .lp-motivos { grid-template-columns: 1fr; } }
  .lp-motivo {
    background: #fff;
    border: 1px solid rgba(0,0,0,0.07);
    border-radius: 20px;
    padding: 28px 26px;
    box-shadow: 0 2px 16px rgba(0,0,0,0.05);
  }
  .lp-motivo-n {
    display: inline-grid; place-items: center;
    width: 40px; height: 40px; border-radius: 50%;
    font-size: 16px; font-weight: 800;
    color: var(--lp-accent);
    background: color-mix(in srgb, var(--lp-accent) 12%, transparent);
    margin-bottom: 14px;
  }
  .lp-motivo h3 { font-size: 17px; font-weight: 800; margin-bottom: 8px; color: var(--navy); }
  .lp-motivo p { font-size: 14px; color: #555; line-height: 1.6; }

  /* ── INCLUSO ── */
  .lp-incluso-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(32px, 5vw, 72px);
    align-items: center;
  }
  @media (max-width: 780px) { .lp-incluso-grid { grid-template-columns: 1fr; } }
  .lp-incluso-text h2 { font-size: clamp(26px, 3vw, 38px); font-weight: 800; color: var(--cream); line-height: 1.1; letter-spacing: -0.025em; margin: 14px 0 16px; }
  .lp-incluso-text h2 em { font-style: normal; color: var(--lp-accent); }
  .lp-incluso-text p { font-size: 16px; color: rgba(255,244,221,0.65); line-height: 1.6; margin-bottom: 28px; }
  .lp-cta-scroll { display: inline-flex; align-items: center; gap: 8px; }
  .lp-incluso-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 14px; }
  .lp-incluso-item {
    display: flex; align-items: flex-start; gap: 14px;
    font-size: 15px; font-weight: 500; color: rgba(255,244,221,0.9);
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,244,221,0.10);
    border-radius: 12px; padding: 14px 18px;
  }
  .lp-check-ico {
    width: 28px; height: 28px; border-radius: 50%; flex-shrink: 0;
    display: grid; place-items: center;
    font-size: 16px; color: var(--lp-accent);
    background: color-mix(in srgb, var(--lp-accent) 15%, transparent);
  }

  /* ── GARANTIA ── */
  .lp-garantia {
    background: var(--orange);
    padding: clamp(48px, 7vw, 80px) clamp(16px, 4vw, 40px);
  }
  .lp-garantia-inner {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: clamp(28px, 4vw, 56px);
    align-items: center;
  }
  @media (max-width: 680px) { .lp-garantia-inner { grid-template-columns: 1fr; text-align: center; } .lp-garantia-badge { margin: 0 auto; } }
  .lp-garantia-badge {
    width: 120px; height: 120px; border-radius: 50%;
    background: rgba(0,0,0,0.18);
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    gap: 4px; flex-shrink: 0;
  }
  .lp-garantia-badge iconify-icon { font-size: 36px; color: #fff; }
  .lp-garantia-badge span { font-size: 13px; font-weight: 800; color: #fff; line-height: 1.2; text-align: center; }
  .lp-garantia-text h2 { font-size: clamp(24px, 3vw, 38px); font-weight: 800; color: #fff; line-height: 1.1; letter-spacing: -0.025em; margin-bottom: 14px; }
  .lp-garantia-text p { font-size: 16px; color: rgba(255,255,255,0.85); line-height: 1.6; margin-bottom: 24px; max-width: 580px; }
  .btn--dark { background: #fff; color: var(--navy); }
  .btn--dark:hover { background: var(--cream); }

  /* ── PASSOS ── */
  .lp-passos { display: flex; flex-direction: column; gap: 0; }
  .lp-passo {
    display: grid; grid-template-columns: 56px 1fr; gap: 20px; align-items: start;
    padding: 22px 0;
    border-bottom: 1px solid rgba(0,0,0,0.08);
  }
  .lp-passo:last-child { border-bottom: none; }
  .lp-passo-n {
    display: grid; place-items: center;
    width: 48px; height: 48px; border-radius: 50%;
    font-size: 18px; font-weight: 800;
    color: var(--lp-accent);
    background: color-mix(in srgb, var(--lp-accent) 12%, transparent);
    flex-shrink: 0; margin-top: 2px;
  }
  .lp-passo h3 { font-size: 17px; font-weight: 800; color: var(--navy); margin-bottom: 6px; }
  .lp-passo p { font-size: 14.5px; color: #666; line-height: 1.6; }

  /* ── FAQ ── */
  .lp-faq { display: flex; flex-direction: column; gap: 0; }
  .lp-faq-item {
    border-bottom: 1px solid rgba(0,0,0,0.08);
  }
  .lp-faq-q {
    display: flex; align-items: center; justify-content: space-between; gap: 16px;
    padding: 20px 0; cursor: pointer;
    font-size: 16px; font-weight: 700; color: var(--navy);
    list-style: none;
  }
  .lp-faq-q::-webkit-details-marker { display: none; }
  .lp-faq-ico {
    font-size: 22px; font-weight: 300; color: var(--lp-accent); flex-shrink: 0;
    transition: transform .2s;
  }
  .lp-faq-item[open] .lp-faq-ico { transform: rotate(45deg); }
  .lp-faq-item[open] .lp-faq-q { color: var(--lp-accent); }
  .lp-faq-a { font-size: 15px; color: #555; line-height: 1.7; padding-bottom: 20px; }

  /* ── FORM FINAL ── */
  .lp-form-section { padding-top: clamp(56px, 8vw, 96px); padding-bottom: clamp(56px, 8vw, 96px); }
  .lp-form-grid {
    display: grid;
    grid-template-columns: 1fr 0.95fr;
    gap: clamp(32px, 5vw, 64px);
    align-items: center;
  }
  @media (max-width: 880px) { .lp-form-grid { grid-template-columns: 1fr; } }
  .lp-form-pitch h2 { font-size: clamp(24px, 3vw, 36px); font-weight: 800; color: var(--cream); line-height: 1.1; letter-spacing: -0.025em; margin: 14px 0 14px; }
  .lp-form-pitch h2 em { font-style: normal; color: var(--lp-accent); }
  .lp-form-pitch > p { font-size: 16px; color: rgba(255,244,221,0.65); line-height: 1.6; margin-bottom: 22px; }
  .lp-form-checks { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 12px; }
  .lp-form-checks li { display: flex; align-items: center; gap: 10px; font-size: 15px; font-weight: 600; color: rgba(255,244,221,0.85); }
  .lp-form-checks iconify-icon { font-size: 20px; color: var(--lp-accent); flex-shrink: 0; }
</style>
