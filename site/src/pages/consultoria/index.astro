---
import Base from "../../layouts/Base.astro";
import PageHero from "../../components/PageHero.astro";
import { normas } from "../../data/normas.js";
import { baseConsultoria } from "../../data/consultoria/_base.js";

const { stats, porques } = baseConsultoria;
---

<Base
  title="Consultoria de Certificação ISO — Todas as normas | Templum"
  description="Consultoria para ISO 9001, 14001, 27001, 45001, 37001, PBQP-H, SASSMAQ, FSSC 22000, HACCP, ESG, SGI e LGPD. Método próprio, 100% online e garantia de 200% em contrato."
>
  <!-- HERO -->
  <PageHero
    tag="Consultoria Templum"
    sub="Há +30 anos implantamos sistemas de gestão do diagnóstico à auditoria, com método próprio, plataforma de gestão e a única garantia de 200% do mercado."
    image="/assets/img/hero/templum-consultoria-industria.webp"
    badge="12 normas certificáveis"
    icon="solar:checklist-minimalistic-bold"
    chips={["+2.000 clientes certificados", "100% online", "Garantia de 200%"]}
  >
    <Fragment slot="title">A certificação certa para a <em class="accent">sua norma</em></Fragment>
    <Fragment slot="cta">
      <a href="/form" class="btn btn--primary btn--lg">Falar com um especialista <iconify-icon icon="solar:arrow-right-linear"></iconify-icon></a>
      <a href="#normas" class="btn btn--onDark btn--lg">Ver todas as normas</a>
    </Fragment>
  </PageHero>

  <!-- STATS -->
  <section class="section section--cream cn-stats-sec">
    <div class="container">
      <div class="cn-stats">
        {stats.map((s) => (
          <div class="number-card">
            <div class="value">{s.num}</div>
            <div class="label">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- GRID DE NORMAS -->
  <section id="normas" class="section">
    <div class="container">
      <div class="section-header">
        <span class="tag-pill">Escolha a sua certificação</span>
        <h2>Uma consultoria especialista <em class="accent">para cada norma</em></h2>
        <p>Cada certificação tem cor, time e método próprios. Conheça a sua e fale com quem entende dela.</p>
      </div>

      <div class="cn-grid">
        {normas.map((n) => (
          <a class="cn-card" href={n.href} style={`--c:${n.color}`}>
            <div class="cn-media">
              <span class="cn-ico"><iconify-icon icon={n.icon}></iconify-icon></span>
              <img src={`/assets/img/consultoria/${n.slug}.webp`} alt={`Consultoria ${n.nome}`} loading="lazy" onerror="this.style.display='none'" />
              <span class="cn-grad"></span>
            </div>
            <div class="cn-body">
              <span class="cn-cat">{n.categoria}</span>
              <h3>{n.nome}</h3>
              <p>{n.tagline}</p>
              <span class="cn-link">Conhecer a consultoria <iconify-icon icon="solar:arrow-right-linear"></iconify-icon></span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- POR QUE A TEMPLUM -->
  <section class="section section--navy">
    <div class="container">
      <div class="section-header">
        <span class="tag-pill tag-pill--glow">Por que a Templum</span>
        <h2>Segurança, experiência e <em class="accent">garantia em contrato</em></h2>
      </div>
      <div class="cn-porques">
        {porques.map((p) => (
          <div class="cn-porque">
            <span class="cn-porque-ico"><iconify-icon icon={p.icon}></iconify-icon></span>
            <h3>{p.t}</h3>
            <p>{p.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-band">
    <div class="container md">
      <h2>Não sabe por <em>qual norma começar</em>?</h2>
      <p>Um especialista analisa o cenário da sua empresa e indica o caminho mais curto até o certificado — sem compromisso.</p>
      <a href="/form" class="btn btn--dark btn--lg">Receber diagnóstico gratuito <iconify-icon icon="solar:arrow-right-linear"></iconify-icon></a>
    </div>
  </section>
</Base>

<style>
  /* STATS */
  .cn-stats-sec { padding-top: 56px; padding-bottom: 56px; }
  .cn-stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; }
  @media (max-width: 880px) { .cn-stats { grid-template-columns: repeat(2, 1fr); } }

  /* GRID DE NORMAS */
  .cn-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; margin-top: 44px; }
  @media (max-width: 980px) { .cn-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 620px) { .cn-grid { grid-template-columns: 1fr; } }

  .cn-card { display: flex; flex-direction: column; background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--r-24); overflow: hidden; transition: transform .35s var(--ease-soft), box-shadow .35s var(--ease-soft), border-color .35s var(--ease-soft); }
  .cn-card:hover { transform: translateY(-6px); box-shadow: var(--shadow-card); border-color: color-mix(in srgb, var(--c) 50%, var(--border)); }

  .cn-media { position: relative; aspect-ratio: 16 / 10; background: color-mix(in srgb, var(--c) 90%, #0c0e12); overflow: hidden; }
  .cn-media img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; transition: transform .5s var(--ease-soft); }
  .cn-card:hover .cn-media img { transform: scale(1.05); }
  .cn-ico { position: absolute; inset: 0; display: grid; place-items: center; font-size: 64px; color: rgba(255,255,255,0.92); z-index: 0; }
  .cn-grad { position: absolute; inset: 0; z-index: 1; background: linear-gradient(180deg, transparent 40%, color-mix(in srgb, var(--c) 60%, transparent) 100%); }

  .cn-body { display: flex; flex-direction: column; gap: 8px; padding: 22px 24px 26px; flex: 1; }
  .cn-cat { font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: color-mix(in srgb, var(--c) 72%, var(--text-mid)); }
  .cn-body h3 { font-size: 22px; font-weight: 800; letter-spacing: -0.02em; color: var(--text); }
  .cn-body p { font-size: 14.5px; color: var(--text-mid); line-height: 1.55; flex: 1; }
  .cn-link { display: inline-flex; align-items: center; gap: 7px; font-size: 14px; font-weight: 700; color: var(--c); margin-top: 6px; }
  .cn-card:hover .cn-link iconify-icon { transform: translateX(4px); }
  .cn-link iconify-icon { transition: transform .3s var(--ease-soft); }

  /* POR QUE */
  .cn-porques { display: grid; grid-template-columns: repeat(3, 1fr); gap: 22px; margin-top: 44px; }
  @media (max-width: 880px) { .cn-porques { grid-template-columns: 1fr; } }
  .cn-porque { background: rgba(255,244,221,0.04); border: 1px solid rgba(255,244,221,0.12); border-radius: var(--r-20); padding: 30px 28px; }
  .cn-porque-ico { width: 52px; height: 52px; border-radius: 14px; display: grid; place-items: center; font-size: 26px; color: var(--orange); background: rgba(255,89,37,0.16); margin-bottom: 16px; }
  .cn-porque h3 { font-size: 18px; font-weight: 800; color: var(--cream); margin-bottom: 8px; }
  .cn-porque p { font-size: 14.5px; color: rgba(255,244,221,0.72); line-height: 1.6; }
</style>
