<script>
  // Máscara telefone
  document.querySelectorAll('input[name="telefone"]').forEach((el) => {
    el.addEventListener("input", function () {
      const inp = this as HTMLInputElement;
      let d = inp.value.replace(/\D/g, "").substring(0, 11);
      const len = d.length;
      if (len === 0) { inp.value = ""; return; }
      if (len <= 2) inp.value = "(" + d;
      else if (len <= 6) inp.value = "(" + d.slice(0,2) + ") " + d.slice(2);
      else if (len <= 10) inp.value = "(" + d.slice(0,2) + ") " + d.slice(2,6) + "-" + d.slice(6);
      else inp.value = "(" + d.slice(0,2) + ") " + d.slice(2,7) + "-" + d.slice(7);
    });
  });

  // Atribuição UTM
  function getAttrib() {
    const p = new URLSearchParams(location.search);
    const keys = ["utm_source","utm_medium","utm_campaign","utm_term","utm_content"];
    const o: Record<string, string> = {};
    keys.forEach((k) => { if (p.get(k)) o[k] = p.get(k)!; });
    return o;
  }

  // Submit do formulário
  const form = document.querySelector<HTMLFormElement>(".ws-form");
  if (form) {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const btn = form.querySelector<HTMLButtonElement>("button[type=submit]")!;
      btn.disabled = true;
      btn.textContent = "Enviando…";

      const fd = new FormData(form);
      const nome = (fd.get("nome") as string || "").trim();
      const email = (fd.get("email") as string || "").trim();
      const telefone = (fd.get("telefone") as string || "").trim();
      const empresa = (fd.get("empresa") as string || "").trim();
      const cargo = (fd.get("cargo") as string || "").trim();

      try {
        await fetch("/api/lead", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          keepalive: true,
          body: JSON.stringify({
            nome, email, telefone, empresa, cargo,
            norma: "ISO 9001",
            evento: "webserie-iso9001-2026",
            pagina: location.pathname,
            ...getAttrib(),
          }),
        });

        // Confirmação inline
        form.innerHTML = `
          <div style="text-align:center;padding:24px 0;">
            <div style="font-size:44px;margin-bottom:16px;">🎉</div>
            <h3 style="font-size:22px;font-weight:800;color:var(--text);margin-bottom:8px;">Vaga garantida!</h3>
            <p style="color:var(--text-2);line-height:1.7;margin-bottom:20px;">
              Você receberá um e-mail de confirmação em breve.<br />
              Fique de olho na sua caixa de entrada — os links de acesso a cada encontro serão enviados antes de cada evento.
            </p>
            <a href="#calendario" style="display:inline-flex;align-items:center;gap:8px;color:var(--orange);font-weight:700;font-size:14px;">
              Ver calendário completo →
            </a>
          </div>
        `;
      } catch {
        btn.disabled = false;
        btn.textContent = "Tentar novamente";
        alert("Erro ao enviar. Por favor, tente novamente.");
      }
    });
  }
</script>
