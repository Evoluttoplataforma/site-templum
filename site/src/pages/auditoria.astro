---
import Base from "../layouts/Base.astro";
import PageHero from "../components/PageHero.astro";

// Copy real extraída de "site atual/auditoria templum.html".
const diferenciais = [
  { n: "1", t: "Diagnóstico preciso, resultados potentes", d: "Cada auditoria interna realiza uma análise minuciosa dos seus sistemas críticos, assegurando que operem de maneira otimizada e segura. Identificamos falhas antes que se transformem em problemas, protegendo sua empresa contra riscos e fortalecendo sua estabilidade." },
  { n: "2", t: "Mais do que compliance: performance máxima", d: "Nossas auditorias vão além da conformidade com as normas ISO, impulsionando a eficiência dos seus processos. Cada etapa é uma oportunidade para otimizar operações, aumentar a produtividade e descobrir novas possibilidades de crescimento e inovação." },
  { n: "3", t: "Controle total, tranquilidade absoluta", d: "Com nossa abordagem detalhada, você tem a certeza de que todos os seus processos funcionam com segurança e eficiência. Prevenimos riscos e reforçamos as defesas da sua empresa contra ameaças potenciais, garantindo uma operação estável e sem surpresas." },
];
const beneficios = [
  { icon: "solar:shield-check-bold", t: "Tranquilidade pré-certificação", d: "Conhecemos a fundo as exigências das certificadoras e garantimos que sua empresa esteja totalmente preparada." },
  { icon: "solar:users-group-rounded-bold", t: "Especialistas proativos", d: "Nossa equipe não apenas identifica problemas — orienta seu time, com foco em resultados concretos." },
  { icon: "solar:chart-2-bold", t: "Relatórios estratégicos", d: "Fornecemos insights valiosos que vão além das normas e transformam suas auditorias em oportunidades de crescimento." },
  { icon: "solar:refresh-circle-bold", t: "Monitoramento contínuo", d: "Acompanhamos de perto os processos críticos da sua empresa, prevenindo desvios e minimizando riscos." },
  { icon: "solar:copy-bold", t: "Segurança na replicação", d: "Para empresas com múltiplas unidades, asseguramos que todas operem com os mesmos padrões de excelência." },
  { icon: "solar:ranking-bold", t: "Padronização de alta performance", d: "Desenvolvemos modelos de auditoria personalizados que garantem uniformidade e promovem um crescimento sustentável." },
];

const SITE = (Astro.site?.href || "https://templum.com.br/").replace(/\/$/, "");
const pageSchemas = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    name: "Auditoria interna",
    serviceType: "Auditoria interna de sistemas de gestão ISO",
    description: "Auditoria interna inteligente: análise de riscos com base nas normas ISO e relatório personalizado com recomendações práticas, preparando a empresa para a certificação.",
    provider: { "@id": `${SITE}/#organization` },
    areaServed: { "@type": "Country", name: "Brasil" },
    url: `${SITE}/auditoria`,
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Início", item: `${SITE}/` },
      { "@type": "ListItem", position: 2, name: "Auditoria interna", item: `${SITE}/auditoria` },
    ],
  },
];
---

<Base
  title="Auditoria Interna Inteligente — Identifique riscos em minutos | Templum"
  description="Auditorias internas inteligentes da Templum: análise de riscos com base nas normas ISO, relatório personalizado e especialistas proativos. Proteja, fortaleça e certifique sua empresa."
  schemas={pageSchemas}
>
  <PageHero
    tag="Auditorias internas inteligentes"
    sub="Analisamos os riscos para a auditoria interna da sua organização com base nas normas ISO e geramos um relatório personalizado com recomendações práticas."
    image="/assets/img/paginas/auditoria-hero.webp"
    badge="Auditoria interna"
    icon="solar:clipboard-check-bold"
    chips={["98% de precisão na análise", "5 min de tempo médio"]}
  >
    <Fragment slot="title">Identifique os riscos para a <em class="accent">auditoria interna</em> da sua empresa em minutos</Fragment>
    <Fragment slot="cta">
      <a href="https://calculadora-riscos-auditoria-interna-templum.lovable.app/calculator" target="_blank" rel="noopener" class="btn btn--primary btn--lg">Calcular riscos gratuitamente <iconify-icon icon="solar:arrow-right-linear"></iconify-icon></a>
      <a href="/form/" class="btn btn--onDark btn--lg">Solicitar uma proposta</a>
    </Fragment>
  </PageHero>

  <section class="section section--cream">
    <div class="container">
      <div class="section-header">
        <span class="tag-pill">O que a Templum faz por você</span>
        <h2>Com a Templum, você vai <em class="accent">além do básico</em></h2>
        <p>Uma avaliação completa da saúde empresarial, do diagnóstico à proteção contra riscos.</p>
      </div>
      <div class="ad-dif">
        {diferenciais.map((d) => (
          <div class="ad-dif-card">
            <span class="ad-dif-num">{d.n}</span>
            <h3>{d.t}</h3>
            <p>{d.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="tag-pill">Benefícios de escolher a Templum</span>
        <h2>Cada auditoria, uma dose de <em class="accent">precisão e eficiência</em></h2>
        <p>Nossa metodologia afiada e proativa ajuda sua empresa a crescer com segurança e resiliência.</p>
      </div>
      <div class="ad-grid">
        {beneficios.map((b) => (
          <div class="eco-card">
            <span class="ad-ico"><iconify-icon icon={b.icon}></iconify-icon></span>
            <h3>{b.t}</h3>
            <p>{b.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="cta-band">
    <div class="container md">
      <h2>Sua auditoria interna é a <em>chave para o sucesso contínuo</em></h2>
      <p>Proteja, fortaleça e certifique sua empresa com a Templum.</p>
      <a href="/form/" class="btn btn--dark btn--lg">Solicitar uma proposta <iconify-icon icon="solar:arrow-right-linear"></iconify-icon></a>
    </div>
  </section>
</Base>

<style>
  .ad-dif { display: grid; grid-template-columns: repeat(3, 1fr); gap: 22px; margin-top: 44px; }
  @media (max-width: 880px) { .ad-dif { grid-template-columns: 1fr; } }
  .ad-dif-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--r-20); padding: 32px 28px; }
  .ad-dif-num { display: inline-grid; place-items: center; width: 44px; height: 44px; border-radius: 50%; font-size: 20px; font-weight: 800; color: var(--orange); background: rgba(255,89,37,0.12); margin-bottom: 16px; }
  .ad-dif-card h3 { font-size: 19px; font-weight: 800; letter-spacing: -0.01em; margin-bottom: 10px; }
  .ad-dif-card p { font-size: 14.5px; color: var(--text-mid); line-height: 1.6; }

  .ad-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 22px; margin-top: 44px; }
  @media (max-width: 980px) { .ad-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 620px) { .ad-grid { grid-template-columns: 1fr; } }
  .ad-ico { width: 52px; height: 52px; border-radius: 14px; display: grid; place-items: center; font-size: 26px; color: var(--orange); background: rgba(255,89,37,0.10); margin-bottom: 16px; }
</style>
