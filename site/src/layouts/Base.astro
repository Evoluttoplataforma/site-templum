---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import TrackingKit from "../components/TrackingKit.astro";

const {
  title = "Templum Consultoria — Certificação ISO com garantia de 200%",
  description = "Há +30 anos a Templum organiza a gestão da sua empresa do diagnóstico à auditoria, com método próprio e garantia de 200%: certificação ou o dobro do dinheiro de volta.",
  ogImage = "/assets/og/templum-og.jpg",
  noHeaderFooter = false,
  hideWpp = false,
  noindex = false,
  schemas = [],
  preloadImage = "",
} = Astro.props;

const SITE = (Astro.site?.href || "https://templum.com.br/").replace(/\/$/, "");
const canonical = new URL(Astro.url.pathname, Astro.site).href;
// og:image precisa ser URL ABSOLUTA (WhatsApp/Facebook ignoram caminho relativo).
const ogImageUrl = new URL(ogImage, Astro.site).href;

// --- JSON-LD (Schema.org) — entidade + site, em todas as páginas (AIEO/GEO) ---
const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "@id": `${SITE}/#organization`,
  name: "Templum Consultoria",
  alternateName: "Templum",
  url: `${SITE}/`,
  logo: { "@type": "ImageObject", url: `${SITE}/assets/logo/templum.png` },
  image: `${SITE}/assets/og/templum-og.jpg`,
  description:
    "Consultoria de certificações ISO com método próprio e garantia de 200%: há mais de 30 anos organiza a gestão de empresas do diagnóstico à auditoria, com atendimento 100% online em todo o Brasil.",
  slogan: "Certificação ISO com garantia de 200%",
  areaServed: { "@type": "Country", name: "Brasil" },
  knowsAbout: [
    "ISO 9001", "ISO 14001", "ISO 27001", "ISO 45001", "ISO 37001", "PBQP-H",
    "FSSC 22000", "HACCP", "ESG", "SGI", "SASSMAQ", "LGPD",
    "Certificação ISO", "Auditoria interna", "Sistema de gestão",
  ],
  contactPoint: {
    "@type": "ContactPoint",
    telephone: "+55-19-99352-1270",
    contactType: "customer service",
    areaServed: "BR",
    availableLanguage: ["Portuguese"],
  },
  sameAs: [
    "https://www.instagram.com/templumconsultoriailimitada/",
    "https://www.linkedin.com/company/3033783/",
  ],
};
const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": `${SITE}/#website`,
  url: `${SITE}/`,
  name: "Templum Consultoria",
  inLanguage: "pt-BR",
  publisher: { "@id": `${SITE}/#organization` },
};
const allSchemas = [orgSchema, websiteSchema, ...schemas];
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Tracking (Clarity + GA4 x2 + Google Ads + tracking-kit) carregado SÓ na 1ª
         interação do usuário (ou ocioso pós-load) → fora do caminho crítico de render. -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      window.gtag = function(){ dataLayer.push(arguments); };
      (function () {
        var done = false;
        function boot() {
          if (done) return; done = true;
          // Microsoft Clarity
          (function(c,l,a,r,i,t,y){c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);})(window,document,"clarity","script","sr5nwfj8jc");
          // Google gtag (GA4 x2 + Ads)
          var g=document.createElement("script");g.async=true;g.src="https://www.googletagmanager.com/gtag/js?id=G-2BW8QTYLB5";document.head.appendChild(g);
          gtag("js", new Date());
          gtag("config","G-2BW8QTYLB5",{send_page_view:false});
          gtag("config","G-FV41GWD427",{send_page_view:false});
          gtag("config","AW-17896226473");
          // tracking-kit (definido em TrackingKit.astro)
          if (typeof window.__loadTrackingKit === "function") window.__loadTrackingKit();
        }
        var evs = ["pointerdown","touchstart","keydown","scroll","mousemove"];
        var opts = { once: true, passive: true, capture: true };
        function once(){ evs.forEach(function(e){ window.removeEventListener(e, once, opts); }); boot(); }
        evs.forEach(function(e){ window.addEventListener(e, once, opts); });
        window.addEventListener("load", function(){
          var idle = window.requestIdleCallback || function(cb){ return setTimeout(cb, 6000); };
          idle(function(){ setTimeout(boot, 6000); });
        });
      })();
    </script>

    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Templum Consultoria" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:secure_url" content={ogImageUrl} />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Templum Consultoria — Certificação ISO com garantia de 200%" />
    <meta property="og:locale" content="pt_BR" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Schema.org JSON-LD (Organization + WebSite + schemas da página) -->
    {allSchemas.map((s) => (
      <script type="application/ld+json" set:html={JSON.stringify(s)} />
    ))}

    <!-- Montserrat (Medium / SemiBold / Bold / Extrabold) -->
    <!-- Montserrat self-hosted: preload dos pesos-chave (corpo 500, título 800).
         @font-face em fonts.css. Sem CSS externo bloqueante, sem CLS. -->
    <link rel="preload" as="font" type="font/woff2" href="/fonts/montserrat-500.woff2" crossorigin />
    <link rel="preload" as="font" type="font/woff2" href="/fonts/montserrat-600.woff2" crossorigin />
    <link rel="preload" as="font" type="font/woff2" href="/fonts/montserrat-800.woff2" crossorigin />
    {preloadImage && <link rel="preload" as="image" href={preloadImage} fetchpriority="high" />}

    <!-- Ícones (Iconify) — defer p/ não bloquear o render -->
    <script src="https://cdn.jsdelivr.net/npm/iconify-icon@2/dist/iconify-icon.min.js" defer is:inline></script>

    <!-- Tracking (tracking-kit) -->
    <TrackingKit />
  </head>
  <body>
    {!noHeaderFooter && <Header />}
    <main>
      <slot />
    </main>
    {!noHeaderFooter && <Footer />}
    {!noHeaderFooter && !hideWpp && (
      <a class="whatsapp-float" href="https://wa.me/5519993521270" target="_blank" rel="noopener" aria-label="Falar no WhatsApp">
        <iconify-icon icon="ic:baseline-whatsapp"></iconify-icon>
      </a>
    )}

    <!-- Reveal on scroll -->
    <script is:inline>
      (function () {
        const els = document.querySelectorAll(".reveal");
        if (!("IntersectionObserver" in window) || !els.length) {
          els.forEach((el) => el.classList.add("is-in"));
          return;
        }
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add("is-in");
                io.unobserve(e.target);
              }
            });
          },
          { threshold: 0.12 }
        );
        els.forEach((el) => io.observe(el));
      })();
    </script>

    <!-- Atribuição: UTMs + click-ids (Google/Meta) first/last-touch, fbp/fbc,
         client_id (visitante), session_id e session_attributes. window.__tplAttrib(). -->
    <script is:inline>
      (function () {
        var KEYS = ["utm_source","utm_medium","utm_campaign","utm_term","utm_content","gclid","fbclid","gbraid","wbraid","gad_source","gad_campaignid","msclkid","ttclid"];
        function uuid() { try { return crypto.randomUUID(); } catch (_) { return "x" + Date.now().toString(36) + Math.random().toString(36).slice(2, 10); } }
        function cookie(n) { var m = document.cookie.match("(^|;)\\s*" + n + "\\s*=\\s*([^;]+)"); return m ? decodeURIComponent(m.pop()) : ""; }
        try {
          var p = new URLSearchParams(location.search), cur = {}, now = Date.now();
          KEYS.forEach(function (k) { var v = p.get(k); if (v) cur[k] = v; });
          if (!localStorage.getItem("tpl_first")) {
            localStorage.setItem("tpl_first", JSON.stringify(Object.assign({ landing: location.pathname, referrer: document.referrer || "", first_seen: now }, cur)));
          }
          if (Object.keys(cur).length) localStorage.setItem("tpl_last", JSON.stringify(cur));
          if (!localStorage.getItem("tpl_cid")) localStorage.setItem("tpl_cid", uuid());
          if (!sessionStorage.getItem("tpl_sid")) { sessionStorage.setItem("tpl_sid", uuid()); sessionStorage.setItem("tpl_sstart", String(now)); sessionStorage.setItem("tpl_spages", "0"); }
          sessionStorage.setItem("tpl_spages", String((parseInt(sessionStorage.getItem("tpl_spages") || "0", 10)) + 1));
        } catch (_) {}
        window.__tplAttrib = function () {
          var f = {}, l = {};
          try { f = JSON.parse(localStorage.getItem("tpl_first") || "{}"); } catch (_) {}
          try { l = JSON.parse(localStorage.getItem("tpl_last") || "{}"); } catch (_) {}
          function g(k) { return l[k] || f[k] || ""; } // last-touch (com fallback p/ first)
          function ft(k) { return f[k] || ""; }          // first-touch (original)
          var sa = {
            device: /Mobi|Android|iPhone|iPad/i.test(navigator.userAgent) ? "mobile" : "desktop",
            language: navigator.language || "",
            screen: (screen.width || 0) + "x" + (screen.height || 0),
            landing: f.landing || location.pathname,
            referrer: f.referrer || document.referrer || "",
            first_seen: f.first_seen || "",
            session_start: sessionStorage.getItem("tpl_sstart") || "",
            page_count: sessionStorage.getItem("tpl_spages") || "1",
          };
          return {
            client_id: localStorage.getItem("tpl_cid") || "",
            session_id: sessionStorage.getItem("tpl_sid") || "",
            // last-touch
            utm_source: g("utm_source"), utm_medium: g("utm_medium"), utm_campaign: g("utm_campaign"),
            utm_term: g("utm_term"), utm_content: g("utm_content"),
            gclid: g("gclid"), fbclid: g("fbclid"), gbraid: g("gbraid"), wbraid: g("wbraid"),
            gad_source: g("gad_source"), gad_campaignid: g("gad_campaignid"),
            msclkid: g("msclkid"), ttclid: g("ttclid"),
            // first-touch
            utm_source_ft: ft("utm_source"), utm_medium_ft: ft("utm_medium"), utm_campaign_ft: ft("utm_campaign"),
            utm_term_ft: ft("utm_term"), utm_content_ft: ft("utm_content"),
            gclid_ft: ft("gclid"), fbclid_ft: ft("fbclid"), gbraid_ft: ft("gbraid"), wbraid_ft: ft("wbraid"),
            gad_source_ft: ft("gad_source"), gad_campaignid_ft: ft("gad_campaignid"),
            msclkid_ft: ft("msclkid"), ttclid_ft: ft("ttclid"),
            fbp: cookie("_fbp"), fbc: cookie("_fbc"),
            referrer: f.referrer || document.referrer || "", landing: f.landing || location.pathname,
            session_attributes: sa,
          };
        };
      })();
    </script>

    <!-- Handler único de formulários: valida, envia o lead (POST /api/lead →
         Mailchimp + webhook), dispara a conversão no tracking-kit e redireciona.
         Vale para qualquer form[data-trk-event]. data-trk-event="denuncia"
         não é enviado ao Mailchimp/webhook nem ao tracking (apenas UI). -->
    <script is:inline>
      document.addEventListener("submit", function (e) {
        var form = e.target && e.target.closest && e.target.closest("form[data-trk-event]");
        if (!form) return;
        e.preventDefault();
        if (form.checkValidity && !form.checkValidity()) { form.reportValidity(); return; }

        var evt = form.getAttribute("data-trk-event");
        var d = {};
        new FormData(form).forEach(function (v, k) { d[k] = v; });

        // Denúncia: confirmação na própria página (sensível) — sem envio/tracking.
        if (evt === "denuncia") {
          form.hidden = true;
          var scopeD = form.parentElement || document;
          var okD = scopeD.querySelector(".form-success");
          if (okD) okD.hidden = false;
          return;
        }

        // Conversão (evento Lead): guardamos os dados e disparamos na /obrigado.
        // Fazer aqui correria com o redirect (400ms) e o Pixel Helper só veria o
        // PageView da /obrigado. Disparar na thank-you page é confiável e visível.
        try {
          sessionStorage.setItem("tpl_lead_pending", JSON.stringify({
            email: d.email || "", phone: d.telefone || "", name: d.nome || "", norma: d.norma || "",
          }));
        } catch (_) {}
        // Aguarda o fetch completar antes de redirecionar (max 5s).
        // Evita que iOS Safari / mobile cancele o request na navegação.
        var btn = form.querySelector('[type="submit"]');
        if (btn) { btn.disabled = true; }
        var destino = form.getAttribute("data-obrigado") || "/obrigado";
        var _rDone = false;
        function _go() { if (!_rDone) { _rDone = true; window.location.href = destino; } }
        var _t = setTimeout(_go, 5000); // fallback: redireciona em no máximo 5s
        try {
          // UTMs: localStorage (via __tplAttrib) + fallback direto da URL atual
          var _attrib = (window.__tplAttrib && window.__tplAttrib()) || {};
          var _urlP = new URLSearchParams(location.search);
          ["utm_source","utm_medium","utm_campaign","utm_term","utm_content",
           "gclid","fbclid","gad_source","gad_campaignid","msclkid","ttclid","gbraid","wbraid"
          ].forEach(function(k) { if (!_attrib[k] && _urlP.get(k)) _attrib[k] = _urlP.get(k); });
          fetch("/api/lead", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            keepalive: true,
            body: JSON.stringify(Object.assign({
              nome: d.nome || "", email: d.email || "", telefone: d.telefone || "",
              empresa: d.empresa || "", norma: d.norma || "", mensagem: d.mensagem || "",
              cargo: d.cargo || "", urgencia: d.urgencia || "", funcionarios: d.funcionarios || "",
              evento: evt, pagina: location.pathname,
            }, _attrib)),
          }).then(function() { clearTimeout(_t); _go(); }).catch(function() { clearTimeout(_t); _go(); });
        } catch (_) { clearTimeout(_t); _go(); }
      });
    </script>

    <script is:inline>
      document.addEventListener("input", function (e) {
        var el = e.target;
        if (!el || el.tagName !== "INPUT" || el.name !== "telefone") return;
        var d = el.value.replace(/\D/g, "").substring(0, 11);
        var len = d.length;
        var mask = "";
        if (len === 0) { el.value = ""; return; }
        if (len <= 2) { mask = "(" + d; }
        else if (len <= 6) { mask = "(" + d.slice(0,2) + ") " + d.slice(2); }
        else if (len <= 10) { mask = "(" + d.slice(0,2) + ") " + d.slice(2,6) + "-" + d.slice(6); }
        else { mask = "(" + d.slice(0,2) + ") " + d.slice(2,7) + "-" + d.slice(7); }
        el.value = mask;
      });
    </script>
  </body>
</html>
