---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import TrackingKit from "../components/TrackingKit.astro";

const {
  title = "Templum Consultoria — Certificação ISO com garantia de 200%",
  description = "Há +30 anos a Templum organiza a gestão da sua empresa do diagnóstico à auditoria, com método próprio e garantia de 200%: certificação ou o dobro do dinheiro de volta.",
  ogImage = "/assets/img/garantia-200.png",
  noHeaderFooter = false,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="pt_BR" />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Montserrat (Medium / SemiBold / Bold / Extrabold) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <!-- Ícones (Iconify) -->
    <script src="https://cdn.jsdelivr.net/npm/iconify-icon@2/dist/iconify-icon.min.js" is:inline></script>

    <!-- Tracking (tracking-kit) -->
    <TrackingKit />
  </head>
  <body>
    {!noHeaderFooter && <Header />}
    <main>
      <slot />
    </main>
    {!noHeaderFooter && <Footer />}
    {!noHeaderFooter && (
      <a class="whatsapp-float" href="https://wa.me/5519993521270" target="_blank" rel="noopener" aria-label="Falar no WhatsApp">
        <iconify-icon icon="ic:baseline-whatsapp"></iconify-icon>
      </a>
    )}

    <!-- Reveal on scroll -->
    <script is:inline>
      (function () {
        const els = document.querySelectorAll(".reveal");
        if (!("IntersectionObserver" in window) || !els.length) {
          els.forEach((el) => el.classList.add("is-in"));
          return;
        }
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add("is-in");
                io.unobserve(e.target);
              }
            });
          },
          { threshold: 0.12 }
        );
        els.forEach((el) => io.observe(el));
      })();
    </script>

    <!-- Handler único de formulários: valida, envia o lead (POST /api/lead →
         Mailchimp), dispara a conversão no tracking-kit e mostra o sucesso.
         Vale para qualquer form[data-trk-event]. data-trk-event="denuncia"
         não é enviado ao Mailchimp nem ao tracking (apenas UI). -->
    <script is:inline>
      document.addEventListener("submit", function (e) {
        var form = e.target && e.target.closest && e.target.closest("form[data-trk-event]");
        if (!form) return;
        e.preventDefault();
        if (form.checkValidity && !form.checkValidity()) { form.reportValidity(); return; }

        var evt = form.getAttribute("data-trk-event");
        var d = {};
        new FormData(form).forEach(function (v, k) { d[k] = v; });

        // Denúncia: confirmação na própria página (sensível) — sem envio/tracking.
        if (evt === "denuncia") {
          form.hidden = true;
          var scopeD = form.parentElement || document;
          var okD = scopeD.querySelector(".form-success");
          if (okD) okD.hidden = false;
          return;
        }

        // Lead: dispara conversão (tracking-kit → pixels + CAPI) + grava no Mailchimp.
        if (window.trk && typeof window.trk.lead === "function") {
          try { window.trk.lead({ email: d.email, phone: d.telefone, name: d.nome }); } catch (_) {}
        }
        try {
          fetch("/api/lead", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            keepalive: true,
            body: JSON.stringify({
              nome: d.nome || "", email: d.email || "", telefone: d.telefone || "",
              empresa: d.empresa || "", norma: d.norma || "", mensagem: d.mensagem || "",
              cargo: d.cargo || "", urgencia: d.urgencia || "", funcionarios: d.funcionarios || "",
              evento: evt, pagina: location.pathname,
            }),
          });
        } catch (_) {}

        // Feedback imediato no botão e redireciona para a página de obrigado
        // (a conversão conta no pageview da /obrigado). keepalive garante o envio.
        var btn = form.querySelector('[type="submit"]');
        if (btn) { btn.disabled = true; }
        setTimeout(function () { window.location.href = "/obrigado"; }, 400);
      });
    </script>
  </body>
</html>
