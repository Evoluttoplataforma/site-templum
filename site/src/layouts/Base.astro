---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const {
  title = "Templum Consultoria — Certificação ISO com garantia de 200%",
  description = "Há +30 anos a Templum organiza a gestão da sua empresa do diagnóstico à auditoria, com método próprio e garantia de 200%: certificação ou o dobro do dinheiro de volta.",
  ogImage = "/assets/img/garantia-200.png",
  noHeaderFooter = false,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/jpeg" href="/assets/logo/favicon.jpeg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="pt_BR" />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Montserrat (Medium / SemiBold / Bold / Extrabold) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <!-- Ícones (Iconify) -->
    <script src="https://cdn.jsdelivr.net/npm/iconify-icon@2/dist/iconify-icon.min.js" is:inline></script>
  </head>
  <body>
    {!noHeaderFooter && <Header />}
    <main>
      <slot />
    </main>
    {!noHeaderFooter && <Footer />}
    {!noHeaderFooter && (
      <a class="whatsapp-float" href="https://wa.me/5519993521270" target="_blank" rel="noopener" aria-label="Falar no WhatsApp">
        <iconify-icon icon="ic:baseline-whatsapp"></iconify-icon>
      </a>
    )}

    <!-- Reveal on scroll -->
    <script is:inline>
      (function () {
        const els = document.querySelectorAll(".reveal");
        if (!("IntersectionObserver" in window) || !els.length) {
          els.forEach((el) => el.classList.add("is-in"));
          return;
        }
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add("is-in");
                io.unobserve(e.target);
              }
            });
          },
          { threshold: 0.12 }
        );
        els.forEach((el) => io.observe(el));
      })();
    </script>
  </body>
</html>
