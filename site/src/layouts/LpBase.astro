---
import "../styles/global.css";
import TrackingKit from "../components/TrackingKit.astro";

const {
  title = "Templum Consultoria — Certificação ISO com garantia de 200%",
  description = "Há +30 anos a Templum organiza a gestão da sua empresa do diagnóstico à auditoria, com método próprio e garantia de 200%: certificação ou o dobro do dinheiro de volta.",
  ogImage = "/assets/og/templum-og.jpg",
  noindex = true,
  formAnchor = "#form",
  schemas = [],
} = Astro.props;

const SITE = (Astro.site?.href || "https://templum.com.br/").replace(/\/$/, "");
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImageUrl = new URL(ogImage, Astro.site).href;

const allSchemas = schemas;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      window.gtag = function(){ dataLayer.push(arguments); };
      (function () {
        var done = false;
        function boot() {
          if (done) return; done = true;
          (function(c,l,a,r,i,t,y){c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);})(window,document,"clarity","script","sr5nwfj8jc");
          var g=document.createElement("script");g.async=true;g.src="https://www.googletagmanager.com/gtag/js?id=G-2BW8QTYLB5";document.head.appendChild(g);
          gtag("js", new Date());
          gtag("config","G-2BW8QTYLB5",{send_page_view:false});
          gtag("config","G-FV41GWD427",{send_page_view:false});
          gtag("config","AW-17896226473");
          if (typeof window.__loadTrackingKit === "function") window.__loadTrackingKit();
        }
        var evs = ["pointerdown","touchstart","keydown","scroll","mousemove"];
        var opts = { once: true, passive: true, capture: true };
        function once(){ evs.forEach(function(e){ window.removeEventListener(e, once, opts); }); boot(); }
        evs.forEach(function(e){ window.addEventListener(e, once, opts); });
        window.addEventListener("load", function(){
          var idle = window.requestIdleCallback || function(cb){ return setTimeout(cb, 6000); };
          idle(function(){ setTimeout(boot, 6000); });
        });
      })();
    </script>

    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Templum Consultoria" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content="pt_BR" />

    {allSchemas.map((s) => (
      <script type="application/ld+json" set:html={JSON.stringify(s)} />
    ))}

    <link rel="preload" as="font" type="font/woff2" href="/fonts/montserrat-500.woff2" crossorigin />
    <link rel="preload" as="font" type="font/woff2" href="/fonts/montserrat-600.woff2" crossorigin />
    <link rel="preload" as="font" type="font/woff2" href="/fonts/montserrat-800.woff2" crossorigin />

    <script src="https://cdn.jsdelivr.net/npm/iconify-icon@2/dist/iconify-icon.min.js" defer is:inline></script>

    <TrackingKit />
  </head>
  <body>

    <!-- ── HEADER LP ── -->
    <header class="lp-header">
      <div class="lp-header-inner">
        <span class="lp-logo">
          <img src="/assets/logo/templum.png" alt="Templum Consultoria" class="lp-logo-img" />
        </span>
        <div class="lp-header-right">
          <a href={formAnchor} class="btn btn--primary lp-cta-btn">
            Falar com especialista
            <iconify-icon icon="solar:arrow-right-linear"></iconify-icon>
          </a>
        </div>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <!-- ── FOOTER LP ── -->
    <footer class="lp-footer">
      <div class="lp-footer-inner">
        <div class="lp-footer-brand">
          <img src="/assets/logo/templum.png" alt="Templum Consultoria" class="lp-footer-logo" />
          <p>Certificação ISO com garantia de 200%</p>
        </div>
        <div class="lp-footer-links">
          <a href="https://templum.com.br">templum.com.br</a>
          <a href="https://templum.com.br/politica-de-privacidade">Política de privacidade</a>
          <a href="tel:+5519993521270">(19) 99352-1270</a>
        </div>
      </div>
    </footer>

    <!-- Reveal on scroll -->
    <script is:inline>
      (function () {
        const els = document.querySelectorAll(".reveal");
        if (!("IntersectionObserver" in window) || !els.length) {
          els.forEach((el) => el.classList.add("is-in"));
          return;
        }
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) { e.target.classList.add("is-in"); io.unobserve(e.target); }
            });
          },
          { threshold: 0.12 }
        );
        els.forEach((el) => io.observe(el));
      })();
    </script>

    <!-- Atribuição UTM + click-ids -->
    <script is:inline>
      (function () {
        var KEYS = ["utm_source","utm_medium","utm_campaign","utm_term","utm_content","gclid","fbclid","gbraid","wbraid","gad_source","gad_campaignid","msclkid","ttclid"];
        function uuid() { try { return crypto.randomUUID(); } catch (_) { return "x" + Date.now().toString(36) + Math.random().toString(36).slice(2, 10); } }
        function cookie(n) { var m = document.cookie.match("(^|;)\\s*" + n + "\\s*=\\s*([^;]+)"); return m ? decodeURIComponent(m.pop()) : ""; }
        try {
          var p = new URLSearchParams(location.search), cur = {}, now = Date.now();
          KEYS.forEach(function (k) { var v = p.get(k); if (v) cur[k] = v; });
          if (!localStorage.getItem("tpl_first")) {
            localStorage.setItem("tpl_first", JSON.stringify(Object.assign({ landing: location.pathname, referrer: document.referrer || "", first_seen: now }, cur)));
          }
          if (Object.keys(cur).length) localStorage.setItem("tpl_last", JSON.stringify(cur));
          if (!localStorage.getItem("tpl_cid")) localStorage.setItem("tpl_cid", uuid());
          if (!sessionStorage.getItem("tpl_sid")) { sessionStorage.setItem("tpl_sid", uuid()); sessionStorage.setItem("tpl_sstart", String(now)); sessionStorage.setItem("tpl_spages", "0"); }
          sessionStorage.setItem("tpl_spages", String((parseInt(sessionStorage.getItem("tpl_spages") || "0", 10)) + 1));
        } catch (_) {}
        window.__tplAttrib = function () {
          var f = {}, l = {};
          try { f = JSON.parse(localStorage.getItem("tpl_first") || "{}"); } catch (_) {}
          try { l = JSON.parse(localStorage.getItem("tpl_last") || "{}"); } catch (_) {}
          function g(k) { return l[k] || f[k] || ""; }
          function ft(k) { return f[k] || ""; }
          var sa = {
            device: /Mobi|Android|iPhone|iPad/i.test(navigator.userAgent) ? "mobile" : "desktop",
            language: navigator.language || "",
            screen: (screen.width || 0) + "x" + (screen.height || 0),
            landing: f.landing || location.pathname,
            referrer: f.referrer || document.referrer || "",
            first_seen: f.first_seen || "",
            session_start: sessionStorage.getItem("tpl_sstart") || "",
            page_count: sessionStorage.getItem("tpl_spages") || "1",
          };
          return {
            client_id: localStorage.getItem("tpl_cid") || "",
            session_id: sessionStorage.getItem("tpl_sid") || "",
            utm_source: g("utm_source"), utm_medium: g("utm_medium"), utm_campaign: g("utm_campaign"),
            utm_term: g("utm_term"), utm_content: g("utm_content"),
            gclid: g("gclid"), fbclid: g("fbclid"), gbraid: g("gbraid"), wbraid: g("wbraid"),
            gad_source: g("gad_source"), gad_campaignid: g("gad_campaignid"),
            msclkid: g("msclkid"), ttclid: g("ttclid"),
            utm_source_ft: ft("utm_source"), utm_medium_ft: ft("utm_medium"), utm_campaign_ft: ft("utm_campaign"),
            utm_term_ft: ft("utm_term"), utm_content_ft: ft("utm_content"),
            gclid_ft: ft("gclid"), fbclid_ft: ft("fbclid"), gbraid_ft: ft("gbraid"), wbraid_ft: ft("wbraid"),
            gad_source_ft: ft("gad_source"), gad_campaignid_ft: ft("gad_campaignid"),
            msclkid_ft: ft("msclkid"), ttclid_ft: ft("ttclid"),
            fbp: cookie("_fbp"), fbc: cookie("_fbc"),
            referrer: f.referrer || document.referrer || "", landing: f.landing || location.pathname,
            session_attributes: sa,
          };
        };
      })();
    </script>

    <!-- Handler formulários (igual ao Base.astro) -->
    <script is:inline>
      document.addEventListener("submit", function (e) {
        var form = e.target && e.target.closest && e.target.closest("form[data-trk-event]");
        if (!form) return;
        e.preventDefault();
        if (form.checkValidity && !form.checkValidity()) { form.reportValidity(); return; }
        var evt = form.getAttribute("data-trk-event");
        var d = {};
        new FormData(form).forEach(function (v, k) { d[k] = v; });
        try {
          sessionStorage.setItem("tpl_lead_pending", JSON.stringify({
            email: d.email || "", phone: d.telefone || "", name: d.nome || "", norma: d.norma || "",
          }));
        } catch (_) {}
        try {
          fetch("/api/lead", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            keepalive: true,
            body: JSON.stringify(Object.assign({
              nome: d.nome || "", email: d.email || "", telefone: d.telefone || "",
              empresa: d.empresa || "", norma: d.norma || "", mensagem: d.mensagem || "",
              cargo: d.cargo || "", urgencia: d.urgencia || "", funcionarios: d.funcionarios || "",
              evento: evt, pagina: location.pathname,
            }, (window.__tplAttrib && window.__tplAttrib()) || {})),
          });
        } catch (_) {}
        var btn = form.querySelector('[type="submit"]');
        if (btn) { btn.disabled = true; }
        var destino = form.getAttribute("data-obrigado") || "/obrigado";
        setTimeout(function () { window.location.href = destino; }, 400);
      });
    </script>

    <!-- Máscara telefone -->
    <script is:inline>
      document.addEventListener("input", function (e) {
        var el = e.target;
        if (!el || el.tagName !== "INPUT" || el.name !== "telefone") return;
        var d = el.value.replace(/\D/g, "").substring(0, 11);
        var len = d.length;
        var mask = "";
        if (len === 0) { el.value = ""; return; }
        if (len <= 2) { mask = "(" + d; }
        else if (len <= 6) { mask = "(" + d.slice(0,2) + ") " + d.slice(2); }
        else if (len <= 10) { mask = "(" + d.slice(0,2) + ") " + d.slice(2,6) + "-" + d.slice(6); }
        else { mask = "(" + d.slice(0,2) + ") " + d.slice(2,7) + "-" + d.slice(7); }
        el.value = mask;
      });
    </script>

  </body>
</html>

<style is:global>
  html, body { scroll-behavior: smooth; }

  /* ── HEADER LP ── */
  .lp-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--navy);
    border-bottom: 1px solid rgba(255,244,221,0.10);
    padding: 0 clamp(16px, 4vw, 40px);
  }
  .lp-header-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
    gap: 16px;
  }
  .lp-logo { display: flex; align-items: center; }
  .lp-logo-img { height: 36px; width: auto; display: block; filter: brightness(0) invert(1); }
  .lp-header-right { display: flex; align-items: center; gap: 16px; }
  .lp-tel {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-size: 14px;
    font-weight: 600;
    color: rgba(255,244,221,0.75);
    text-decoration: none;
    transition: color .2s;
  }
  .lp-tel iconify-icon { font-size: 18px; color: var(--orange); }
  .lp-tel:hover { color: var(--cream); }
  .lp-cta-btn { font-size: 14px; padding: 10px 20px; white-space: nowrap; }
  @media (max-width: 480px) {
    .lp-logo-img { height: 28px; }
    .lp-cta-btn { padding: 9px 14px; font-size: 13px; }
    .lp-cta-btn iconify-icon { display: none; }
  }

  /* ── FOOTER LP ── */
  .lp-footer {
    background: var(--navy);
    border-top: 1px solid rgba(255,244,221,0.10);
    padding: 28px clamp(16px, 4vw, 40px);
  }
  .lp-footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    flex-wrap: wrap;
  }
  .lp-footer-brand { display: flex; flex-direction: column; gap: 4px; }
  .lp-footer-logo { height: 36px; width: auto; display: block; filter: brightness(0) invert(1); }
  .lp-footer-brand p { font-size: 12px; color: rgba(255,244,221,0.45); margin: 2px 0 0; }
  .lp-footer-links { display: flex; gap: 20px; flex-wrap: wrap; }
  .lp-footer-links a { font-size: 13px; color: rgba(255,244,221,0.5); text-decoration: none; transition: color .2s; }
  .lp-footer-links a:hover { color: var(--cream); }
</style>
